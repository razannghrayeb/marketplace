script-source,140,node:internal/util/diff,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayIsArray\x2C\x0d\n  ArrayPrototypeReverse\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst { validateStringArray\x2C validateString } = require('internal/validators');\x0d\nconst { myersDiff } = require('internal/assert/myers_diff');\x0d\n\x0d\nfunction validateInput(value\x2C name) {\x0d\n  if (!ArrayIsArray(value)) {\x0d\n    validateString(value\x2C name);\x0d\n    return;\x0d\n  }\x0d\n\x0d\n  validateStringArray(value\x2C name);\x0d\n}\x0d\n\x0d\n/**\x0d\n * Generate a difference report between two values\x0d\n * @param {Array | string} actual - The first value to compare\x0d\n * @param {Array | string} expected - The second value to compare\x0d\n * @returns {Array} - An array of differences between the two values.\x0d\n *   The returned data is an array of arrays\x2C where each sub-array has two elements:\x0d\n *   1. The operation to perform: -1 for delete\x2C 0 for no-op\x2C 1 for insert\x0d\n *   2. The value to perform the operation on\x0d\n */\x0d\nfunction diff(actual\x2C expected) {\x0d\n  if (actual === expected) {\x0d\n    return [];\x0d\n  }\x0d\n\x0d\n  validateInput(actual\x2C 'actual');\x0d\n  validateInput(expected\x2C 'expected');\x0d\n\x0d\n  return ArrayPrototypeReverse(myersDiff(actual\x2C expected));\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  diff\x2C\x0d\n};\x0d\n

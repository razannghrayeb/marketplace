is.#writing = false;\x0d\n      if (this.#sync) {\x0d\n        if (!this.#asyncDrainScheduled) {\x0d\n          this.#asyncDrainScheduled = true;\x0d\n          process.nextTick(() => this.#emitDrain());\x0d\n        }\x0d\n      } else {\x0d\n        this.emit('drain');\x0d\n      }\x0d\n    }\x0d\n  }\x0d\n\x0d\n  #openFile(file) {\x0d\n    this.#opening = true;\x0d\n    this.#writing = true;\x0d\n    this.#asyncDrainScheduled = false;\x0d\n\x0d\n    // NOTE: 'error' and 'ready' events emitted below only relevant when sonic.sync===false\x0d\n    // for sync mode\x2C there is no way to add a listener that will receive these\x0d\n\x0d\n    const fileOpened = (err\x2C fd) => {\x0d\n      if (err) {\x0d\n        this.#reopening = false;\x0d\n        this.#writing = false;\x0d\n        this.#opening = false;\x0d\n\x0d\n        if (this.#sync) {\x0d\n          process.nextTick(() => {\x0d\n            if (this.listenerCount('error') > 0) {\x0d\n              this.emit('error'\x2C err);\x0d\n            }\x0d\n          });\x0d\n        } else {\x0d\n          this.emit('error'\x2C err);\x0d\n        }\x0d\n        return;\x0d\n      }\x0d\n\x0d\n      const reopening = this.#reopening;\x0d\n\x0d\n      this.#fd = fd;\x0d\n      this.#file = file;\x0d\n      this.#reopening = false;\x0d\n      this.#opening = false;\x0d\n      this.#writing = false;\x0d\n\x0d\n      if (this.#sync) {\x0d\n        process.nextTick(() => this.emit('ready'));\x0d\n      } else {\x0d\n        this.emit('ready');\x0d\n      }\x0d\n\x0d\n      if (this.#destroyed) {\x0d\n        return;\x0d\n      }\x0d\n\x0d\n      // start\x0d\n      if ((!this.#writing && this.#len > this.#minLength) || this.#flushPending) {\x0d\n        this.#actualWrite();\x0d\n      } else if (reopening) {\x0d\n        process.nextTick(() => this.emit('drain'));\x0d\n      }\x0d\n    };\x0d\n\x0d\n    const flags = this.#append ? 'a' : 'w';\x0d\n    const mode = this.#mode;\x0d\n\x0d\n    if (this.#sync) {\x0d\n      try
th\x2C { base\x2C specifier\x2C isESM } = kEmptyObject) {\x0d\n  // This function will be called by both CJS and ESM\x2C so we need to make sure\x0d\n  // non-null attributes are converted to strings.\x0d\n  const parsed = modulesBinding.readPackageJSON(\x0d\n    jsonPath\x2C\x0d\n    isESM\x2C\x0d\n    base == null ? undefined : `${base}`\x2C\x0d\n    specifier == null ? undefined : `${specifier}`\x2C\x0d\n  );\x0d\n\x0d\n  const result = deserializePackageJSON(jsonPath\x2C parsed);\x0d\n\x0d\n  return {\x0d\n    __proto__: null\x2C\x0d\n    ...result.data\x2C\x0d\n    exists: result.exists\x2C\x0d\n    pjsonPath: result.path\x2C\x0d\n  };\x0d\n}\x0d\n\x0d\n/**\x0d\n * A cache mapping a module's path to its parent `package.json` file's path.\x0d\n * This is used in concert with `deserializedPackageJSONCache` to improve\x0d\n * the performance of `getNearestParentPackageJSON` when called repeatedly\x0d\n * on the same module paths.\x0d\n */\x0d\nconst moduleToParentPackageJSONCache = new SafeMap();\x0d\n\x0d\n/**\x0d\n * A cache mapping the path of a `package.json` file to its\x0d\n * {@link DeserializedPackageConfig deserialized representation}\x2C\x0d\n * as produced by {@link deserializedPackageJSONCache}. The purpose of this\x0d\n * cache is to ensure that we always return the same\x0d\n * {@link DeserializedPackageConfig} instance for a given `package.json`\x2C\x0d\n * which is necessary to ensure that we don't re-parse `imports` and\x0d\n * `exports` redundantly.\x0d\n */\x0d\nconst deserializedPackageJSONCache = new SafeMap();\x0d\n\x0d\n/**\x0d\n * Get the nearest parent package.json file from a given path.\x0d\n * Return the package.json data and the path to the package.json file\x2C or undefined.\x0d\n * @param {string} checkPath The path to start searching from.\x0d\n * @returns {undefined | DeserializedPackageConfig}\x0d\n */\x0d\nfunction getNearestParentPackageJSON(checkPath) {\x0d\n  const parentPackageJSONPath = moduleToParentPackageJSONCache.get(checkPath);\x0d\n  if (parentPackageJSONPath !== undefined) {\x0d\n    return deserializedPackageJSONCache.get(parentPackageJSONPath);\x0d\n  }\x0d\n\x0d\n  const result = modulesBinding.getNearestParentPackageJSON(checkPath);\x0d\n  const packageConfig = deserializePackageJSON(checkPath\x2C result);\x0d\n\x0d\n  moduleToParentPackageJSONCache.set(checkPath\x2C packageConfig.path);\x0d\n\x0d\n  const maybeCachedPackageConfig = deserializedPackageJSONCache.get(packageConfig.path);\x0d\n  if (maybeCachedPackageConfig !== undefined) {\x0d\n    return maybeCachedPackageConfig;\x0d\n  }\x0d\n\x0d\n  deserializedPackageJSONCache.set(packageConfig.path\x2C packageConfig);\x0d\n  return packageConfig;\x0d\n}\x0d\n\x0d\n/**\x0d\n * Returns the package configuration for the given resolved URL.\x0d\n * @param {URL | string} resolved - The resolved URL.\x0d\n * @returns {import('typings/internalBinding/modules').PackageConfig} - The package configuration.\x0d\n */\x0d\nfunction getPackageScopeConfig(resolved) {\x0d\n  const result = modulesBinding.getPackageScopeConfig(`${resolved}`);\x0d\n\x0d\n  if (ArrayIsArray(result)) {\x0d\n    const { data\x2C exists\x2C path } = deserializePackageJSON(`${resolved}`\x2C result);\x0d\n\x0d\n    return {\x0d\n      __proto__: null\x2C\x0d\n      ...data\x2C\x0d\n      exists\x2C\x0d\n      pjsonPath: path\x2C\x0d\n    };\x0d\n  }\x0d\n\x0d\n  // This means that the response is a string\x0d\n  // and it is the path to the package.json file\x0d\n  return {\x0d\n    __proto__: null\x2C\x0d\n    pjsonPath: result\x2C\x0d\n    exists: false\x2C\x0d\n    type: 'none'\x2C\x0d\n  };\x0d\n}\x0d\n\x0d\n/**\x0d\n * Returns the package type for a given URL.\x0d\n * @param {URL} url - The URL to get the package type for.\x0d\n * @returns {string}\x0d\n */\x0d\nfunction getPackageType(url) {\x0d\n  const type = modulesBinding.getPackageType(`${url}`);\x0d\n  return type ?? 'none';\x0d\n}\x0d\n\x0d\nconst invalidPackageNameRegEx = /^\\.|%|\\\\/;\x0d\n/**\x0d\n * Parse a package name from a specifier.\x0d\n * @param {string} specifier - The import specifier.\x0d\n * @param {string | URL | undefined} base - The parent URL.\x0d\n * @returns {object}\x0d\n */\x0d\nfunction parsePackageName(specifier\x2C base) {\x0d\n  let separatorIndex = StringPrototypeIndexOf(specifier\x2C '/');\x0d\n  let validPackageName = true;\x0d\n  let isScoped = false;\x0d\n  if (specifier[0] === '@') {\x0d\n    isScoped = true;\x0d\n    if (separatorIndex === -1 || specifier.length === 0) {\x0d\n      validPackageName = false;\x0d\n    } else {\x0d\n      separatorIndex = StringPrototypeIndexOf(\x0d\n        specifier\x2C '/'\x2C separatorIndex + 1);\x0d\n    }\x0d\n  }\x0d\n\x0d\n  const packageName = separatorIndex === -1 ?\x0d\n    specifier : StringPrototypeSlice(specifier\x2C 0\x2C separatorIndex);\x0d\n\x0d\n  // Package name cannot have leading . and cannot have percent-encoding or\x0d\n  // \\\\ separators.\x0d\n  if (RegExpPrototypeExec(invalidPackageNameRegEx\x2C packageName) !== null) {\x0d\n    validPackageName = false;\x0d\n  }\x0d\n\x0d\n  if (!validPackageName) {\x0d\n    throw new ERR_INVALID_MODULE_SPECIFIER(\x0d\n      specifier\x2C 'is not a valid package name'\x2C fileURLToPath(base));\x0d\n  }\x0d\n\x0d\n  const packageSubpath = '.' + (separatorIndex === -1 ? '' :\x0d\n    StringPrototypeSlice(specifier\x2C separatorIndex));\x0d\n\x0d\n  return { packageName\x2C packageSubpath\x2C isScoped };\x0d\n}\x0d\n\x0d\nfunction getPackageJSONURL(specifier\x2C base) {\x0d\n  const { packageName\x2C packageSubpath\x2C isScoped } = parsePackageName(specifier\x2C base);\x0d\n\x0d\n  // ResolveSelf\x0d\n  const packageConfig = getPackageScopeConfig(base);\x0d\n  if (packageConfig.exists) {\x0d\n    if (packageConfig.exports != null && packageConfig.name === packageName) {\x0d\n      const packageJSONPath = packageConfig.pjsonPath;\x0d\n      return { packageJSONUrl: pathToFileURL(packageJSONPath)\x2C packageJSONPath\x2C packageSubpath };\x0d\n    }\x0d\n  }\x0d\n\x0d\n  let packageJSONUrl = new URL(`./node_modules/${packageName}/package.json`\x2C base);\x0d\n  let packageJSONPath = fileURLToPath(packageJSONUrl);\x0d\n  let lastPath;\x0d\n  do {\x0d\n    const stat = internalFsBinding.internalModuleStat(\x0d\n      StringPrototypeSlice(packageJSONPath\x2C 0\x2C packageJSONPath.length - 13)\x2C\x0d\n    );\x0d\n    // Check for !stat.isDirectory()\x0d\n    if (stat !== 1) {\x0d\n      lastPath = packageJSONPath;\x0d\n      packageJSONUrl = new URL(\x0d\n        `${isScoped ? '../' : ''}../../../node_modules/${packageName}/package.json`\x2C\x0d\n        packageJSONUrl\x2C\x0d\n      );\x0d\n      packageJSONPath = fileURLToPath(packageJSONUrl);\x0d\n      continue;\x0d\n    }\x0d\n\x0d\n    // Package match.\x0d\n    return { packageJSONUrl\x2C packageJSONPath\x2C packageSubpath };\x0d\n  } while (packageJSONPath.length !== lastPath.length);\x0d\n\x0d\n  throw new ERR_MODULE_NOT_FOUND(packageName\x2C fileURLToPath(base)\x2C null);\x0d\n}\x0d\n\x0d\n/** @type {import('./esm/resolve.js').defaultResolve} */\x0d\nlet defaultResolve;\x0d\n/**\x0d\n * @param {string | URL} specifier The location for which to get the "root" package.json\x0d\n * @param {string | URL} [base] The location of the current module (ex file://tmp/foo.js).\x0d\n * @returns {string}\x0d\n */\x0d\nfunction findPackageJSON(specifier\x2C base = 'data:') {\x0d\n  if (arguments.length === 0) {\x0d\n    throw new ERR_MISSING_ARGS('specifier');\x0d\n  }\x0d\n  try {\x0d\n    specifier = `${specifier}`;\x0d\n  } catch {\x0d\n    validateString(specifier\x2C 'specifier');\x0d\n  }\x0d\n\x0d\n  let parentURL = base;\x0d\n  if (!isURL(base)) {\x0d\n    validateString(base\x2C 'base');\x0d\n    parentURL = path.isAbsolute(base) ? pathToFileURL(base) : new URL(base);\x0d\n  }\x0d\n\x0d\n  if (specifier && specifier[0] !== '.' && specifier[0] !== '/' && !URLCanParse(specifier)) {\x0d\n    // If `specifier` is a bare specifier.\x0d\n    const { packageJSONPath } = getPackageJSONURL(specifier\x2C parentURL);\x0d\n    return packageJSONPath;\x0d\n  }\x0d\n\x0d\n  let resolvedTarget;\x0d\n  defaultResolve ??= require('internal/modules/esm/resolve').defaultResolve;\x0d\n\x0d\n  try {\x0d\n    // TODO(@JakobJingleheimer): Detect whether findPackageJSON is being used within a loader\x0d\n    // (possibly piggyback on `allowImportMetaResolve`)\x0d\n    // - When inside\x2C use the default resolve\x0d\n    //   - (I think it's impossible to use the chain because of re-entry & a deadlock from atomics).\x0d\n    // - When outside\x2C use cascadedLoader.resolveSync (not implemented yet\x2C but the pieces exist).\x0d\n    resolvedTarget = defaultResolve(specifier\x2C { parentURL: `${parentURL}` }).url;\x0d\n  } catch (err) {\x0d\n    if (err.code === 'ERR_UNSUPPORTED_DIR_IMPORT') {\x0d\n      resolvedTarget = err.url;\x0d\n    } else {\x0d\n      throw err;\x0d\n    }\x0d\n  }\x0d\n\x0d\n  const pkg = getNearestParentPackageJSON(fileURLToPath(resolvedTarget));\x0d\n\x0d\n  return pkg?.path;\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  read\x2C\x0d\n  getNearestParentPackageJSON\x2C\x0d\n  getPackageScopeConfig\x2C\x0d\n  getPackageType\x2C\x0d\n  getPackageJSONURL\x2C\x0d\n  findPackageJSON\x2C\x0d\n};\x0d\n

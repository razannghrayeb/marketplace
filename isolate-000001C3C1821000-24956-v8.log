x0d\n\x0d\nconst DOT_CODE = 46;\x0d\nconst SLASH_CODE = 47;\x0d\n\x0d\n/**\x0d\n * Returns the file extension from a URL. Should give similar result to\x0d\n * `require('node:path').extname(require('node:url').fileURLToPath(url))`\x0d\n * when used with a `file:` URL.\x0d\n * @param {URL} url\x0d\n * @returns {string}\x0d\n */\x0d\nfunction extname(url) {\x0d\n  const { pathname } = url;\x0d\n  for (let i = pathname.length - 1; i > 0; i--) {\x0d\n    switch (StringPrototypeCharCodeAt(pathname\x2C i)) {\x0d\n      case SLASH_CODE:\x0d\n        return '';\x0d\n\x0d\n      case DOT_CODE:\x0d\n        return StringPrototypeCharCodeAt(pathname\x2C i - 1) === SLASH_CODE ? '' : StringPrototypeSlice(pathname\x2C i);\x0d\n    }\x0d\n  }\x0d\n  return '';\x0d\n}\x0d\n\x0d\n/**\x0d\n * Determine whether the given file URL is under a `node_modules` folder.\x0d\n * This function assumes that the input has already been verified to be a `file:` URL\x2C\x0d\n * and is a file rather than a folder.\x0d\n * @param {URL} url\x0d\n * @returns {boolean}\x0d\n */\x0d\nfunction underNodeModules(url) {\x0d\n  if (url.protocol !== 'file:') { return false; } // We determine module types for other protocols based on MIME header\x0d\n\x0d\n  return StringPrototypeIncludes(url.pathname\x2C '/node_modules/');\x0d\n}\x0d\n\x0d\nlet typelessPackageJsonFilesWarnedAbout;\x0d\nfunction warnTypelessPackageJsonFile(pjsonPath\x2C url) {\x0d\n  typelessPackageJsonFilesWarnedAbout ??= new SafeSet();\x0d\n  if (!underNodeModules(url) && !typelessPackageJsonFilesWarnedAbout.has(pjsonPath)) {\x0d\n    const warning = `Module type of ${url} is not specified and it doesn't parse as CommonJS.\\n` +\x0d\n      'Reparsing as ES module because module syntax was detected. This incurs a performance overhead.\\n' +\x0d\n      `To eliminate this warning\x2C add "type": "module" to ${pjsonPath}.`;\x0d\n    process.emitWarning(warning\x2C {\x0d\n      code: 'MODULE_TYPELESS_PACKAGE_JSON'\x2C\x0d\n    });\x0d\n    typelessPackageJsonFilesWarnedAbout.add(pjsonPath);\x0d\n  }\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {URL} url\x0d\n * @param {{parentURL: string; source?: Buffer}} context\x0d\n * @param {boolean} ignoreErrors\x0d\n * @returns {string}\x0d\n */\x0d\nfunction getFileProtocolModuleFormat(url\x2C context = { __proto__: null }\x2C ignoreErrors) {\x0d\n  const { source } = context;\x0d\n  const ext = extname(url);\x0d\n\x0d\n  if (ext === '.js') {\x0d\n    const { type: packageType\x2C pjsonPath\x2C exists: foundPackageJson } = getPackageScopeConfig(url);\x0d\n    if (packageType !== 'none') {\x0d\n      return packageType;\x0d\n    }\x0d\n\x0d\n    // The controlling `package.json` file has no `type` field.\x0d\n    // `source` is undefined when this is called from `defaultResolve`;\x0d\n    // but this gets called again from `defaultLoad`/`defaultLoadSync`.\x0d\n    // For ambiguous files (.js\x2C no type field) we return undefined from `resolve` and re-run the check in `load`.\x0d\n    const format = detectModuleFormat(source\x2C url);\x0d\n    if (format === 'module' && foundPackageJson) {\x0d\n      // This module has a .js extension\x2C a package.json with no `type` field\x2C and ESM syntax.\x0d\n      // Warn about the missing `type` field so that the user can avoid the performance penalty of detection.\x0d\n      warnTypelessPackageJsonFile(pjsonPath\x2C url);\x0d\n    }\x0d\n    return format;\x0d\n  }\x0d\n  if (ext === '.ts' && getOptionValue('--strip-types')) {\x0d\n    const { type: packageType\x2C pjsonPath\x2C exists: foundPackageJson } = getPackageScopeConfig(url);\x0d\n    if (packageType !== 'none') {\x0d\n      return `${packageType}-typescript`;\x0d\n    }\x0d\n    // The controlling `package.json` file has no `type` field.\x0d\n    // `source` is undefined when this is called from `defaultResolve`;\x0d\n    // but this gets called again from `defaultLoad`/`defaultLoadSync`.\x0d\n    // Since strip-types depends on detect-module\x2C we always return null if source is undefined.\x0d\n    if (!source) { return null; }\x0d\n    const { stringify } = require('internal/modules/helpers');\x0d\n    const { stripTypeScriptModuleTypes } = require('internal/modules/typescript');\x0d\n    const stringifiedSource = stringify(source);\x0d\n    const parsedSource = stripTypeScriptModuleTypes(stringifiedSource\x2C fileURLToPath(url));\x0d\n    const detectedFormat = detectModuleFormat(parsedSource\x2C url);\x0d\n    const format = `${detectedFormat}-typescript`;\x0d\n    if (format === 'module-typescript' && foundPackageJson) {\x0d\n      // This module has a .js extension\x2C a package.json with no `type` field\x2C and ESM syntax.\x0d\n      // Warn about the missing `type` field so that the user can avoid the performance penalty of detection.\x0d\n      warnTypelessPackageJsonFile(pjsonPath\x2C url);\x0d\n    }\x0d\n    return format;\x0d\n  }\x0d\n\x0d\n  if (ext === '') {\x0d\n    const packageType = getPackageType(url);\x0d\n    if (packageType === 'module') {\x0d\n      return getFormatOfExtensionlessFile(url);\x0d\n    }\x0d\n    if (packageType !== 'none') {\x0d\n      return packageType; // 'commonjs' or future package types\x0d\n    }\x0d\n\x0d\n    // The controlling `package.json` file has no `type` field.\x0d\n    if (!source) {\x0d\n      return null;\x0d\n    }\x0d\n    const format = getFormatOfExtensionlessFile(url);\x0d\n    if (format === 'wasm') {\x0d\n      return format;\x0d\n    }\x0d\n    return detectModuleFormat(source\x2C url);\x0d\n  }\x0d\n\x0d\n  const format = extensionFormatMap[ext];\x0d\n  if (format) { return format; }\x0d\n\x0d\n  // Explicit undefined return indicates load hook should rerun format check\x0d\n  if (ignoreErrors) { return undefined; }\x0d\n  const filepath = fileURLToPath(url);\x0d\n  throw new ERR_UNKNOWN_FILE_EXTENSION(ext\x2C filepath);\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {URL} url\x0d\n * @param {{parentURL: string}} context\x0d\n * @returns {Promise<string> | string | undefined} only works when enabled\x0d\n */\x0d\nfunction defaultGetFormatWithoutErrors(url\x2C context) {\x0d\n  const protocol = url.protocol;\x0d\n  if (!ObjectPrototypeHasOwnProperty(protocolHandlers\x2C protocol)) {\x0d\n    return null;\x0d\n  }\x0d\n  return protocolHandlers[protocol](url\x2C context\x2C true);\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {URL} url\x0d\n * @param {{parentURL: string}} context\x0d\n * @returns {Promise<string> | string | undefined} only works when enabled\x0d\n */\x0d\nfunction defaultGetFormat(url\x2C context) {\x0d\n  const protocol = url.protocol;\x0d\n  if (!ObjectPrototypeHasOwnProperty(protocolHandlers\x2C protocol)) {\x0d\n    return null;\x0d\n  }\x0d\n  return protocolHandlers[protocol](url\x2C context\x2C false);\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  defaultGetFormat\x2C\x0d\n  defaultGetFormatWithoutErrors\x2C\x0d\n  extensionFormatMap\x2C\x0d\n  extname\x2C\x0d\n};\x0d\n

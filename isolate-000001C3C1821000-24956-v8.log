N\x0d\n    // parse error instead of just manipulating the original error message.\x0d\n    // That would allow to add further properties and maybe additional\x0d\n    // debugging information.\x0d\n    err.message = errPath(url) + ': ' + err.message;\x0d\n    throw err;\x0d\n  }\x0d\n  if (shouldCheckAndPopulateCJSModuleCache) {\x0d\n    CJSModule._cache[modulePath] = module;\x0d\n  }\x0d\n  cjsCache.set(url\x2C module);\x0d\n  return new ModuleWrap(url\x2C undefined\x2C ['default']\x2C function() {\x0d\n    debug(`Parsing JSONModule ${url}`);\x0d\n    this.setExport('default'\x2C module.exports);\x0d\n  });\x0d\n});\x0d\n\x0d\n// Strategy for loading a wasm module\x0d\n// This logic should collapse into WebAssembly Module Record in future.\x0d\n/**\x0d\n * @type {WeakMap<\x0d\n *   import('internal/modules/esm/utils').ModuleNamespaceObject\x2C\x0d\n *   WebAssembly.Instance\x0d\n * >} [[Instance]] slot proxy for WebAssembly Module Record\x0d\n */\x0d\nconst wasmInstances = new SafeWeakMap();\x0d\ntranslators.set('wasm'\x2C function(url\x2C translateContext) {\x0d\n  const { source } = translateContext;\x0d\n  assertBufferSource(source\x2C false\x2C 'load');\x0d\n\x0d\n  debug(`Translating WASMModule ${url}`\x2C translateContext);\x0d\n\x0d\n  let compiled;\x0d\n  try {\x0d\n    compiled = new WebAssembly.Module(source\x2C {\x0d\n      builtins: ['js-string']\x2C\x0d\n    });\x0d\n  } catch (err) {\x0d\n    err.message = errPath(url) + ': ' + err.message;\x0d\n    throw err;\x0d\n  }\x0d\n\x0d\n  const importsList = new SafeSet();\x0d\n  const wasmGlobalImports = [];\x0d\n  for (const impt of WebAssembly.Module.imports(compiled)) {\x0d\n    if (impt.kind === 'global') {\x0d\n      ArrayPrototypePush(wasmGlobalImports\x2C impt);\x0d\n    }\x0d\n    // Prefix reservations per https://webassembly.github.io/esm-integration/js-api/index.html#parse-a-webassembly-module.\x0d\n    if (impt.module.startsWith('wasm-js:')) {\x0d\n      throw new WebAssembly.LinkError(`Invalid
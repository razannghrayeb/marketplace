script-source,68,node:internal/modules/package_json_reader,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayIsArray\x2C\x0d\n  JSONParse\x2C\x0d\n  ObjectDefineProperty\x2C\x0d\n  RegExpPrototypeExec\x2C\x0d\n  SafeMap\x2C\x0d\n  StringPrototypeIndexOf\x2C\x0d\n  StringPrototypeSlice\x2C\x0d\n} = primordials;\x0d\nconst {\x0d\n  fileURLToPath\x2C\x0d\n  isURL\x2C\x0d\n  pathToFileURL\x2C\x0d\n  URL\x2C\x0d\n} = require('internal/url');\x0d\nconst { canParse: URLCanParse } = internalBinding('url');\x0d\nconst {\x0d\n  codes: {\x0d\n    ERR_INVALID_MODULE_SPECIFIER\x2C\x0d\n    ERR_MISSING_ARGS\x2C\x0d\n    ERR_MODULE_NOT_FOUND\x2C\x0d\n  }\x2C\x0d\n} = require('internal/errors');\x0d\nconst { kEmptyObject } = require('internal/util');\x0d\nconst modulesBinding = internalBinding('modules');\x0d\nconst path = require('path');\x0d\nconst { validateString } = require('internal/validators');\x0d\nconst internalFsBinding = internalBinding('fs');\x0d\n\x0d\n\x0d\n/**\x0d\n * @typedef {import('typings/internalBinding/modules').DeserializedPackageConfig} DeserializedPackageConfig\x0d\n * @typedef {import('typings/internalBinding/modules').PackageConfig} PackageConfig\x0d\n * @typedef {import('typings/internalBinding/modules').SerializedPackageConfig} SerializedPackageConfig\x0d\n */\x0d\n\x0d\n/**\x0d\n * @param {URL['pathname']} path\x0d\n * @param {SerializedPackageConfig} contents\x0d\n * @returns {DeserializedPackageConfig}\x0d\n */\x0d\nfunction deserializePackageJSON(path\x2C contents) {\x0d\n  if (contents === undefined) {\x0d\n    return {\x0d\n      data: {\x0d\n        __proto__: null\x2C\x0d\n        type: 'none'\x2C // Ignore unknown types for forwards compatibility\x0d\n      }\x2C\x0d\n      exists: false\x2C\x0d\n      path\x2C\x0d\n    };\x0d\n  }\x0d\n\x0d\n  const {\x0d\n    0: name\x2C\x0d\n    1: main\x2C\x0d\n    2: type\x2C\x0d\n    3: plainImports\x2C\x0d\n    4: plainExports\x2C\x0d\n    5: optionalFilePath\x2C\x0d\n  } = contents;\x0d\n\x0d\n  const pjson
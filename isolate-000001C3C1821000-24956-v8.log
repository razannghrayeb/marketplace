ol;\x0d\n\x0d\nconst kIsMainSymbol = Symbol('kIsMainSymbol');\x0d\nconst kIsCachedByESMLoader = Symbol('kIsCachedByESMLoader');\x0d\nconst kRequiredModuleSymbol = Symbol('kRequiredModuleSymbol');\x0d\nconst kIsExecuting = Symbol('kIsExecuting');\x0d\n\x0d\nconst kURL = Symbol('kURL');\x0d\nconst kFormat = Symbol('kFormat');\x0d\n\x0d\n// Set first due to cycle with ESM loader functions.\x0d\nmodule.exports = {\x0d\n  kModuleSource\x2C\x0d\n  kModuleExport\x2C\x0d\n  kModuleExportNames\x2C\x0d\n  kModuleCircularVisited\x2C\x0d\n  initializeCJS\x2C\x0d\n  Module\x2C\x0d\n  findLongestRegisteredExtension\x2C\x0d\n  resolveForCJSWithHooks\x2C\x0d\n  loadSourceForCJSWithHooks: loadSource\x2C\x0d\n  populateCJSExportsFromESM\x2C\x0d\n  wrapSafe\x2C\x0d\n  wrapModuleLoad\x2C\x0d\n  kIsMainSymbol\x2C\x0d\n  kIsCachedByESMLoader\x2C\x0d\n  kRequiredModuleSymbol\x2C\x0d\n  kIsExecuting\x2C\x0d\n};\x0d\n\x0d\nconst { BuiltinModule } = require('internal/bootstrap/realm');\x0d\nconst {\x0d\n  maybeCacheSourceMap\x2C\x0d\n} = require('internal/source_map/source_map_cache');\x0d\nconst { pathToFileURL\x2C fileURLToPath\x2C isURL\x2C URL } = require('internal/url');\x0d\nconst {\x0d\n  pendingDeprecate\x2C\x0d\n  emitExperimentalWarning\x2C\x0d\n  kEmptyObject\x2C\x0d\n  setOwnProperty\x2C\x0d\n  getLazy\x2C\x0d\n  isWindows\x2C\x0d\n  isUnderNodeModules\x2C\x0d\n} = require('internal/util');\x0d\nconst {\x0d\n  makeContextifyScript\x2C\x0d\n  runScriptInThisContext\x2C\x0d\n} = require('internal/vm');\x0d\nconst {\x0d\n  containsModuleSyntax\x2C\x0d\n  compileFunctionForCJSLoader\x2C\x0d\n} = internalBinding('contextify');\x0d\n\x0d\nconst assert = require('internal/assert');\x0d\nconst fs = require('fs');\x0d\nconst path = require('path');\x0d\nconst internalFsBinding = internalBinding('fs');\x0d\nconst { safeGetenv } = internalBinding('credentials');\x0d\nconst {\x0d\n  getCjsConditions\x2C\x0d\n  getCjsConditionsArray\x2C\x0d\n  initializeCjsConditions\x2C\x0d\n  loadBuiltinMod
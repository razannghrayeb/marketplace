script-source,148,node:internal/worker/messaging,'use strict';\x0d\n\x0d\nconst {\x0d\n  AtomicsNotify\x2C\x0d\n  AtomicsStore\x2C\x0d\n  AtomicsWaitAsync\x2C\x0d\n  Int32Array\x2C\x0d\n  SafeMap\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  isMainThread\x2C\x0d\n  threadId: currentThreadId\x2C\x0d\n} = internalBinding('worker');\x0d\n\x0d\nconst {\x0d\n  constructSharedArrayBuffer\x2C\x0d\n} = require('internal/util');\x0d\n\x0d\nconst {\x0d\n  codes: {\x0d\n    ERR_WORKER_MESSAGING_ERRORED\x2C\x0d\n    ERR_WORKER_MESSAGING_FAILED\x2C\x0d\n    ERR_WORKER_MESSAGING_SAME_THREAD\x2C\x0d\n    ERR_WORKER_MESSAGING_TIMEOUT\x2C\x0d\n  }\x2C\x0d\n} = require('internal/errors');\x0d\n\x0d\nconst { MessageChannel } = require('internal/worker/io');\x0d\n\x0d\nconst { validateNumber } = require('internal/validators');\x0d\n\x0d\nconst messageTypes = {\x0d\n  REGISTER_MAIN_THREAD_PORT: 'registerMainThreadPort'\x2C\x0d\n  UNREGISTER_MAIN_THREAD_PORT: 'unregisterMainThreadPort'\x2C\x0d\n  SEND_MESSAGE_TO_WORKER: 'sendMessageToWorker'\x2C\x0d\n  RECEIVE_MESSAGE_FROM_WORKER: 'receiveMessageFromWorker'\x2C\x0d\n};\x0d\n\x0d\n// This is only populated by main thread and always empty in other threads\x0d\nconst threadsPorts = new SafeMap();\x0d\n\x0d\n// This is only populated in child threads and always undefined in main thread\x0d\nlet mainThreadPort;\x0d\n\x0d\n// SharedArrayBuffer must always be Int32\x2C so it's * 4.\x0d\n// We need one for the operation status (performing / performed) and one for the result (success / failure).\x0d\nconst WORKER_MESSAGING_SHARED_DATA = 2 * 4;\x0d\nconst WORKER_MESSAGING_STATUS_INDEX = 0;\x0d\nconst WORKER_MESSAGING_RESULT_INDEX = 1;\x0d\n\x0d\n// Response codes\x0d\nconst WORKER_MESSAGING_RESULT_DELIVERED = 0;\x0d\nconst WORKER_MESSAGING_RESULT_NO_LISTENERS = 1;\x0d\nconst WORKER_MESSAGING_RESULT_LISTENER_ERROR = 2;\x0d\n\x0d\n// This event handler is always executed on the main thread only\x0d\nfunction handleMessageFromThread(message) {\x0d\n  switch (message.type) {\x0d\n    case messageTypes.REGISTER_MAIN_THREAD_PORT:\x0d\n      {\x0d\n        const { threadId\x2C port } = message;\x0d\n\x0d\n        // Register the port\x0d\n        threadsPorts.set(threadId\x2C port);\x0d\n\x0d\n        // Handle messages on this port\x0d\n        // When a new thread wants to register a children\x0d\n        // this take care of doing that.\x0d\n        // This way any thread can be linked to the main one.\x0d\n        port.on('message'\x2C handleMessageFromThread);\x0d\n\x0d\n        // Never block the thread on this port\x0d\n        port.unref();\x0d\n      }\x0d\n\x0d\n      break;\x0d\n    case messageTypes.UNREGISTER_MAIN_THREAD_PORT:\x0d\n      threadsPorts.get(message.threadId).close();\x0d\n      threadsPorts.delete(message.threadId);\x0d\n      break;\x0d\n    case messageTypes.SEND_MESSAGE_TO_WORKER:\x0d\n      {\x0d\n        // Send the message to the target thread\x0d\n        const { source\x2C destination\x2C value\x2C transferList\x2C memory } = message;\x0d\n        sendMessageToWorker(source\x2C destination\x2C value\x2C transferList\x2C memory);\x0d\n      }\x0d\n      break;\x0d\n  }\x0d\n}\x0d\n\x0d\nfunction handleMessageFromMainThread(message) {\x0d\n  switch (message.type) {\x0d\n    case messageTypes.RECEIVE_MESSAGE_FROM_WORKER:\x0d\n      receiveMessageFromWorker(message.source\x2C message.value\x2C message.memory);\x0d\n      break;\x0d\n  }\x0d\n}\x0d\n\x0d\nfunction sendMessageToWorker(source\x2C destination\x2C value\x2C transferList\x2C memory) {\x0d\n  // We are on the main thread\x2C we can directly process the message\x0d\n  if (destination === 0) {\x0d\n    receiveMessageFromWorker(source\x2C value\x2C memory);\x0d\n    return;\x0d\n  }\x0d\n\x0d\n  // Search the port to the target thread\x0d\n  const port = threadsPorts.get(destination);\x0d\n\x0d\n  if (!port) {\x0d\n    const status = new Int32Array(memory);\x0d\n    AtomicsStore(status\x2C WORKER_MESSAGING_RESULT_INDEX\x2C WORKER_MESSAGING_RESULT_NO_LISTENERS);\x0d\n    AtomicsStore(status\x2C WORKER_MESSAGING_STATUS_INDEX\x2C 1);\x0d\n    AtomicsNotify(status\x2C WORKER_MESSAGING_STATUS_INDEX\x2C 1);\x0d\n    return;\x0d\n  }\x0d\n\x0d\n  port.postMessage(\x0d\n    {\x0d\n      type: messageTypes.RECEIVE_MESSAGE_FROM_WORKER\x2C\x0d\n      source\x2C\x0d\n      destination\x2C\x0d\n      value\x2C\x0d\n      memory\x2C\x0d\n    }\x2C\x0d\n    transferList\x2C\x0d\n  );\x0d\n}\x0d\n\x0d\nfunction receiveMessageFromWorker(source\x2C value\x2C memory) {\x0d\n  let response = WORKER_MESSAGING_RESULT_NO_LISTENERS;\x0d\n\x0d\n  try {\x0d\n    if (process.emit('workerMessage'\x2C value\x2C source)) {\x0d\n      response = WORKER_MESSAGING_RESULT_DELIVERED;\x0d\n    }\x0d\n  } catch {\x0d\n    response = WORKER_MESSAGING_RESULT_LISTENER_ERROR;\x0d\n  }\x0d\n\x0d\n  // Populate the result\x0d\n  const status = new Int32Array(memory);\x0d\n  AtomicsStore(status\x2C WORKER_MESSAGING_RESULT_INDEX\x2C response);\x0d\n  AtomicsStore(status\x2C WORKER_MESSAGING_STATUS_INDEX\x2C 1);\x0d\n  AtomicsNotify(status\x2C WORKER_MESSAGING_STATUS_INDEX\x2C 1);\x0d\n}\x0d\n\x0d\nfunction createMainThreadPort(threadId) {\x0d\n  // Create a channel that links the new thread to the main thread\x0d\n  const {\x0d\n    port1: mainThreadPortToMain\x2C\x0d\n    port2: mainThreadPortToThread\x2C\x0d\n  } = new MessageChannel();\x0d\n\x0d\n  const registrationMessage = {\x0d\n    type: messageTypes.REGISTER_MAIN_THREAD_PORT\x2C\x0d\n    threadId\x2C\x0d\n    port: mainThreadPortToMain\x2C\x0d\n  };\x0d\n\x0d\n  if (isMainThread) {\x0d\n    handleMessageFromThread(registrationMessage);\x0d\n  } else {\x0d\n    mainThreadPort.postMessage(registrationMessage\x2C [mainThreadPortToMain]);\x0d\n  }\x0d\n\x0d\n  return mainThreadPortToThread;\x0d\n}\x0d\n\x0d\nfunction destroyMainThreadPort(threadId) {\x0d\n  const unregistrationMessage = {\x0d\n    type: messageTypes.UNREGISTER_MAIN_THREAD_PORT\x2C\x0d\n    threadId\x2C\x0d\n  };\x0d\n\x0d\n  if (isMainThread) {\x0d\n    handleMessageFromThread(unregistrationMessage);\x0d\n  } else {\x0d\n    mainThreadPort.postMessage(unregistrationMessage);\x0d\n  }\x0d\n}\x0d\n\x0d\nfunction setupMainThreadPort(port) {\x0d\n  mainThreadPort = port;\x0d\n  mainThreadPort.on('message'\x2C handleMessageFromMainThread);\x0d\n\x0d\n  // Never block the process on this port\x0d\n  mainThreadPort.unref();\x0d\n}\x0d\n\x0d\nasync function postMessageToThread(threadId\x2C value\x2C transferList\x2C timeout) {\x0d\n  if (typeof transferList === 'number' && typeof timeout === 'undefined') {\x0d\n    timeout = transferList;\x0d\n    transferList = [];\x0d\n  }\x0d\n\x0d\n  if (typeof timeout !== 'undefined') {\x0d\n    validateNumber(timeout\x2C 'timeout'\x2C 0);\x0d\n  }\x0d\n\x0d\n  if (threadId === currentThreadId) {\x0d\n    throw new ERR_WORKER_MESSAGING_SAME_THREAD();\x0d\n  }\x0d\n\x0d\n  const memory = constructSharedArrayBuffer(WORKER_MESSAGING_SHARED_DATA);\x0d\n  const status = new Int32Array(memory);\x0d\n  const promise = AtomicsWaitAsync(status\x2C WORKER_MESSAGING_STATUS_INDEX\x2C 0\x2C timeout).value;\x0d\n\x0d\n  const message = {\x0d\n    type: messageTypes.SEND_MESSAGE_TO_WORKER\x2C\x0d\n    source: currentThreadId\x2C\x0d\n    destination: threadId\x2C\x0d\n    value\x2C\x0d\n    memory\x2C\x0d\n    transferList\x2C\x0d\n  };\x0d\n\x0d\n  if (isMainThread) {\x0d\n    handleMessageFromThread(message);\x0d\n  } else {\x0d\n    mainThreadPort.postMessage(message\x2C transferList);\x0d\n  }\x0d\n\x0d\n  // Wait for the response\x0d\n  const response = await promise;\x0d\n\x0d\n  if (response === 'timed-out') {\x0d\n    throw new ERR_WORKER_MESSAGING_TIMEOUT();\x0d\n  } else if (status[WORKER_MESSAGING_RESULT_INDEX] === WORKER_MESSAGING_RESULT_NO_LISTENERS) {\x0d\n    throw new ERR_WORKER_MESSAGING_FAILED();\x0d\n  } else if (status[WORKER_MESSAGING_RESULT_INDEX] === WORKER_MESSAGING_RESULT_LISTENER_ERROR) {\x0d\n    throw new ERR_WORKER_MESSAGING_ERRORED();\x0d\n  }\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  createMainThreadPort\x2C\x0d\n  destroyMainThreadPort\x2C\x0d\n  setupMainThreadPort\x2C\x0d\n  postMessageToThread\x2C\x0d\n};\x0d\n

script-source,171,node:internal/crypto/kem,'use strict';\x0d\n\x0d\nconst {\x0d\n  FunctionPrototypeCall\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  codes: {\x0d\n    ERR_CRYPTO_KEM_NOT_SUPPORTED\x2C\x0d\n  }\x2C\x0d\n} = require('internal/errors');\x0d\n\x0d\nconst {\x0d\n  validateFunction\x2C\x0d\n} = require('internal/validators');\x0d\n\x0d\nconst {\x0d\n  kCryptoJobAsync\x2C\x0d\n  kCryptoJobSync\x2C\x0d\n  KEMDecapsulateJob\x2C\x0d\n  KEMEncapsulateJob\x2C\x0d\n} = internalBinding('crypto');\x0d\n\x0d\nconst {\x0d\n  preparePrivateKey\x2C\x0d\n  preparePublicOrPrivateKey\x2C\x0d\n} = require('internal/crypto/keys');\x0d\n\x0d\nconst {\x0d\n  getArrayBufferOrView\x2C\x0d\n} = require('internal/crypto/util');\x0d\n\x0d\nfunction encapsulate(key\x2C callback) {\x0d\n  if (!KEMEncapsulateJob)\x0d\n    throw new ERR_CRYPTO_KEM_NOT_SUPPORTED();\x0d\n\x0d\n  if (callback !== undefined)\x0d\n    validateFunction(callback\x2C 'callback');\x0d\n\x0d\n  const {\x0d\n    data: keyData\x2C\x0d\n    format: keyFormat\x2C\x0d\n    type: keyType\x2C\x0d\n    passphrase: keyPassphrase\x2C\x0d\n  } = preparePublicOrPrivateKey(key);\x0d\n\x0d\n  const job = new KEMEncapsulateJob(\x0d\n    callback ? kCryptoJobAsync : kCryptoJobSync\x2C\x0d\n    keyData\x2C\x0d\n    keyFormat\x2C\x0d\n    keyType\x2C\x0d\n    keyPassphrase);\x0d\n\x0d\n  if (!callback) {\x0d\n    const { 0: err\x2C 1: result } = job.run();\x0d\n    if (err !== undefined)\x0d\n      throw err;\x0d\n    const { 0: sharedKey\x2C 1: ciphertext } = result;\x0d\n    return { sharedKey\x2C ciphertext };\x0d\n  }\x0d\n\x0d\n  job.ondone = (error\x2C result) => {\x0d\n    if (error) return FunctionPrototypeCall(callback\x2C job\x2C error);\x0d\n    const { 0: sharedKey\x2C 1: ciphertext } = result;\x0d\n    FunctionPrototypeCall(callback\x2C job\x2C null\x2C { sharedKey\x2C ciphertext });\x0d\n  };\x0d\n  job.run();\x0d\n}\x0d\n\x0d\nfunction decapsulate(key\x2C ciphertext\x2C callback) {\x0d\n  if (!KEMDecapsulateJob)\x0d\n    throw new ERR_CRYPTO_KEM_NOT_SUPPORTED();\x0d\n\x0d\n  if (callback !== undefined)\x0d\n    validateFunction(callback\x2C 'callback');\x0d\n\x0d\n  const {\x0d\n    data: keyData\x2C\x0d\n    format: keyFormat\x2C\x0d\n    type: keyType\x2C\x0d\n    passphrase: keyPassphrase\x2C\x0d\n  } = preparePrivateKey(key);\x0d\n\x0d\n  ciphertext = getArrayBufferOrView(ciphertext\x2C 'ciphertext');\x0d\n\x0d\n  const job = new KEMDecapsulateJob(\x0d\n    callback ? kCryptoJobAsync : kCryptoJobSync\x2C\x0d\n    keyData\x2C\x0d\n    keyFormat\x2C\x0d\n    keyType\x2C\x0d\n    keyPassphrase\x2C\x0d\n    ciphertext);\x0d\n\x0d\n  if (!callback) {\x0d\n    const { 0: err\x2C 1: result } = job.run();\x0d\n    if (err !== undefined)\x0d\n      throw err;\x0d\n\x0d\n    return result;\x0d\n  }\x0d\n\x0d\n  job.ondone = (error\x2C result) => {\x0d\n    if (error) return FunctionPrototypeCall(callback\x2C job\x2C error);\x0d\n    FunctionPrototypeCall(callback\x2C job\x2C null\x2C result);\x0d\n  };\x0d\n  job.run();\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  encapsulate\x2C\x0d\n  decapsulate\x2C\x0d\n};\x0d\n

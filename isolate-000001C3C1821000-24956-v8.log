script-source,21,node:internal/async_context_frame,'use strict';\x0d\n\x0d\nconst {\x0d\n  ObjectSetPrototypeOf\x2C\x0d\n  SafeMap\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  getContinuationPreservedEmbedderData\x2C\x0d\n  setContinuationPreservedEmbedderData\x2C\x0d\n} = internalBinding('async_context_frame');\x0d\n\x0d\nlet enabled_;\x0d\n\x0d\nclass ActiveAsyncContextFrame extends SafeMap {\x0d\n  static get enabled() {\x0d\n    return true;\x0d\n  }\x0d\n\x0d\n  static current() {\x0d\n    return getContinuationPreservedEmbedderData();\x0d\n  }\x0d\n\x0d\n  static set(frame) {\x0d\n    setContinuationPreservedEmbedderData(frame);\x0d\n  }\x0d\n\x0d\n  static exchange(frame) {\x0d\n    const prior = this.current();\x0d\n    this.set(frame);\x0d\n    return prior;\x0d\n  }\x0d\n\x0d\n  static disable(store) {\x0d\n    const frame = this.current();\x0d\n    frame?.disable(store);\x0d\n  }\x0d\n}\x0d\n\x0d\nfunction checkEnabled() {\x0d\n  const enabled = require('internal/options')\x0d\n    .getOptionValue('--async-context-frame');\x0d\n\x0d\n  // If enabled\x2C swap to active prototype so we don't need to check status\x0d\n  // on every interaction with the async context frame.\x0d\n  if (enabled) {\x0d\n    // eslint-disable-next-line no-use-before-define\x0d\n    ObjectSetPrototypeOf(AsyncContextFrame\x2C ActiveAsyncContextFrame);\x0d\n  }\x0d\n\x0d\n  return enabled;\x0d\n}\x0d\n\x0d\nclass InactiveAsyncContextFrame extends SafeMap {\x0d\n  static get enabled() {\x0d\n    enabled_ ??= checkEnabled();\x0d\n    return enabled_;\x0d\n  }\x0d\n\x0d\n  static current() {}\x0d\n  static set(frame) {}\x0d\n  static exchange(frame) {}\x0d\n  static disable(store) {}\x0d\n}\x0d\n\x0d\nclass AsyncContextFrame extends InactiveAsyncContextFrame {\x0d\n  constructor(store\x2C data) {\x0d\n    super(AsyncContextFrame.current());\x0d\n    this.set(store\x2C data);\x0d\n  }\x0d\n\x0d\n  disable(store) {\x0d\n    this.delete(store);\x0d\n  }\x0d\n}\x0d\n\x0d\nmodule.exports = AsyncContextFrame;\x0d\n

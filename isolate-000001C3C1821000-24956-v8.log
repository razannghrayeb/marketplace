script-source,129,node:internal/fs/dir,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayPrototypePush\x2C\x0d\n  ArrayPrototypeShift\x2C\x0d\n  FunctionPrototypeBind\x2C\x0d\n  ObjectDefineProperties\x2C\x0d\n  PromiseReject\x2C\x0d\n  SymbolAsyncDispose\x2C\x0d\n  SymbolAsyncIterator\x2C\x0d\n  SymbolDispose\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst pathModule = require('path');\x0d\nconst binding = internalBinding('fs');\x0d\nconst dirBinding = internalBinding('fs_dir');\x0d\nconst {\x0d\n  codes: {\x0d\n    ERR_DIR_CLOSED\x2C\x0d\n    ERR_DIR_CONCURRENT_OPERATION\x2C\x0d\n    ERR_INVALID_THIS\x2C\x0d\n    ERR_MISSING_ARGS\x2C\x0d\n  }\x2C\x0d\n} = require('internal/errors');\x0d\n\x0d\nconst { FSReqCallback } = binding;\x0d\nconst {\x0d\n  promisify\x2C\x0d\n} = require('internal/util');\x0d\nconst {\x0d\n  getDirent\x2C\x0d\n  getOptions\x2C\x0d\n  getValidatedPath\x2C\x0d\n} = require('internal/fs/utils');\x0d\nconst {\x0d\n  validateFunction\x2C\x0d\n  validateUint32\x2C\x0d\n} = require('internal/validators');\x0d\n\x0d\nclass Dir {\x0d\n  #handle;\x0d\n  #path;\x0d\n  #bufferedEntries = [];\x0d\n  #closed = false;\x0d\n  #options;\x0d\n  #readPromisified;\x0d\n  #closePromisified;\x0d\n  #operationQueue = null;\x0d\n  #handlerQueue = [];\x0d\n\x0d\n  constructor(handle\x2C path\x2C options) {\x0d\n    if (handle == null) throw new ERR_MISSING_ARGS('handle');\x0d\n    this.#handle = handle;\x0d\n    this.#path = path;\x0d\n    this.#options = {\x0d\n      bufferSize: 32\x2C\x0d\n      ...getOptions(options\x2C {\x0d\n        encoding: 'utf8'\x2C\x0d\n      })\x2C\x0d\n    };\x0d\n\x0d\n    try {\x0d\n      validateUint32(this.#options.bufferSize\x2C 'options.bufferSize'\x2C true);\x0d\n    } catch (validationError) {\x0d\n      // Userland won't be able to close handle if we throw\x2C so we close it first\x0d\n      this.#handle.close();\x0d\n      throw validationError;\x0d\n    }\x0d\n\x0d\n    this.#readPromisified = FunctionPrototypeBind(\x0d\n      promisify(this.#readImpl)\x2C this\x2C false);\x0d\n    this.#closePromisified = FunctionPrototypeBind(\x0d\n      promisify(this.close)\x2C this);\x0d\n  }\x0d\n\x0d\n  get path() {\x0d\n    if (!(#path in this))\x0d\n      throw new ERR_INVALID_THIS('Dir');\x0d\n    return this.#path;\x0d\n  }\x0d\n\x0d\n  #processHandlerQueue() {\x0d\n    while (this.#handlerQueue.length > 0) {\x0d\n      const handler = ArrayPrototypeShift(this.#handlerQueue);\x0d\n      const { handle\x2C path } = handler;\x0d\n\x0d\n      const result = handle.read(\x0d\n        this.#options.encoding\x2C\x0d\n        this.#options.bufferSize\x2C\x0d\n      );\x0d\n\x0d\n      if (result !== null) {\x0d\n        this.processReadResult(path\x2C result);\x0d\n        if (result.length > 0) {\x0d\n          ArrayPrototypePush(this.#handlerQueue\x2C handler);\x0d\n        }\x0d\n      } else {\x0d\n        handle.close();\x0d\n      }\x0d\n\x0d\n      if (this.#bufferedEntries.length > 0) {\x0d\n        break;\x0d\n      }\x0d\n    }\x0d\n\x0d\n    return this.#bufferedEntries.length > 0;\x0d\n  }\x0d\n\x0d\n  read(callback) {\x0d\n    return arguments.length === 0 ? this.#readPromisified() : this.#readImpl(true\x2C callback);\x0d\n  }\x0d\n\x0d\n  #readImpl(maybeSync\x2C callback) {\x0d\n    if (this.#closed === true) {\x0d\n      throw new ERR_DIR_CLOSED();\x0d\n    }\x0d\n\x0d\n    if (callback === undefined) {\x0d\n      return this.#readPromisified();\x0d\n    }\x0d\n\x0d\n    validateFunction(callback\x2C 'callback');\x0d\n\x0d\n    if (this.#operationQueue !== null) {\x0d\n      ArrayPrototypePush(this.#operationQueue\x2C () => {\x0d\n        this.#readImpl(maybeSync\x2C callback);\x0d\n      });\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    if (this.#processHandlerQueue()) {\x0d\n      try {\x0d\n        const dirent = ArrayPrototypeShift(this.#bufferedEntries);\x0d\n\x0d\n        if (this.#options.recursive && dirent.isDirectory()) {\x0d\n          this.readSyncRecursive(dirent);\x0d\n        }\x0d\n\x0d\n        if (maybeSync)\x0d\n          process.nextTick(callback\x2C null\x2C dirent);\x0d\n        else\x0d\n          callback(null\x2C dirent);\x0d\n        return;\x0d\n      } catch (error) {\x0d\n        return callback(error);\x0d\n      }\x0d\n    }\x0d\n\x0d\n    const req = new FSReqCallback();\x0d\n    req.oncomplete = (err\x2C result) => {\x0d\n      process.nextTick(() => {\x0d\n        const queue = this.#operationQueue;\x0d\n        this.#operationQueue = null;\x0d\n        for (const op of queue) op();\x0d\n      });\x0d\n\x0d\n      if (err || result === null) {\x0d\n        return callback(err\x2C result);\x0d\n      }\x0d\n\x0d\n      try {\x0d\n        this.processReadResult(this.#path\x2C result);\x0d\n        const dirent = ArrayPrototypeShift(this.#bufferedEntries);\x0d\n        if (this.#options.recursive && dirent.isDirectory()) {\x0d\n          this.readSyncRecursive(dirent);\x0d\n        }\x0d\n        callback(null\x2C dirent);\x0d\n      } catch (error) {\x0d\n        callback(error);\x0d\n      }\x0d\n    };\x0d\n\x0d\n    this.#operationQueue = [];\x0d\n    this.#handle.read(\x0d\n      this.#options.encoding\x2C\x0d\n      this.#options.bufferSize\x2C\x0d\n      req\x2C\x0d\n    );\x0d\n  }\x0d\n\x0d\n  processReadResult(path\x2C result) {\x0d\n    for (let i = 0; i < result.length; i += 2) {\x0d\n      ArrayPrototypePush(\x0d\n        this.#bufferedEntries\x2C\x0d\n        getDirent(\x0d\n          path\x2C\x0d\n          result[i]\x2C\x0d\n          result[i + 1]\x2C\x0d\n        )\x2C\x0d\n      );\x0d\n    }\x0d\n  }\x0d\n\x0d\n  readSyncRecursive(dirent) {\x0d\n    const path = pathModule.join(dirent.parentPath\x2C dirent.name);\x0d\n    const handle = dirBinding.opendir(\x0d\n      path\x2C\x0d\n      this.#options.encoding\x2C\x0d\n    );\x0d\n\x0d\n    if (handle === undefined) {\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    ArrayPrototypePush(this.#handlerQueue\x2C { handle\x2C path });\x0d\n  }\x0d\n\x0d\n  readSync() {\x0d\n    if (this.#closed === true) {\x0d\n      throw new ERR_DIR_CLOSED();\x0d\n    }\x0d\n\x0d\n    if (this.#operationQueue !== null) {\x0d\n      throw new ERR_DIR_CONCURRENT_OPERATION();\x0d\n    }\x0d\n\x0d\n    if (this.#processHandlerQueue()) {\x0d\n      const dirent = ArrayPrototypeShift(this.#bufferedEntries);\x0d\n      if (this.#options.recursive && dirent.isDirectory()) {\x0d\n        this.readSyncRecursive(dirent);\x0d\n      }\x0d\n      return dirent;\x0d\n    }\x0d\n\x0d\n    const result = this.#handle.read(\x0d\n      this.#options.encoding\x2C\x0d\n      this.#options.bufferSize\x2C\x0d\n    );\x0d\n\x0d\n    if (result === null) {\x0d\n      return result;\x0d\n    }\x0d\n\x0d\n    this.processReadResult(this.#path\x2C result);\x0d\n\x0d\n    const dirent = ArrayPrototypeShift(this.#bufferedEntries);\x0d\n    if (this.#options.recursive && dirent.isDirectory()) {\x0d\n      this.readSyncRecursive(dirent);\x0d\n    }\x0d\n    return dirent;\x0d\n  }\x0d\n\x0d\n  close(callback) {\x0d\n    if (callback === undefined) {\x0d\n      if (this.#closed === true) {\x0d\n        return PromiseReject(new ERR_DIR_CLOSED());\x0d\n      }\x0d\n      return this.#closePromisified();\x0d\n    }\x0d\n\x0d\n    validateFunction(callback\x2C 'callback');\x0d\n\x0d\n    if (this.#closed === true) {\x0d\n      process.nextTick(callback\x2C new ERR_DIR_CLOSED());\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    if (this.#operationQueue !== null) {\x0d\n      ArrayPrototypePush(this.#operationQueue\x2C () => {\x0d\n        this.close(callback);\x0d\n      });\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    while (this.#handlerQueue.length > 0) {\x0d\n      const handler = ArrayPrototypeShift(this.#handlerQueue);\x0d\n      handler.handle.close();\x0d\n    }\x0d\n\x0d\n    this.#closed = true;\x0d\n    const req = new FSReqCallback();\x0d\n    req.oncomplete = callback;\x0d\n    this.#handle.close(req);\x0d\n  }\x0d\n\x0d\n  closeSync() {\x0d\n    if (this.#closed === true) {\x0d\n      throw new ERR_DIR_CLOSED();\x0d\n    }\x0d\n\x0d\n    if (this.#operationQueue !== null) {\x0d\n      throw new ERR_DIR_CONCURRENT_OPERATION();\x0d\n    }\x0d\n\x0d\n    while (this.#handlerQueue.length > 0) {\x0d\n      const handler = ArrayPrototypeShift(this.#handlerQueue);\x0d\n      handler.handle.close();\x0d\n    }\x0d\n\x0d\n    this.#closed = true;\x0d\n    this.#handle.close();\x0d\n  }\x0d\n\x0d\n  async* entries() {\x0d\n    try {\x0d\n      while (true) {\x0d\n        const result = await this.#readPromisified();\x0d\n        if (result === null) {\x0d\n          break;\x0d\n        }\x0d\n        yield result;\x0d\n      }\x0d\n    } finally {\x0d\n      await this.#closePromisified();\x0d\n    }\x0d\n  }\x0d\n\x0d\n  [SymbolDispose]() {\x0d\n    if (this.#closed) return;\x0d\n    this.closeSync();\x0d\n  }\x0d\n\x0d\n  async [SymbolAsyncDispose]() {\x0d\n    if (this.#closed) return;\x0d\n    await this.#closePromisified();\x0d\n  }\x0d\n}\x0d\n\x0d\nObjectDefineProperties(Dir.prototype\x2C {\x0d\n  [SymbolAsyncIterator]: {\x0d\n    __proto__: null\x2C\x0d\n    enumerable: false\x2C\x0d\n    writable: true\x2C\x0d\n    configurable: true\x2C\x0d\n    value: Dir.prototype.entries\x2C\x0d\n  }\x2C\x0d\n});\x0d\n\x0d\nfunction opendir(path\x2C options\x2C callback) {\x0d\n  callback = typeof options === 'function' ? options : callback;\x0d\n  validateFunction(callback\x2C 'callback');\x0d\n\x0d\n  path = getValidatedPath(path);\x0d\n  options = getOptions(options\x2C {\x0d\n    encoding: 'utf8'\x2C\x0d\n  });\x0d\n\x0d\n  function opendirCallback(error\x2C handle) {\x0d\n    if (error) {\x0d\n      callback(error);\x0d\n    } else {\x0d\n      callback(null\x2C new Dir(handle\x2C path\x2C options));\x0d\n    }\x0d\n  }\x0d\n\x0d\n  const req = new FSReqCallback();\x0d\n  req.oncomplete = opendirCallback;\x0d\n\x0d\n  dirBinding.opendir(\x0d\n    path\x2C\x0d\n    options.encoding\x2C\x0d\n    req\x2C\x0d\n  );\x0d\n}\x0d\n\x0d\nfunction opendirSync(path\x2C options) {\x0d\n  path = getValidatedPath(path);\x0d\n  options = getOptions(options\x2C { encoding: 'utf8' });\x0d\n\x0d\n  const handle = dirBinding.opendirSync(path);\x0d\n\x0d\n  return new Dir(handle\x2C path\x2C options);\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  Dir\x2C\x0d\n  opendir\x2C\x0d\n  opendirSync\x2C\x0d\n};\x0d\n

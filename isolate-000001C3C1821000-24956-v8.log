script-source,156,node:internal/crypto/argon2,'use strict';\x0d\n\x0d\nconst {\x0d\n  FunctionPrototypeCall\x2C\x0d\n  MathPow\x2C\x0d\n  StringPrototypeToLowerCase\x2C\x0d\n  TypedArrayPrototypeGetBuffer\x2C\x0d\n  Uint8Array\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst { Buffer } = require('buffer');\x0d\n\x0d\nconst {\x0d\n  Argon2Job\x2C\x0d\n  kCryptoJobAsync\x2C\x0d\n  kCryptoJobSync\x2C\x0d\n  kTypeArgon2d\x2C\x0d\n  kTypeArgon2i\x2C\x0d\n  kTypeArgon2id\x2C\x0d\n} = internalBinding('crypto');\x0d\n\x0d\nconst {\x0d\n  lazyDOMException\x2C\x0d\n  promisify\x2C\x0d\n} = require('internal/util');\x0d\n\x0d\nconst {\x0d\n  getArrayBufferOrView\x2C\x0d\n  kKeyObject\x2C\x0d\n} = require('internal/crypto/util');\x0d\n\x0d\nconst {\x0d\n  validateString\x2C\x0d\n  validateFunction\x2C\x0d\n  validateInteger\x2C\x0d\n  validateObject\x2C\x0d\n  validateOneOf\x2C\x0d\n  validateUint32\x2C\x0d\n} = require('internal/validators');\x0d\n\x0d\nconst {\x0d\n  codes: {\x0d\n    ERR_CRYPTO_ARGON2_NOT_SUPPORTED\x2C\x0d\n  }\x2C\x0d\n} = require('internal/errors');\x0d\n\x0d\n/**\x0d\n * @param {'argon2d' | 'argon2i' | 'argon2id'} algorithm\x0d\n * @param {object} parameters\x0d\n * @param {ArrayBufferLike} parameters.message\x0d\n * @param {ArrayBufferLike} parameters.nonce\x0d\n * @param {number} parameters.parallelism\x0d\n * @param {number} parameters.tagLength\x0d\n * @param {number} parameters.memory\x0d\n * @param {number} parameters.passes\x0d\n * @param {ArrayBufferLike} [parameters.secret]\x0d\n * @param {ArrayBufferLike} [parameters.associatedData]\x0d\n * @param {Function} callback\x0d\n */\x0d\nfunction argon2(algorithm\x2C parameters\x2C callback) {\x0d\n  parameters = check(algorithm\x2C parameters);\x0d\n\x0d\n  validateFunction(callback\x2C 'callback');\x0d\n\x0d\n  const job = new Argon2Job(\x0d\n    kCryptoJobAsync\x2C\x0d\n    parameters.message\x2C\x0d\n    parameters.nonce\x2C\x0d\n    parameters.parallelism\x2C\x0d\n    parameters.tagLength\x2C\x0d\n    parameters.memory\x2C\x0d\n    parameters.passes\x2C\x0d\n    parameters.secret\x2C\x0d\n    parameters.associatedData\x2C\x0d\n    parameters.type);\x0d\n\x0d\n  job.ondone = (error\x2C result) => {\x0d\n    if (error !== undefined)\x0d\n      return FunctionPrototypeCall(callback\x2C job\x2C error);\x0d\n    const buf = Buffer.from(result);\x0d\n    return FunctionPrototypeCall(callback\x2C job\x2C null\x2C buf);\x0d\n  };\x0d\n\x0d\n  job.run();\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {'argon2d' | 'argon2i' | 'argon2id'} algorithm\x0d\n * @param {object} parameters\x0d\n * @param {ArrayBufferLike} parameters.message\x0d\n * @param {ArrayBufferLike} parameters.nonce\x0d\n * @param {number} parameters.parallelism\x0d\n * @param {number} parameters.tagLength\x0d\n * @param {number} parameters.memory\x0d\n * @param {number} parameters.passes\x0d\n * @param {ArrayBufferLike} [parameters.secret]\x0d\n * @param {ArrayBufferLike} [parameters.associatedData]\x0d\n * @returns {Buffer}\x0d\n */\x0d\nfunction argon2Sync(algorithm\x2C parameters) {\x0d\n  parameters = check(algorithm\x2C parameters);\x0d\n\x0d\n  const job = new Argon2Job(\x0d\n    kCryptoJobSync\x2C\x0d\n    parameters.message\x2C\x0d\n    parameters.nonce\x2C\x0d\n    parameters.parallelism\x2C\x0d\n    parameters.tagLength\x2C\x0d\n    parameters.memory\x2C\x0d\n    parameters.passes\x2C\x0d\n    parameters.secret\x2C\x0d\n    parameters.associatedData\x2C\x0d\n    parameters.type);\x0d\n\x0d\n  const { 0: err\x2C 1: result } = job.run();\x0d\n\x0d\n  if (err !== undefined)\x0d\n    throw err;\x0d\n\x0d\n  return Buffer.from(result);\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {'argon2d' | 'argon2i' | 'argon2id'} algorithm\x0d\n * @param {object} parameters\x0d\n * @param {ArrayBufferLike} parameters.message\x0d\n * @param {ArrayBufferLike} parameters.nonce\x0d\n * @param {number} parameters.parallelism\x0d\n * @param {number} parameters.tagLength\x0d\n * @param {number} parameters.memory\x0d\n * @param {number} parameters.passes\x0d\n * @param {ArrayBufferLike} [parameters.secret]\x0d\n * @param {ArrayBufferLike} [parameters.associatedData]\x0d\n * @returns {object}\x0d\n */\x0d\nfunction check(algorithm\x2C parameters) {\x0d\n  if (Argon2Job === undefined)\x0d\n    throw new ERR_CRYPTO_ARGON2_NOT_SUPPORTED();\x0d\n\x0d\n  validateString(algorithm\x2C 'algorithm');\x0d\n  validateOneOf(algorithm\x2C 'algorithm'\x2C ['argon2d'\x2C 'argon2i'\x2C 'argon2id']);\x0d\n\x0d\n  let type;\x0d\n  switch (algorithm) {\x0d\n    case 'argon2d':\x0d\n      type = kTypeArgon2d;\x0d\n      break;\x0d\n    case 'argon2i':\x0d\n      type = kTypeArgon2i;\x0d\n      break;\x0d\n    case 'argon2id':\x0d\n      type = kTypeArgon2id;\x0d\n      break;\x0d\n    default:  // unreachable\x0d\n      throw new ERR_CRYPTO_ARGON2_NOT_SUPPORTED();\x0d\n  }\x0d\n\x0d\n  validateObject(parameters\x2C 'parameters');\x0d\n\x0d\n  const { parallelism\x2C tagLength\x2C memory\x2C passes } = parameters;\x0d\n  const MAX_POSITIVE_UINT_32 = MathPow(2\x2C 32) - 1;\x0d\n\x0d\n  const message = getArrayBufferOrView(parameters.message\x2C 'parameters.message');\x0d\n  validateInteger(message.byteLength\x2C 'parameters.message.byteLength'\x2C 0\x2C MAX_POSITIVE_UINT_32);\x0d\n\x0d\n  const nonce = getArrayBufferOrView(parameters.nonce\x2C 'parameters.nonce');\x0d\n  validateInteger(nonce.byteLength\x2C 'parameters.nonce.byteLength'\x2C 8\x2C MAX_POSITIVE_UINT_32);\x0d\n\x0d\n  validateInteger(parallelism\x2C 'parameters.parallelism'\x2C 1\x2C MathPow(2\x2C 24) - 1);\x0d\n  validateInteger(tagLength\x2C 'parameters.tagLength'\x2C 4\x2C MAX_POSITIVE_UINT_32);\x0d\n  validateInteger(memory\x2C 'parameters.memory'\x2C 8 * parallelism\x2C MAX_POSITIVE_UINT_32);\x0d\n  validateUint32(passes\x2C 'parameters.passes'\x2C true);\x0d\n\x0d\n  let secret;\x0d\n  if (parameters.secret === undefined) {\x0d\n    secret = new Uint8Array(0);\x0d\n  } else {\x0d\n    secret = getArrayBufferOrView(parameters.secret);\x0d\n    validateInteger(secret.byteLength\x2C 'parameters.secret.byteLength'\x2C 0\x2C MAX_POSITIVE_UINT_32);\x0d\n  }\x0d\n\x0d\n  let associatedData;\x0d\n  if (parameters.associatedData === undefined) {\x0d\n    associatedData = new Uint8Array(0);\x0d\n  } else {\x0d\n    associatedData = getArrayBufferOrView(parameters.associatedData);\x0d\n    validateInteger(associatedData.byteLength\x2C 'parameters.associatedData.byteLength'\x2C 0\x2C MAX_POSITIVE_UINT_32);\x0d\n  }\x0d\n\x0d\n  return { message\x2C nonce\x2C secret\x2C associatedData\x2C tagLength\x2C passes\x2C parallelism\x2C memory\x2C type };\x0d\n}\x0d\n\x0d\nconst argon2Promise = promisify(argon2);\x0d\nfunction validateArgon2DeriveBitsLength(length) {\x0d\n  if (length === null)\x0d\n    throw lazyDOMException('length cannot be null'\x2C 'OperationError');\x0d\n\x0d\n  if (length % 8) {\x0d\n    throw lazyDOMException(\x0d\n      'length must be a multiple of 8'\x2C\x0d\n      'OperationError');\x0d\n  }\x0d\n\x0d\n  if (length < 32) {\x0d\n    throw lazyDOMException(\x0d\n      'length must be >= 32'\x2C\x0d\n      'OperationError');\x0d\n  }\x0d\n}\x0d\n\x0d\nasync function argon2DeriveBits(algorithm\x2C baseKey\x2C length) {\x0d\n  validateArgon2DeriveBitsLength(length);\x0d\n\x0d\n  let result;\x0d\n  try {\x0d\n    result = await argon2Promise(\x0d\n      StringPrototypeToLowerCase(algorithm.name)\x2C\x0d\n      {\x0d\n        message: baseKey[kKeyObject].export()\x2C\x0d\n        nonce: algorithm.nonce\x2C\x0d\n        parallelism: algorithm.parallelism\x2C\x0d\n        tagLength: length / 8\x2C\x0d\n        memory: algorithm.memory\x2C\x0d\n        passes: algorithm.passes\x2C\x0d\n        secret: algorithm.secretValue\x2C\x0d\n        associatedData: algorithm.associatedData\x2C\x0d\n      }\x2C\x0d\n    );\x0d\n  } catch (err) {\x0d\n    throw lazyDOMException(\x0d\n      'The operation failed for an operation-specific reason'\x2C\x0d\n      { name: 'OperationError'\x2C cause: err });\x0d\n  }\x0d\n\x0d\n  return TypedArrayPrototypeGetBuffer(result);\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  argon2\x2C\x0d\n  argon2Sync\x2C\x0d\n  argon2DeriveBits\x2C\x0d\n  validateArgon2DeriveBitsLength\x2C\x0d\n};\x0d\n

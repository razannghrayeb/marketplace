ction createRequire(filenameOrURL) {\x0d\n  let filepath\x2C fileURL;\x0d\n\x0d\n  if (isURL(filenameOrURL) ||\x0d\n      (typeof filenameOrURL === 'string' && !path.isAbsolute(filenameOrURL))) {\x0d\n    try {\x0d\n      // It might be an URL\x2C try to convert it.\x0d\n      // If it's a relative path\x2C it would not parse and would be considered invalid per\x0d\n      // the documented contract.\x0d\n      fileURL = new URL(filenameOrURL);\x0d\n      filepath = fileURLToPath(fileURL);\x0d\n    } catch {\x0d\n      throw new ERR_INVALID_ARG_VALUE('filename'\x2C filenameOrURL\x2C\x0d\n                                      createRequireError);\x0d\n    }\x0d\n  } else if (typeof filenameOrURL !== 'string') {\x0d\n    throw new ERR_INVALID_ARG_VALUE('filename'\x2C filenameOrURL\x2C createRequireError);\x0d\n  } else {\x0d\n    filepath = filenameOrURL;\x0d\n  }\x0d\n  return createRequireFromPath(filepath\x2C fileURL);\x0d\n}\x0d\n\x0d\n/**\x0d\n * Checks if a path is relative\x0d\n * @param {string} path the target path\x0d\n * @returns {boolean} true if the path is relative\x2C false otherwise\x0d\n */\x0d\nfunction isRelative(path) {\x0d\n  if (StringPrototypeCharCodeAt(path\x2C 0) !== CHAR_DOT) { return false; }\x0d\n\x0d\n  return path.length === 1 || path === '..' ||\x0d\n  StringPrototypeStartsWith(path\x2C './') ||\x0d\n  StringPrototypeStartsWith(path\x2C '../') ||\x0d\n  ((isWindows && StringPrototypeStartsWith(path\x2C '.\\\\')) ||\x0d\n  StringPrototypeStartsWith(path\x2C '..\\\\'));\x0d\n}\x0d\n\x0d\nModule.createRequire = createRequire;\x0d\n\x0d\n/**\x0d\n * Define the paths to use for resolving a module.\x0d\n */\x0d\nModule._initPaths = function() {\x0d\n  const homeDir = isWindows ? process.env.USERPROFILE : safeGetenv('HOME');\x0d\n  const nodePath = isWindows ? process.env.NODE_PATH : safeGetenv('NODE_PATH');\x0d\n\x0d\n  // process.execPath is $PREFIX/bin/node except on Windows where it is\x0d\n  // $PREFIX\\node.exe where $PREFIX is the root of
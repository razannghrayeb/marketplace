script-source,142,node:internal/util/colors,'use strict';\x0d\n\x0d\nlet internalTTy;\x0d\nfunction lazyInternalTTY() {\x0d\n  internalTTy ??= require('internal/tty');\x0d\n  return internalTTy;\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  blue: ''\x2C\x0d\n  green: ''\x2C\x0d\n  white: ''\x2C\x0d\n  red: ''\x2C\x0d\n  gray: ''\x2C\x0d\n  clear: ''\x2C\x0d\n  reset: ''\x2C\x0d\n  hasColors: false\x2C\x0d\n  shouldColorize(stream) {\x0d\n    if (process.env.FORCE_COLOR !== undefined) {\x0d\n      return lazyInternalTTY().getColorDepth() > 2;\x0d\n    }\x0d\n    return stream?.isTTY && (\x0d\n      typeof stream.getColorDepth === 'function' ?\x0d\n        stream.getColorDepth() > 2 : true);\x0d\n  }\x2C\x0d\n  refresh() {\x0d\n    if (module.exports.shouldColorize(process.stderr)) {\x0d\n      module.exports.blue = '\\u001b[34m';\x0d\n      module.exports.green = '\\u001b[32m';\x0d\n      module.exports.white = '\\u001b[39m';\x0d\n      module.exports.yellow = '\\u001b[33m';\x0d\n      module.exports.red = '\\u001b[31m';\x0d\n      module.exports.gray = '\\u001b[90m';\x0d\n      module.exports.clear = '\\u001bc';\x0d\n      module.exports.reset = '\\u001b[0m';\x0d\n      module.exports.hasColors = true;\x0d\n    } else {\x0d\n      module.exports.blue = '';\x0d\n      module.exports.green = '';\x0d\n      module.exports.white = '';\x0d\n      module.exports.yellow = '';\x0d\n      module.exports.red = '';\x0d\n      module.exports.gray = '';\x0d\n      module.exports.clear = '';\x0d\n      module.exports.reset = '';\x0d\n      module.exports.hasColors = false;\x0d\n    }\x0d\n  }\x2C\x0d\n};\x0d\n\x0d\nmodule.exports.refresh();\x0d\n

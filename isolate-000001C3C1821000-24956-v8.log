script-source,79,node:internal/modules/esm/loader,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayPrototypeJoin\x2C\x0d\n  ArrayPrototypeMap\x2C\x0d\n  ArrayPrototypeReduce\x2C\x0d\n  FunctionPrototypeCall\x2C\x0d\n  JSONStringify\x2C\x0d\n  ObjectSetPrototypeOf\x2C\x0d\n  Promise\x2C\x0d\n  PromisePrototypeThen\x2C\x0d\n  RegExpPrototypeSymbolReplace\x2C\x0d\n  encodeURIComponent\x2C\x0d\n  hardenRegExp\x2C\x0d\n} = primordials;\x0d\n\x0d\n\x0d\n// This is needed to avoid cycles in esm/resolve <-> cjs/loader\x0d\nconst {\x0d\n  kIsExecuting\x2C\x0d\n  kRequiredModuleSymbol\x2C\x0d\n} = require('internal/modules/cjs/loader');\x0d\nconst { imported_cjs_symbol } = internalBinding('symbols');\x0d\n\x0d\nconst assert = require('internal/assert');\x0d\nconst {\x0d\n  ERR_REQUIRE_ASYNC_MODULE\x2C\x0d\n  ERR_REQUIRE_CYCLE_MODULE\x2C\x0d\n  ERR_REQUIRE_ESM\x2C\x0d\n  ERR_UNKNOWN_MODULE_FORMAT\x2C\x0d\n} = require('internal/errors').codes;\x0d\nconst { getOptionValue } = require('internal/options');\x0d\nconst { isURL\x2C pathToFileURL } = require('internal/url');\x0d\nconst { kEmptyObject } = require('internal/util');\x0d\nconst {\x0d\n  compileSourceTextModule\x2C\x0d\n  getDefaultConditions\x2C\x0d\n  shouldSpawnLoaderHookWorker\x2C\x0d\n  requestTypes: { kImportInRequiredESM\x2C kRequireInImportedCJS\x2C kImportInImportedESM }\x2C\x0d\n} = require('internal/modules/esm/utils');\x0d\n/**\x0d\n * @typedef {import('./utils.js').ModuleRequestType} ModuleRequestType\x0d\n */\x0d\nconst { kImplicitTypeAttribute } = require('internal/modules/esm/assert');\x0d\nconst {\x0d\n  ModuleWrap\x2C\x0d\n  kEvaluated\x2C\x0d\n  kEvaluating\x2C\x0d\n  kEvaluationPhase\x2C\x0d\n  kInstantiated\x2C\x0d\n  kErrored\x2C\x0d\n  kSourcePhase\x2C\x0d\n  throwIfPromiseRejected\x2C\x0d\n} = internalBinding('module_wrap');\x0d\nconst {\x0d\n  urlToFilename\x2C\x0d\n} = require('internal/modules/helpers');\x0d\nconst {\x0d\n  resolveHooks: syncResolveHooks\x2C\x0d\n  resolveWithHooks: resolveWithSyncHooks\x2C\x0d\n  loadHooks: syncLoadHooks\x2C\x0d\n  loadWithHooks: loadWithSyncHooks\x2C\x0d\n  validateLoadSloppy\x2C\x0d\n} = require('internal/modules/customization_hooks');\x0d\nlet defaultResolve\x2C defaultLoadSync\x2C importMetaInitializer;\x0d\n\x0d\nconst { tracingChannel } = require('diagnostics_channel');\x0d\nconst onImport = tracingChannel('module.import');\x0d\n\x0d\nlet debug = require('internal/util/debuglog').debuglog('esm'\x2C (fn) => {\x0d\n  debug = fn;\x0d\n});\x0d\n\x0d\nconst { isPromise } = require('internal/util/types');\x0d\n\x0d\n/**\x0d\n * @typedef {import('./hooks.js').AsyncLoaderHookWorker} AsyncLoaderHookWorker\x0d\n * @typedef {import('./module_job.js').ModuleJobBase} ModuleJobBase\x0d\n * @typedef {import('url').URL} URL\x0d\n */\x0d\n\x0d\n/**\x0d\n * Lazy loads the module_map module and returns a new instance of ResolveCache.\x0d\n * @returns {import('./module_map.js').ResolveCache}\x0d\n */\x0d\nfunction newResolveCache() {\x0d\n  const { ResolveCache } = require('internal/modules/esm/module_map');\x0d\n  return new ResolveCache();\x0d\n}\x0d\n\x0d\n/**\x0d\n * Generate a load cache (to store the final result of a load-chain for a particular module).\x0d\n * @returns {import('./module_map.js').LoadCache}\x0d\n */\x0d\nfunction newLoadCache() {\x0d\n  const { LoadCache } = require('internal/modules/esm/module_map');\x0d\n  return new LoadCache();\x0d\n}\x0d\n\x0d\nlet _translators;\x0d\nfunction lazyLoadTranslators() {\x0d\n  _translators ??= require('internal/modules/esm/translators');\x0d\n  return _translators;\x0d\n}\x0d\n\x0d\n/**\x0d\n * Lazy-load translators to avoid potentially unnecessary work at startup (ex if ESM is not used).\x0d\n * @returns {import('./translators.js').Translators}\x0d\n */\x0d\nfunction getTranslators() {\x0d\n  return lazyLoadTranslators().translators;\x0d\n}\x0d\n\x0d\n/**\x0d\n * Generate message about potential race condition caused by requiring a cached module that has started\x0d\n * async linking.\x0d\n * @param {string} filename Filename of the module being required.\x0d\n * @param {string|undefined} parentFilename Filename of the module calling require().\x0d\n * @param {boolean} isForAsyncLoaderHookWorker Whether this is for the async loader hook worker.\x0d\n * @returns {string} Error message.\x0d\n */\x0d\nfunction getRaceMessage(filename\x2C parentFilename\x2C isForAsyncLoaderHookWorker) {\x0d\n  let raceMessage = `Cannot require() ES Module ${filename} because it is not yet fully loaded.\\n`;\x0d\n  raceMessage += 'This may be caused by a race condition if the module is simultaneously dynamically ';\x0d\n  raceMessage += 'import()-ed via Promise.all().\\n';\x0d\n  raceMessage += 'Try await-ing the import() sequentially in a loop instead.\\n';\x0d\n  raceMessage += ` (From ${parentFilename ? `${parentFilename} in ` : ' '}`;\x0d\n  raceMessage += `${isForAsyncLoaderHookWorker ? 'loader hook worker thread' : 'non-loader-hook thread'})`;\x0d\n  return raceMessage;\x0d\n}\x0d\n\x0d\n/**\x0d\n * @typedef {import('../cjs/loader.js').Module} CJSModule\x0d\n */\x0d\n\x0d\n/**\x0d\n * @typedef {Record<string\x2C any>} ModuleExports\x0d\n */\x0d\n\x0d\n/**\x0d\n * @typedef {'builtin'|'commonjs'|'json'|'module'|'wasm'} ModuleFormat\x0d\n */\x0d\n\x0d\n/**\x0d\n * @typedef {ArrayBuffer|TypedArray|string} ModuleSource\x0d\n */\x0d\n\x0d\n/**\x0d\n * @typedef {{ format: ModuleFormat\x2C source: ModuleSource\x2C translatorKey: string }} TranslateContext\x0d\n */\x0d\n\x0d\n/**\x0d\n * @typedef {import('./hooks.js').AsyncLoaderHooks} AsyncLoaderHooks\x0d\n * @typedef {import('./hooks.js').AsyncLoaderHooksOnLoaderHookWorker} AsyncLoaderHooksOnLoaderHookWorker\x0d\n * @typedef {import('./hooks.js').AsyncLoaderHooksProxiedToLoaderHookWorker} AsyncLoaderHooksProxiedToLoaderHookWorker\x0d\n */\x0d\n\x0d\n/**\x0d\n * This class covers the base machinery of module loading. There are two types of loader hooks:\x0d\n * 1. Asynchronous loader hooks\x2C which are run in a separate loader hook worker thread.\x0d\n *    This is configured in #asyncLoaderHooks.\x0d\n * 2. Synchronous loader hooks\x2C which are run in-thread. This is shared with the CJS loader and is\x0d\n *    stored in the cross-module syncResolveHooks and syncLoadHooks arrays.\x0d\n */\x0d\nclass ModuleLoader {\x0d\n  /**\x0d\n   * The conditions for resolving packages if `--conditions` is not used.\x0d\n   */\x0d\n  #defaultConditions = getDefaultConditions();\x0d\n\x0d\n  /**\x0d\n   * Registry of resolved specifiers\x0d\n   */\x0d\n  #resolveCache = newResolveCache();\x0d\n\x0d\n  /**\x0d\n   * Registry of loaded modules\x2C akin to `require.cache`\x0d\n   */\x0d\n  loadCache = newLoadCache();\x0d\n\x0d\n  /**\x0d\n   * Methods which translate input code or other information into ES modules\x0d\n   */\x0d\n  translators = getTranslators();\x0d\n\x0d\n  /**\x0d\n   * Truthy to allow the use of `import.meta.resolve`. This is needed\x0d\n   * currently because the `Hooks` class does not have `resolveSync`\x0d\n   * implemented and `import.meta.resolve` requires it.\x0d\n   */\x0d\n  allowImportMetaResolve;\x0d\n\x0d\n  /**\x0d\n   * @see {AsyncLoaderHooks.isForAsyncLoaderHookWorker}\x0d\n   * Shortcut to this.#asyncLoaderHooks.isForAsyncLoaderHookWorker.\x0d\n   */\x0d\n  isForAsyncLoaderHookWorker = false;\x0d\n\x0d\n  /**\x0d\n   * Asynchronous loader hooks to pass requests to.\x0d\n   *\x0d\n   * Note that this value _MUST_ be set with `#setAsyncLoaderHooks`\x0d\n   * because it needs to copy `#asyncLoaderHooks.allowImportMetaResolve`\x0d\n   *  to this property and failure to do so will cause undefined\x0d\n   * behavior when invoking `import.meta.resolve`.\x0d\n   *\x0d\n   * When the ModuleLoader is created on a loader hook thread\x2C this is\x0d\n   * {@link AsyncLoaderHooksOnLoaderHookWorker}\x2C and its methods directly call out\x0d\n   * to loader methods. Otherwise\x2C this is {@link AsyncLoaderHooksProxiedToLoaderHookWorker}\x2C\x0d\n   * and its methods post messages to the loader thread and possibly block on it.\x0d\n   * @see {ModuleLoader.#setAsyncLoaderHooks}\x0d\n   * @type {AsyncLoaderHooks}\x0d\n   */\x0d\n  #asyncLoaderHooks;\x0d\n\x0d\n  constructor(asyncLoaderHooks) {\x0d\n    this.#setAsyncLoaderHooks(asyncLoaderHooks);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Change the currently activate async loader hooks for this module\x0d\n   * loader to be the provided `AsyncLoaderHooks`.\x0d\n   *\x0d\n   * If present\x2C this class customizes its core functionality to the\x0d\n   * `AsyncLoaderHooks` object\x2C including registration\x2C loading\x2C and resolving.\x0d\n   * There are some responsibilities that this class _always_ takes\x0d\n   * care of\x2C like validating outputs\x2C so that the AsyncLoaderHooks object\x0d\n   * does not have to do so.\x0d\n   *\x0d\n   * Calling this function alters how modules are loaded and should be\x0d\n   * invoked with care.\x0d\n   * @param {AsyncLoaderHooks} asyncLoaderHooks\x0d\n   */\x0d\n  #setAsyncLoaderHooks(asyncLoaderHooks) {\x0d\n    this.#asyncLoaderHooks = asyncLoaderHooks;\x0d\n    if (asyncLoaderHooks) {\x0d\n      this.allowImportMetaResolve = asyncLoaderHooks.allowImportMetaResolve;\x0d\n      this.isForAsyncLoaderHookWorker = asyncLoaderHooks.isForAsyncLoaderHookWorker;\x0d\n    } else {\x0d\n      this.allowImportMetaResolve = true;\x0d\n      this.isForAsyncLoaderHookWorker = false;\x0d\n    }\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   *\x0d\n   * @param {string} source Source code of the module.\x0d\n   * @param {string} url URL of the module.\x0d\n   * @param {{ isMain?: boolean }|undefined} context - context object containing module metadata.\x0d\n   * @returns {object} The module wrap object.\x0d\n   */\x0d\n  createModuleWrap(source\x2C url\x2C context = kEmptyObject) {\x0d\n    return compileSourceTextModule(url\x2C source\x2C this\x2C context);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   *\x0d\n   * @param {string} url URL of the module.\x0d\n   * @param {object} wrap Module wrap object.\x0d\n   * @param {boolean} isEntryPoint Whether the module is the entry point.\x0d\n   * @returns {Promise<object>} The module object.\x0d\n   */\x0d\n  async executeModuleJob(url\x2C wrap\x2C isEntryPoint = false) {\x0d\n    const { ModuleJob } = require('internal/modules/esm/module_job');\x0d\n    const module = await onImport.tracePromise(async () => {\x0d\n      const job = new ModuleJob(this\x2C url\x2C undefined\x2C wrap\x2C kEvaluationPhase\x2C false\x2C false\x2C kImportInImportedESM);\x0d\n      this.loadCache.set(url\x2C undefined\x2C job);\x0d\n      const { module } = await job.run(isEntryPoint);\x0d\n      return module;\x0d\n    }\x2C {\x0d\n      __proto__: null\x2C\x0d\n      parentURL: '<eval>'\x2C\x0d\n      url\x2C\x0d\n    });\x0d\n\x0d\n    return {\x0d\n      __proto__: null\x2C\x0d\n      namespace: module.getNamespace()\x2C\x0d\n      module\x2C\x0d\n    };\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   *\x0d\n   * @param {string} source Source code of the module.\x0d\n   * @param {string} url URL of the module.\x0d\n   * @param {boolean} isEntryPoint Whether the module is the entry point.\x0d\n   * @returns {Promise<object>} The module object.\x0d\n   */\x0d\n  eval(source\x2C url\x2C isEntryPoint = false) {\x0d\n    const context = isEntryPoint ? { isMain: true } : undefined;\x0d\n    const wrap = this.createModuleWrap(source\x2C url\x2C context);\x0d\n    return this.executeModuleJob(url\x2C wrap\x2C isEntryPoint);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * This constructs (creates\x2C instantiates and evaluates) a module graph that\x0d\n   * is require()'d.\x0d\n   * @param {CJSModule} mod CJS module wrapper of the ESM.\x0d\n   * @param {string} filename Resolved filename of the module being require()'d\x0d\n   * @param {string} source Source code. TODO(joyeecheung): pass the raw buffer.\x0d\n   * @param {string} isMain Whether this module is a main module.\x0d\n   * @param {CJSModule|undefined} parent Parent module\x2C if any.\x0d\n   * @returns {{wrap: ModuleWrap\x2C namespace: import('internal/modules/esm/utils').ModuleNamespaceObject}}\x0d\n   */\x0d\n  importSyncForRequire(mod\x2C filename\x2C source\x2C isMain\x2C parent) {\x0d\n    const url = pathToFileURL(filename).href;\x0d\n    if (!getOptionValue('--experimental-require-module')) {\x0d\n      throw new ERR_REQUIRE_ESM(url\x2C true);\x0d\n    }\x0d\n\x0d\n    let job = this.loadCache.get(url\x2C kImplicitTypeAttribute);\x0d\n    // This module job is already created:\x0d\n    // 1. If it was loaded by `require()` before\x2C at this point the instantiation\x0d\n    //    is already completed and we can check the whether it is in a cycle\x0d\n    //    (in that case the module status is kEvaluaing)\x2C and whether the\x0d\n    //    required graph is synchronous.\x0d\n    // 2. If it was loaded by `import` before\x2C only allow it if it's already evaluated\x0d\n    //    to forbid cycles.\x0d\n    //    TODO(joyeecheung): ensure that imported synchronous graphs are evaluated\x0d\n    //    synchronously so that any previously imported synchronous graph is already\x0d\n    //    evaluated at this point.\x0d\n    // TODO(joyeecheung): add something similar to CJS loader's requireStack to help\x0d\n    // debugging the the problematic links in the graph for import.\x0d\n    debug('importSyncForRequire'\x2C parent?.filename\x2C '->'\x2C filename\x2C job);\x0d\n    if (job !== undefined) {\x0d\n      mod[kRequiredModuleSymbol] = job.module;\x0d\n      const parentFilename = urlToFilename(parent?.filename);\x0d\n      // This race should only be possible on the loader hook thread. See https://github.com/nodejs/node/issues/59666\x0d\n      if (!job.module) {\x0d\n        assert.fail(getRaceMessage(filename\x2C parentFilename)\x2C this.isForAsyncLoaderHookWorker);\x0d\n      }\x0d\n      const status = job.module.getStatus();\x0d\n      debug('Module status'\x2C job\x2C status);\x0d\n      // hasAsyncGraph is available after module been instantiated.\x0d\n      if (status >= kInstantiated && job.module.hasAsyncGraph) {\x0d\n        throw new ERR_REQUIRE_ASYNC_MODULE(filename\x2C parentFilename);\x0d\n      }\x0d\n      if (status === kEvaluated) {\x0d\n        return { wrap: job.module\x2C namespace: job.module.getNamespace() };\x0d\n      } else if (status === kInstantiated) {\x0d\n        // When it's an async job cached by another import request\x2C\x0d\n        // which has finished linking but has not started its\x0d\n        // evaluation because the async run() task would be later\x0d\n        // in line. Then start the evaluation now with runSync()\x2C which\x0d\n        // is guaranteed to finish by the time the other run() get to it\x2C\x0d\n        // and the other task would just get the cached evaluation results\x2C\x0d\n        // similar to what would happen when both are async.\x0d\n        mod[kRequiredModuleSymbol] = job.module;\x0d\n        const { namespace } = job.runSync(parent);\x0d\n        return { wrap: job.module\x2C namespace: namespace || job.module.getNamespace() };\x0d\n      } else if (status === kErrored) {\x0d\n        // If the module was previously imported and errored\x2C throw the error.\x0d\n        throw job.module.getError();\x0d\n      }\x0d\n      // When the cached async job have already encountered a linking\x0d\n      // error that gets wrapped into a rejection\x2C but is still later\x0d\n      // in line to throw on it\x2C just unwrap and throw the linking error\x0d\n      // from require().\x0d\n      if (job.instantiated) {\x0d\n        throwIfPromiseRejected(job.instantiated);\x0d\n      }\x0d\n      if (status !== kEvaluating) {\x0d\n        assert.fail(`Unexpected module status ${status}. ` +\x0d\n                    getRaceMessage(filename\x2C parentFilename));\x0d\n      }\x0d\n      let message = `Cannot require() ES Module ${filename} in a cycle.`;\x0d\n      if (parentFilename) {\x0d\n        message += ` (from ${parentFilename})`;\x0d\n      }\x0d\n      message += ' A cycle involving require(esm) is not allowed to maintain ';\x0d\n      message += 'invariants mandated by the ECMAScript specification. ';\x0d\n      message += 'Try making at least part of the dependency in the graph lazily loaded.';\x0d\n      throw new ERR_REQUIRE_CYCLE_MODULE(message);\x0d\n\x0d\n    }\x0d\n    // TODO(joyeecheung): refactor this so that we pre-parse in C++ and hit the\x0d\n    // cache here\x2C or use a carrier object to carry the compiled module script\x0d\n    // into the constructor to ensure cache hit.\x0d\n    const wrap = compileSourceTextModule(url\x2C source\x2C this);\x0d\n    const inspectBrk = (isMain && getOptionValue('--inspect-brk'));\x0d\n\x0d\n    const { ModuleJobSync } = require('internal/modules/esm/module_job');\x0d\n    job = new ModuleJobSync(this\x2C url\x2C kEmptyObject\x2C wrap\x2C kEvaluationPhase\x2C isMain\x2C inspectBrk\x2C\x0d\n                            kImportInRequiredESM);\x0d\n    this.loadCache.set(url\x2C kImplicitTypeAttribute\x2C job);\x0d\n    mod[kRequiredModuleSymbol] = job.module;\x0d\n    return { wrap: job.module\x2C namespace: job.runSync(parent).namespace };\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Check invariants on a cached module job when require()'d from ESM.\x0d\n   * @param {string} specifier The first parameter of require().\x0d\n   * @param {string} url URL of the module being required.\x0d\n   * @param {string|undefined} parentURL URL of the module calling require().\x0d\n   * @param {ModuleJobBase} job The cached module job.\x0d\n   */\x0d\n  #checkCachedJobForRequireESM(specifier\x2C url\x2C parentURL\x2C job) {\x0d\n    // This race should only be possible on the loader hook thread. See https://github.com/nodejs/node/issues/59666\x0d\n    if (!job.module) {\x0d\n      assert.fail(getRaceMessage(url\x2C parentURL\x2C this.isForAsyncLoaderHookWorker));\x0d\n    }\x0d\n    // This module is being evaluated\x2C which means it's imported in a previous link\x0d\n    // in a cycle.\x0d\n    if (job.module.getStatus() === kEvaluating) {\x0d\n      const parentFilename = urlToFilename(parentURL);\x0d\n      let message = `Cannot import Module ${specifier} in a cycle.`;\x0d\n      if (parentFilename) {\x0d\n        message += ` (from ${parentFilename})`;\x0d\n      }\x0d\n      throw new ERR_REQUIRE_CYCLE_MODULE(message);\x0d\n    }\x0d\n\x0d\n    // Otherwise the module could be imported before but the evaluation may be already\x0d\n    // completed (e.g. the require call is lazy) so it's okay. We will return the\x0d\n    // job and check asynchronicity of the entire graph later\x2C after the\x0d\n    // graph is instantiated.\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Load a module and translate it into a ModuleWrap for require(esm).\x0d\n   * This is run synchronously\x2C and the translator always return a ModuleWrap synchronously.\x0d\n   * @param {string} url URL of the module to be translated.\x0d\n   * @param {object} loadContext See {@link load}\x0d\n   * @param {string|undefined} parentURL URL of the parent module. Undefined if it's the entry point.\x0d\n   * @param {ModuleRequest} request Module request.\x0d\n   * @returns {ModuleWrap}\x0d\n   */\x0d\n  loadAndTranslateForImportInRequiredESM(url\x2C loadContext\x2C parentURL\x2C request) {\x0d\n    const loadResult = this.#loadSync(url\x2C loadContext);\x0d\n    // Use the synchronous commonjs translator which can deal with cycles.\x0d\n    const formatFromLoad = loadResult.format;\x0d\n    const translatorKey = (formatFromLoad === 'commonjs' || formatFromLoad === 'commonjs-typescript') ?\x0d\n      'commonjs-sync' : formatFromLoad;\x0d\n    const translateContext = { ...loadResult\x2C translatorKey\x2C __proto__: null };\x0d\n    const wrap = this.#translate(url\x2C translateContext\x2C parentURL);\x0d\n    assert(wrap instanceof ModuleWrap\x2C `Translator used for require(${url}) should not be async`);\x0d\n\x0d\n    const cjsModule = wrap[imported_cjs_symbol];\x0d\n    if (cjsModule) {\x0d\n      // Check if the ESM initiating import CJS is being required by the same CJS module.\x0d\n      if (cjsModule?.[kIsExecuting]) {\x0d\n        const parentFilename = urlToFilename(parentURL);\x0d\n        let message = `Cannot import CommonJS Module ${request.specifier} in a cycle.`;\x0d\n        if (parentFilename) {\x0d\n          message += ` (from ${parentFilename})`;\x0d\n        }\x0d\n        throw new ERR_REQUIRE_CYCLE_MODULE(message);\x0d\n      }\x0d\n    }\x0d\n\x0d\n    return wrap;\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Translate a loaded module source into a ModuleWrap. This is run synchronously\x2C\x0d\n   * but the translator may return the ModuleWrap in a Promise.\x0d\n   * @param {string} url URL of the module to be translated.\x0d\n   * @param {TranslateContext} translateContext Context for the translator\x0d\n   * @param {string|undefined} parentURL URL of the module initiating the module loading for the first time.\x0d\n   *   Undefined if it's the entry point.\x0d\n   * @returns {ModuleWrap}\x0d\n   */\x0d\n  #translate(url\x2C translateContext\x2C parentURL) {\x0d\n    const { translatorKey\x2C format } = translateContext;\x0d\n    this.validateLoadResult(url\x2C format);\x0d\n    const translator = getTranslators().get(translatorKey);\x0d\n\x0d\n    if (!translator) {\x0d\n      throw new ERR_UNKNOWN_MODULE_FORMAT(translatorKey\x2C url);\x0d\n    }\x0d\n\x0d\n    const result = FunctionPrototypeCall(translator\x2C this\x2C url\x2C translateContext\x2C parentURL);\x0d\n    assert(result instanceof ModuleWrap\x2C `The ${format} module returned is not a ModuleWrap`);\x0d\n    if (format === 'commonjs' || format === 'commonjs-sync' || format === 'require-commonjs') {\x0d\n      result.isCommonJS = true;\x0d\n    }\x0d\n    return result;\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Load a module and translate it into a ModuleWrap for require() in imported CJS.\x0d\n   * This is run synchronously\x2C and the translator always return a ModuleWrap synchronously.\x0d\n   * @param {string} url URL of the module to be translated.\x0d\n   * @param {object} loadContext See {@link load}\x0d\n   * @param {string|undefined} parentURL URL of the parent module. Undefined if it's the entry point.\x0d\n   * @returns {ModuleWrap}\x0d\n   */\x0d\n  loadAndTranslateForRequireInImportedCJS(url\x2C loadContext\x2C parentURL) {\x0d\n    const loadResult = this.#loadSync(url\x2C loadContext);\x0d\n    const formatFromLoad = loadResult.format;\x0d\n\x0d\n    if (formatFromLoad === 'wasm') {  // require(wasm) is not supported.\x0d\n      throw new ERR_UNKNOWN_MODULE_FORMAT(formatFromLoad\x2C url);\x0d\n    }\x0d\n\x0d\n    if (formatFromLoad === 'module' || formatFromLoad === 'module-typescript') {\x0d\n      if (!getOptionValue('--experimental-require-module')) {\x0d\n        throw new ERR_REQUIRE_ESM(url\x2C true);\x0d\n      }\x0d\n    }\x0d\n\x0d\n    let translatorKey = formatFromLoad;\x0d\n    if (formatFromLoad === 'commonjs') {\x0d\n      translatorKey = 'require-commonjs';\x0d\n    }\x0d\n    if (formatFromLoad === 'commonjs-typescript') {\x0d\n      translatorKey = 'require-commonjs-typescript';\x0d\n    }\x0d\n\x0d\n    const translateContext = { ...loadResult\x2C translatorKey\x2C __proto__: null };\x0d\n    const wrap = this.#translate(url\x2C translateContext\x2C parentURL);\x0d\n    assert(wrap instanceof ModuleWrap\x2C `Translator used for require(${url}) should not be async`);\x0d\n    return wrap;\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Load a module and translate it into a ModuleWrap for ordinary imported ESM.\x0d\n   * This may be run asynchronously if there are asynchronous module loader hooks registered.\x0d\n   * @param {string} url URL of the module to be translated.\x0d\n   * @param {object} loadContext See {@link load}\x0d\n   * @param {string|undefined} parentURL URL of the parent module. Undefined if it's the entry point.\x0d\n   * @returns {Promise<ModuleWrap>|ModuleWrap}\x0d\n   */\x0d\n  loadAndTranslate(url\x2C
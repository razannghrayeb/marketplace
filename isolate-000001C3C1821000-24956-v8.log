script-source,82,node:internal/modules/esm/translators,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayPrototypePush\x2C\x0d\n  FunctionPrototypeCall\x2C\x0d\n  JSONParse\x2C\x0d\n  ObjectAssign\x2C\x0d\n  ObjectPrototypeHasOwnProperty\x2C\x0d\n  ReflectApply\x2C\x0d\n  SafeArrayIterator\x2C\x0d\n  SafeMap\x2C\x0d\n  SafeSet\x2C\x0d\n  SafeWeakMap\x2C\x0d\n  StringPrototypeIncludes\x2C\x0d\n  StringPrototypeReplaceAll\x2C\x0d\n  StringPrototypeSlice\x2C\x0d\n  StringPrototypeStartsWith\x2C\x0d\n  globalThis: { WebAssembly }\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  compileFunctionForCJSLoader\x2C\x0d\n} = internalBinding('contextify');\x0d\n\x0d\nconst { BuiltinModule } = require('internal/bootstrap/realm');\x0d\nconst assert = require('internal/assert');\x0d\nconst { readFileSync } = require('fs');\x0d\nconst { dirname\x2C extname } = require('path');\x0d\nconst {\x0d\n  assertBufferSource\x2C\x0d\n  loadBuiltinModule\x2C\x0d\n  stringify\x2C\x0d\n  stripBOM\x2C\x0d\n  urlToFilename\x2C\x0d\n} = require('internal/modules/helpers');\x0d\nconst { stripTypeScriptModuleTypes } = require('internal/modules/typescript');\x0d\nconst {\x0d\n  kIsCachedByESMLoader\x2C\x0d\n  Module: CJSModule\x2C\x0d\n  wrapModuleLoad\x2C\x0d\n  kModuleSource\x2C\x0d\n  kModuleExport\x2C\x0d\n  kModuleExportNames\x2C\x0d\n  findLongestRegisteredExtension\x2C\x0d\n  resolveForCJSWithHooks\x2C\x0d\n  loadSourceForCJSWithHooks\x2C\x0d\n  populateCJSExportsFromESM\x2C\x0d\n} = require('internal/modules/cjs/loader');\x0d\nconst { fileURLToPath\x2C pathToFileURL\x2C URL } = require('internal/url');\x0d\nlet debug = require('internal/util/debuglog').debuglog('esm'\x2C (fn) => {\x0d\n  debug = fn;\x0d\n});\x0d\nconst { emitExperimentalWarning\x2C kEmptyObject\x2C setOwnProperty\x2C isWindows } = require('internal/util');\x0d\nconst {\x0d\n  ERR_INVALID_RETURN_PROPERTY_VALUE\x2C\x0d\n  ERR_UNKNOWN_BUILTIN_MODULE\x2C\x0d\n} = require('internal/errors').codes;\x0d\nconst { maybeCacheSourceMap } = require('internal/source_map/source_map_cache');\x0d\nconst moduleWrap = internalBinding('module_wrap');\x0d\nconst { ModuleWrap\x2C kEvaluationPhase } = moduleWrap;\x0d\n\x0d\n// Lazy-loading to avoid circular dependencies.\x0d\nlet getSourceSync;\x0d\n/**\x0d\n * @param {Parameters<typeof import('./load').getSourceSync>[0]} url\x0d\n * @returns {ReturnType<typeof import('./load').getSourceSync>}\x0d\n */\x0d\nfunction getSource(url) {\x0d\n  getSourceSync ??= require('internal/modules/esm/load').getSourceSync;\x0d\n  return getSourceSync(url);\x0d\n}\x0d\n\x0d\n/** @type {import('deps/cjs-module-lexer/lexer.js').parse} */\x0d\nlet cjsParse;\x0d\n/**\x0d\n * Initializes the CommonJS module lexer parser using the JavaScript version.\x0d\n * TODO(joyeecheung): Use `require('internal/deps/cjs-module-lexer/dist/lexer').initSync()`\x0d\n * when cjs-module-lexer 1.4.0 is rolled in.\x0d\n */\x0d\nfunction initCJSParseSync() {\x0d\n  if (cjsParse === undefined) {\x0d\n    cjsParse = require('internal/deps/cjs-module-lexer/lexer').parse;\x0d\n  }\x0d\n}\x0d\n\x0d\nconst translators = new SafeMap();\x0d\nexports.translators = translators;\x0d\n\x0d\n/**\x0d\n * Converts a URL to a file path if the URL protocol is 'file:'.\x0d\n * @param {string} url - The URL to convert.\x0d\n * @returns {string|URL}\x0d\n */\x0d\nfunction errPath(url) {\x0d\n  const parsed = new URL(url);\x0d\n  if (parsed.protocol === 'file:') {\x0d\n    return fileURLToPath(parsed);\x0d\n  }\x0d\n  return url;\x0d\n}\x0d\n\x0d\n// Strategy for loading a standard JavaScript module.\x0d\ntranslators.set('module'\x2C function moduleStrategy(url\x2C translateContext\x2C parentURL) {\x0d\n  let { source } = translateContext;\x0d\n  const isMain = (parentURL === undefined);\x0d\n  assertBufferSource(source\x2C true\x2C 'load');\x0d\n  source = stringify(source);\x0d\n  debug(`Translating StandardModule ${url}`\x2C translateContext);\x0d\n  const { compileSourceTextModule } = require('internal/modules/esm/utils');\x0d\n  const context = isMain ? { isMain } : undefined;\x0d\n  const module = compileSourceTextModule(url\x2C source\x2C this\x2C context);\x0d\n  return module;\x0d\n});\x0d\n\x0d\nconst { requestTypes: { kRequireInImportedCJS } } = require('internal/modules/esm/utils');\x0d\n/**\x0d\n * Loads a CommonJS module via the ESM Loader sync CommonJS translator.\x0d\n * This translator creates its own version of the `require` function passed into CommonJS modules.\x0d\n * Any monkey patches applied to the CommonJS Loader will not affect this module.\x0d\n * Any `require` calls in this module will load all children in the same way.\x0d\n * @param {import('internal/modules/cjs/loader').Module} module - The module to load.\x0d\n * @param {string} source - The source code of the module.\x0d\n * @param {string} url - The URL of the module.\x0d\n * @param {string} filename - The filename of the module.\x0d\n * @param {boolean} isMain - Whether the module is the entrypoint\x0d\n */\x0d\nfunction loadCJSModule(module\x2C source\x2C url\x2C filename\x2C isMain) {\x0d\n  const compileResult = compileFunctionForCJSLoader(source\x2C filename\x2C false /* is_sea_main */\x2C false);\x0d\n\x0d\n  const { function: compiledWrapper\x2C sourceMapURL\x2C sourceURL } = compileResult;\x0d\n  // Cache the source map for the cjs module if present.\x0d\n  if (sourceMapURL) {\x0d\n    maybeCacheSourceMap(url\x2C source\x2C module\x2C false\x2C sourceURL\x2C sourceMapURL);\x0d\n  }\x0d\n  const cascadedLoader = require('internal/modules/esm/loader').getOrInitializeCascadedLoader();\x0d\n  const __dirname = dirname(filename);\x0d\n  // eslint-disable-next-line func-name-matching\x2Cfunc-style\x0d\n  const requireFn = function require(specifier) {\x0d\n    let importAttributes = kEmptyObject;\x0d\n    if (!StringPrototypeStartsWith(specifier\x2C 'node:') && !BuiltinModule.normalizeRequirableId(specifier)) {\x0d\n      // TODO: do not depend on the monkey-patchable CJS loader here.\x0d\n      const path = CJSModule._resolveFilename(specifier\x2C module);\x0d\n      switch (extname(path)) {\x0d\n        case '.json':\x0d\n          importAttributes = { __proto__: null\x2C type: 'json' };\x0d\n          break;\x0d\n        case '.node':\x0d\n          return wrapModuleLoad(specifier\x2C module);\x0d\n        default:\x0d\n            // fall through\x0d\n      }\x0d\n      specifier = `${pathToFileURL(path)}`;\x0d\n    }\x0d\n\x0d\n    // FIXME(node:59666) Currently\x2C the ESM loader re-invents require() here for imported CJS and this\x0d\n    // requires a separate cache to be populated as well as introducing several quirks. This is not ideal.\x0d\n    const request = { specifier\x2C attributes: importAttributes\x2C phase: kEvaluationPhase\x2C __proto__: null };\x0d\n    const job = cascadedLoader.getOrCreateModuleJob(url\x2C request\x2C kRequireInImportedCJS);\x0d\n    job.runSync();\x0d\n    let mod = cjsCache.get(job.url);\x0d\n    assert(job.module\x2C `Imported CJS module ${url} failed to load module ${job.url} using require() due to race condition`);\x0d\n\x0d\n    if (job.module.synthetic) {\x0d\n      assert(mod\x2C `Imported CJS module ${url} failed to load module ${job.url} using require() due to missed cache`);\x0d\n      return mod.exports;\x0d\n    }\x0d\n\x0d\n    // The module being required is a source text module.\x0d\n    if (!mod) {\x0d\n      mod = cjsEmplaceModuleCacheEntry(job.url);\x0d\n      cjsCache.set(job.url\x2C mod);\x0d\n    }\x0d\n    // The module has been cached by the re-invented require. Update the exports object\x0d\n    // from the namespace object and return the evaluated exports.\x0d\n    if (!mod.loaded) {\x0d\n      debug('populateCJSExportsFromESM from require(esm) in imported CJS'\x2C url\x2C mod\x2C job.module);\x0d\n      populateCJSExportsFromESM(mod\x2C job.module\x2C job.module.getNamespace());\x0d\n      mod.loaded = true;\x0d\n    }\x0d\n    return mod.exports;\x0d\n  };\x0d\n  setOwnProperty(requireFn\x2C 'resolve'\x2C function resolve(specifier) {\x0d\n    if (!StringPrototypeStartsWith(specifier\x2C 'node:')) {\x0d\n      const path = CJSModule._resolveFilename(specifier\x2C module);\x0d\n      if (specifier !== path) {\x0d\n        specifier = `${pathToFileURL(path)}`;\x0d\n      }\x0d\n    }\x0d\n\x0d\n    const request = { specifier\x2C __proto__: null\x2C attributes: kEmptyObject };\x0d\n    const { url: resolvedURL } = cascadedLoader.resolveSync(url\x2C request);\x0d\n    return urlToFilename(resolvedURL);\x0d\n  });\x0d\n  setOwnProperty(requireFn\x2C 'main'\x2C process.mainModule);\x0d\n\x0d\n  ReflectApply(compiledWrapper\x2C module.exports\x2C\x0d\n               [module.exports\x2C requireFn\x2C module\x2C filename\x2C __dirname]);\x0d\n  setOwnProperty(module\x2C 'loaded'\x2C true);\x0d\n}\x0d\n\x0d\n// TODO: can we use a weak map instead?\x0d\nconst cjsCache = new SafeMap();\x0d\n\x0d\n/**\x0d\n * Creates a ModuleWrap object for a CommonJS module.\x0d\n * @param {string} url - The URL of the module.\x0d\n * @param {{ format: ModuleFormat\x2C source: ModuleSource }} translateContext Context for the translator\x0d\n * @param {string|undefined} parentURL URL of the module initiating the module loading for the first time.\x0d\n *   Undefined if it's the entry point.\x0d\n * @param {typeof loadCJSModule} [loadCJS] - The function to load the CommonJS module.\x0d\n * @returns {ModuleWrap} The ModuleWrap object for the CommonJS module.\x0d\n */\x0d\nfunction createCJSModuleWrap(url\x2C translateContext\x2C parentURL\x2C loadCJS = loadCJSModule) {\x0d\n  debug(`Translating CJSModule ${url}`\x2C translateContext);\x0d\n\x0d\n  const { format: sourceFormat } = translateContext;\x0d\n  let { source } = translateContext;\x0d\n  const isMain = (parentURL === undefined);\x0d\n  const filename = urlToFilename(url);\x0d\n  // In case the source was not provided by the `load` step\x2C we need fetch it now.\x0d\n  source = stringify(source ?? getSource(new URL(url)).source);\x0d\n\x0d\n  const { exportNames\x2C module } = cjsPreparseModuleExports(filename\x2C source\x2C sourceFormat);\x0d\n  cjsCache.set(url\x2C module);\x0d\n\x0d\n  const wrapperNames = [...exportNames];\x0d\n  if (!exportNames.has('default')) {\x0d\n    ArrayPrototypePush(wrapperNames\x2C 'default');\x0d\n  }\x0d\n  if (!exportNames.has('module.exports')) {\x0d\n    ArrayPrototypePush(wrapperNames\x2C 'module.exports');\x0d\n  }\x0d\n\x0d\n  if (isMain) {\x0d\n    setOwnProperty(process\x2C 'mainModule'\x2C module);\x0d\n  }\x0d\n\x0d\n  return new ModuleWrap(url\x2C undefined\x2C wrapperNames\x2C function() {\x0d\n    debug(`Loading CJSModule ${url}`);\x0d\n\x0d\n    if (!module.loaded) {\x0d\n      loadCJS(module\x2C source\x2C url\x2C filename\x2C !!isMain);\x0d\n    }\x0d\n\x0d\n    let exports;\x0d\n    if (module[kModuleExport] !== undefined) {\x0d\n      exports = module[kModuleExport];\x0d\n      module[kModuleExport] = undefined;\x0d\n    } else {\x0d\n      ({ exports } = module);\x0d\n    }\x0d\n    for (const exportName of exportNames) {\x0d\n      if (exportName === 'default' || exportName === 'module.exports' ||\x0d\n          !ObjectPrototypeHasOwnProperty(exports\x2C exportName)) {\x0d\n        continue;\x0d\n      }\x0d\n      // We might trigger a getter -> dont fail.\x0d\n      let value;\x0d\n      try {\x0d\n        value = exports[exportName];\x0d\n      } catch {\x0d\n        // Continue regardless of error.\x0d\n      }\x0d\n      this.setExport(exportName\x2C value);\x0d\n    }\x0d\n    this.setExport('default'\x2C exports);\x0d\n    this.setExport('module.exports'\x2C exports);\x0d\n  }\x2C module);\x0d\n}\x0d\n\x0d\n/**\x0d\n * Creates a ModuleWrap object for a CommonJS module without source texts.\x0d\n * @param {string} url - The URL of the module.\x0d\n * @param {string|undefined} parentURL - URL of the parent module\x2C if any.\x0d\n * @returns {ModuleWrap} The ModuleWrap object for the CommonJS module.\x0d\n */\x0d\nfunction createCJSNoSourceModuleWrap(url\x2C parentURL) {\x0d\n  debug(`Translating CJSModule without source ${url}`);\x0d\n  const isMain = (parentURL === undefined);\x0d\n\x0d\n  const filename = urlToFilename(url);\x0d\n\x0d\n  const module = cjsEmplaceModuleCacheEntry(filename);\x0d\n  cjsCache.set(url\x2C module);\x0d\n\x0d\n  if (isMain) {\x0d\n    setOwnProperty(process\x2C 'mainModule'\x2C module);\x0d\n  }\x0d\n\x0d\n  // Addon export names are not known until the addon is loaded.\x0d\n  const exportNames = ['default'\x2C 'module.exports'];\x0d\n  return new ModuleWrap(url\x2C undefined\x2C exportNames\x2C function evaluationCallback() {\x0d\n    debug(`Loading CJSModule ${url}`);\x0d\n\x0d\n    if (!module.loaded) {\x0d\n      wrapModuleLoad(filename\x2C null\x2C isMain);\x0d\n    }\x0d\n\x0d\n    /** @type {import('./loader').ModuleExports} */\x0d\n    let exports;\x0d\n    if (module[kModuleExport] !== undefined) {\x0d\n      exports = module[kModuleExport];\x0d\n      module[kModuleExport] = undefined;\x0d\n    } else {\x0d\n      ({ exports } = module);\x0d\n    }\x0d\n\x0d\n    this.setExport('default'\x2C exports);\x0d\n    this.setExport('module.exports'\x2C exports);\x0d\n  }\x2C module);\x0d\n}\x0d\n\x0d\ntranslators.set('commonjs-sync'\x2C function requireCommonJS(url\x2C translateContext\x2C parentURL) {\x0d\n  initCJSParseSync();\x0d\n\x0d\n  return createCJSModuleWrap(url\x2C translateContext\x2C parentURL\x2C loadCJSModuleWithModuleLoad);\x0d\n});\x0d\n\x0d\n// Handle CommonJS modules referenced by `require` calls.\x0d\n// This translator function must be sync\x2C as `require` is sync.\x0d\ntranslators.set('require-commonjs'\x2C (url\x2C translateContext\x2C parentURL) => {\x0d\n  initCJSParseSync();\x0d\n  assert(cjsParse);\x0d\n\x0d\n  return createCJSModuleWrap(url\x2C translateContext\x2C parentURL);\x0d\n});\x0d\n\x0d\n// Handle CommonJS modules referenced by `require` calls.\x0d\n// This translator function must be sync\x2C as `require` is sync.\x0d\ntranslators.set('require-commonjs-typescript'\x2C (url\x2C translateContext\x2C parentURL) => {\x0d\n  assert(cjsParse);\x0d\n  translateContext.source = stripTypeScriptModuleTypes(stringify(translateContext.source)\x2C url);\x0d\n  return createCJSModuleWrap(url\x2C translateContext\x2C parentURL);\x0d\n});\x0d\n\x0d\n// This goes through Module._load to accommodate monkey-patchers.\x0d\nfunction loadCJSModuleWithModuleLoad(module\x2C source\x2C url\x2C filename\x2C isMain) {\x0d\n  assert(module === CJSModule._cache[filename]);\x0d\n  wrapModuleLoad(filename\x2C undefined\x2C isMain);\x0d\n}\x0d\n\x0d\n// Handle CommonJS modules referenced by `import` statements or expressions\x2C\x0d\n// or as the initial entry point when the ESM loader handles a CommonJS entry.\x0d\ntranslators.set('commonjs'\x2C function commonjsStrategy(url\x2C translateContext\x2C parentURL) {\x0d\n  if (!cjsParse) {\x0d\n    initCJSParseSync();\x0d\n  }\x0d\n\x0d\n  // For backward-compatibility\x2C it's possible to return a nullish value for\x0d\n  // CJS source associated with a `file:` URL - that usually means the source is not\x0d\n  // customized (is loaded by default load) or the hook author wants it to be reloaded\x0d\n  // through CJS routine. In this case\x2C the source is obtained by calling the\x0d\n  // monkey-patchable CJS loader.\x0d\n  // TODO(joyeecheung): just use wrapModuleLoad and let the CJS loader\x0d\n  // invoke the off-thread hooks. Use a special parent to avoid invoking in-thread\x0d\n  // hooks twice.\x0d\n  const shouldReloadByCJSLoader = (translateContext.shouldBeReloadedByCJSLoader || translateContext.source == null);\x0d\n  const cjsLoader = shouldReloadByCJSLoader ? loadCJSModuleWithModuleLoad : loadCJSModule;\x0d\n\x0d\n  try {\x0d\n    // We still need to read the FS to detect the exports.\x0d\n    translateContext.source ??= readFileSync(new URL(url)\x2C 'utf8');\x0d\n  } catch {\x0d\n    // Continue regardless of error.\x0d\n  }\x0d\n  return createCJSModuleWrap(url\x2C translateContext\x2C parentURL\x2C cjsLoader);\x0d\n});\x0d\n\x0d\n/**\x0d\n * Get or create an entry in the CJS module cache for the given filename.\x0d\n * @param {string} filename CJS module filename\x0d\n * @param {CJSModule} parent The parent CJS module\x0d\n * @returns {CJSModule} the cached CJS module entry\x0d\n */\x0d\nfunction cjsEmplaceModuleCacheEntry(filename\x2C parent) {\x0d\n  // TODO: Do we want to keep hitting the user mutable CJS loader here?\x0d\n  let cjsMod = CJSModule._cache[filename];\x0d\n  if (cjsMod) {\x0d\n    return cjsMod;\x0d\n  }\x0d\n\x0d\n  cjsMod = new CJSModule(filename\x2C parent);\x0d\n  cjsMod.filename = filename;\x0d\n  cjsMod.paths = CJSModule._nodeModulePaths(cjsMod.path);\x0d\n  cjsMod[kIsCachedByESMLoader] = true;\x0d\n  CJSModule._cache[filename] = cjsMod;\x0d\n\x0d\n  return cjsMod;\x0d\n}\x0d\n\x0d\n/**\x0d\n * Pre-parses a CommonJS module's exports and re-exports.\x0d\n * @param {string} filename - The filename of the module.\x0d\n * @param {string} [source] - The source code of the module.\x0d\n * @param {string} [format]\x0d\n * @returns {{module: CJSModule\x2C exportNames: string[]}}\x0d\n */\x0d\nfunction cjsPreparseModuleExports(filename\x2C source\x2C format) {\x0d\n  const module = cjsEmplaceModuleCacheEntry(filename);\x0d\n  if (module[kModuleExportNames] !== undefined) {\x0d\n    return { module\x2C exportNames: module[kModuleExportNames] };\x0d\n  }\x0d\n\x0d\n  if (source === undefined) {\x0d\n    ({ source } = loadSourceForCJSWithHooks(module\x2C filename\x2C format));\x0d\n  }\x0d\n  module[kModuleSource] = source;\x0d\n\x0d\n  debug(`Preparsing exports of ${filename}`);\x0d\n  let exports\x2C reexports;\x0d\n  try {\x0d\n    ({ exports\x2C reexports } = cjsParse(source || ''));\x0d\n  } catch {\x0d\n    exports = [];\x0d\n    reexports = [];\x0d\n  }\x0d\n\x0d\n  const exportNames = new SafeSet(new SafeArrayIterator(exports));\x0d\n\x0d\n  // Set first for cycles.\x0d\n  module[kModuleExportNames] = exportNames;\x0d\n\x0d\n  // If there are any re-exports e.g. `module.exports = { ...require(...) }`\x2C\x0d\n  // pre-parse the dependencies to find transitively exported names.\x0d\n  if (reexports.length) {\x0d\n    module.filename ??= filename;\x0d\n    module.paths ??= CJSModule._nodeModulePaths(dirname(filename));\x0d\n\x0d\n    for (let i = 0; i < reexports.length; i++) {\x0d\n      debug(`Preparsing re-exports of '${filename}'`);\x0d\n      const reexport = reexports[i];\x0d\n      let resolved;\x0d\n      let format;\x0d\n      try {\x0d\n        ({ format\x2C filename: resolved } = resolveForCJSWithHooks(reexport\x2C module\x2C false));\x0d\n      } catch (e) {\x0d\n        debug(`Failed to resolve '${reexport}'\x2C skipping`\x2C e);\x0d\n        continue;\x0d\n      }\x0d\n\x0d\n      if (format === 'commonjs' ||\x0d\n        (!BuiltinModule.normalizeRequirableId(resolved) && findLongestRegisteredExtension(resolved) === '.js')) {\x0d\n        const { exportNames: reexportNames } = cjsPreparseModuleExports(resolved\x2C undefined\x2C format);\x0d\n        for (const name of reexportNames) {\x0d\n          exportNames.add(name);\x0d\n        }\x0d\n      }\x0d\n    }\x0d\n  }\x0d\n\x0d\n  return { module\x2C exportNames };\x0d\n}\x0d\n\x0d\n// Strategy for loading a node builtin CommonJS module that isn't\x0d\n// through normal resolution\x0d\ntranslators.set('builtin'\x2C function builtinStrategy(url\x2C translateContext) {\x0d\n  debug(`Translating BuiltinModule ${url}`\x2C translateContext);\x0d\n  // Slice 'node:' scheme\x0d\n  const id = StringPrototypeSlice(url\x2C 5);\x0d\n  const module = loadBuiltinModule(id\x2C url);\x0d\n  cjsCache.set(url\x2C module);\x0d\n  if (!StringPrototypeStartsWith(url\x2C 'node:') || !module) {\x0d\n    throw new ERR_UNKNOWN_BUILTIN_MODULE(url);\x0d\n  }\x0d\n  debug(`Loading BuiltinModule ${url}`);\x0d\n  return module.getESMFacade();\x0d\n});\x0d\n\x0d\n// Strategy for loading a JSON file\x0d\ntranslators.set('j
n care of that for us. Note that this only\x0d\n    // causes IDNs with an appropriate `xn--` prefix to be decoded.\x0d\n    return `\\\\\\\\${domainToUnicode(hostname)}${pathname}`;\x0d\n  }\x0d\n  // Otherwise\x2C it's a local path that requires a drive letter\x0d\n  const letter = StringPrototypeCodePointAt(pathname\x2C 1) | 0x20;\x0d\n  const sep = StringPrototypeCharAt(pathname\x2C 2);\x0d\n  if (letter < CHAR_LOWERCASE_A || letter > CHAR_LOWERCASE_Z ||   // a..z A..Z\x0d\n      (sep !== ':')) {\x0d\n    throw new ERR_INVALID_FILE_URL_PATH('must be absolute'\x2C url);\x0d\n  }\x0d\n  return StringPrototypeSlice(pathname\x2C 1);\x0d\n}\x0d\n\x0d\nfunction getPathBufferFromURLWin32(url) {\x0d\n  const hostname = url.hostname;\x0d\n  let pathname = url.pathname;\x0d\n  // In the getPathFromURLWin32 variant\x2C we scan the input for backslash (\\)\x0d\n  // and forward slash (/) characters\x2C specifically looking for the ASCII/UTF8\x0d\n  // encoding these and forbidding their use. This is a bit tricky\x0d\n  // because these may conflict with non-UTF8 encodings. For instance\x2C\x0d\n  // in shift-jis\x2C %5C identifies the symbol for the Japanese Yen and not the\x0d\n  // backslash. If we have a url like file:///foo/%5c/bar\x2C then we really have\x0d\n  // no way of knowing if that %5c is meant to be a backslash \\ or a yen sign.\x0d\n  // Passing in an encoding option does not help since our Buffer encoding only\x0d\n  // knows about certain specific text encodings and a single file path might\x0d\n  // actually contain segments that use multiple encodings. It's tricky! So\x2C\x0d\n  // for this variation where we are producing a buffer\x2C we won't scan for the\x0d\n  // slashes at all\x2C and instead will decode the bytes literally into the\x0d\n  // returned Buffer. That said\x2C that can also be tricky because\x2C on windows\x2C\x0d\n  // the file path separator *is* the ASCII backslash. This is a known issue\x0d\n  // on windows specific to the Shift-JIS encoding that we're not really going\x0d\n  // to solve here. Instead\x2C we're going to do the best we can and just\x0d\n  // interpret the input url as a sequence of bytes.\x0d\n\x0d\n  // Because we are converting to a Windows file path here\x2C we need to replace\x0d\n  // the explicit forward slash separators with backslashes. Note that this\x0d\n  // intentionally disregards any percent-encoded forward slashes in the path.\x0d\n  pathname = SideEffectFreeRegExpPrototypeSymbolReplace(FORWARD_SLASH\x2C pathname\x2C '\\\\');\x0d\n\x0d\n  // Now\x2C let's start to build our Buffer. We will initially start with a\x0d\n  // Buffer allocated to fit in the entire string. Worst case there are no\x0d\n  // percent encoded characters and we take the string as is. Any invalid\x0d\n  // percent encodings\x2C e.g. `%ZZ` are ignored and are passed through\x0d\n  // literally.\x0d\n  const decodedu8 = percentDecode(Buffer.from(pathname\x2C 'utf8'));\x0d\n  const decodedPathname = Buffer.from(TypedArrayPrototypeGetBuffer(decodedu8)\x2C\x0d\n                                      TypedArrayPrototypeGetByteOffset(decodedu8)\x2C\x0d\n                                      TypedArrayPrototypeGetByteLength(decodedu8));\x0d\n  if (hostname !== '') {\x0d\n    // If hostname is set\x2C then we have a UNC path\x0d\n    // Pass the hostname through domainToUnicode just in case\x0d\n    // it is an IDN using punycode encoding. We do not need to worry\x0d\n    // about percent encoding because the URL parser will have\x0d\n    // already taken care of that for us. Note that this only\x0d\n    // causes IDNs with an appropriate `xn--` prefix to be decoded.\x0d\n\x0d\n    // This is a bit tricky because of the need to convert to a Buffer\x0d\n    // followed by concatenation of the results.\x0d\n    const prefix = Buffer.from('\\\\\\\\'\x2C 'ascii');\x0d\n    const domain = Buffer.from(domainToUnicode(hostname)\x2C 'utf8');\x0d\n\x0d\n    return Buffer.concat([prefix\x2C domain\x2C decodedPat
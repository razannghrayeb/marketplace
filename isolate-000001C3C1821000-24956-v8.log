script-source,141,node:internal/assert/myers_diff,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayPrototypePush\x2C\x0d\n  Int32Array\x2C\x0d\n  StringPrototypeEndsWith\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  codes: {\x0d\n    ERR_OUT_OF_RANGE\x2C\x0d\n  }\x2C\x0d\n} = require('internal/errors');\x0d\n\x0d\nconst colors = require('internal/util/colors');\x0d\n\x0d\nconst kNopLinesToCollapse = 5;\x0d\nconst kOperations = {\x0d\n  DELETE: -1\x2C\x0d\n  NOP: 0\x2C\x0d\n  INSERT: 1\x2C\x0d\n};\x0d\n\x0d\nfunction areLinesEqual(actual\x2C expected\x2C checkCommaDisparity) {\x0d\n  if (actual === expected) {\x0d\n    return true;\x0d\n  }\x0d\n  if (checkCommaDisparity) {\x0d\n    return (actual + '\x2C') === expected || actual === (expected + '\x2C');\x0d\n  }\x0d\n  return false;\x0d\n}\x0d\n\x0d\nfunction myersDiff(actual\x2C expected\x2C checkCommaDisparity = false) {\x0d\n  const actualLength = actual.length;\x0d\n  const expectedLength = expected.length;\x0d\n  const max = actualLength + expectedLength;\x0d\n\x0d\n  if (max > 2 ** 31 - 1) {\x0d\n    throw new ERR_OUT_OF_RANGE(\x0d\n      'myersDiff input size'\x2C\x0d\n      '< 2^31'\x2C\x0d\n      max\x2C\x0d\n    );\x0d\n  }\x0d\n\x0d\n  const v = new Int32Array(2 * max + 1);\x0d\n  const trace = [];\x0d\n\x0d\n  for (let diffLevel = 0; diffLevel <= max; diffLevel++) {\x0d\n    ArrayPrototypePush(trace\x2C new Int32Array(v)); // Clone the current state of `v`\x0d\n\x0d\n    for (let diagonalIndex = -diffLevel; diagonalIndex <= diffLevel; diagonalIndex += 2) {\x0d\n      const offset = diagonalIndex + max;\x0d\n      const previousOffset = v[offset - 1];\x0d\n      const nextOffset = v[offset + 1];\x0d\n      let x = diagonalIndex === -diffLevel || (diagonalIndex !== diffLevel && previousOffset < nextOffset) ?\x0d\n        nextOffset :\x0d\n        previousOffset + 1;\x0d\n      let y = x - diagonalIndex;\x0d\n\x0d\n      while (\x0d\n        x < actualLength &&\x0d\n        y < expectedLength &&\x0d\n        areLinesEqual(actual[x]\x2C expected[y]\x2C checkCommaDisparity)\x0d\n      ) {\x0d\n        x++;\x0d\n        y++;\x0d\n      }\x0d\n\x0d\n      v[offset] = x;\x0d\n\x0d\n      if (x >= actualLength && y >= expectedLength) {\x0d\n        return backtrack(trace\x2C actual\x2C expected\x2C checkCommaDisparity);\x0d\n      }\x0d\n    }\x0d\n  }\x0d\n}\x0d\n\x0d\nfunction backtrack(trace\x2C actual\x2C expected\x2C checkCommaDisparity) {\x0d\n  const actualLength = actual.length;\x0d\n  const expectedLength = expected.length;\x0d\n  const max = actualLength + expectedLength;\x0d\n\x0d\n  let x = actualLength;\x0d\n  let y = expectedLength;\x0d\n  const result = [];\x0d\n\x0d\n  for (let diffLevel = trace.length - 1; diffLevel >= 0; diffLevel--) {\x0d\n    const v = trace[diffLevel];\x0d\n    const diagonalIndex = x - y;\x0d\n    const offset = diagonalIndex + max;\x0d\n\x0d\n    let prevDiagonalIndex;\x0d\n    if (\x0d\n      diagonalIndex === -diffLevel ||\x0d\n      (diagonalIndex !== diffLevel && v[offset - 1] < v[offset + 1])\x0d\n    ) {\x0d\n      prevDiagonalIndex = diagonalIndex + 1;\x0d\n    } else {\x0d\n      prevDiagonalIndex = diagonalIndex - 1;\x0d\n    }\x0d\n\x0d\n    const prevX = v[prevDiagonalIndex + max];\x0d\n    const prevY = prevX - prevDiagonalIndex;\x0d\n\x0d\n    while (x > prevX && y > prevY) {\x0d\n      const actualItem = actual[x - 1];\x0d\n      const value = checkCommaDisparity && !StringPrototypeEndsWith(actualItem\x2C '\x2C') ? expected[y - 1] : actualItem;\x0d\n      ArrayPrototypePush(result\x2C [ kOperations.NOP\x2C value ]);\x0d\n      x--;\x0d\n      y--;\x0d\n    }\x0d\n\x0d\n    if (diffLevel > 0) {\x0d\n      if (x > prevX) {\x0d\n        ArrayPrototypePush(result\x2C [ kOperations.INSERT\x2C actual[--x] ]);\x0d\n      } else {\x0d\n        ArrayPrototypePush(result\x2C [ kOperations.DELETE\x2C expected[--y] ]);\x0d\n      }\x0d\n    }\x0d\n  }\x0d\n\x0d\n  return result;\x0d\n}\x0d\n\x0d\nfunction printSimpleMyersDiff(diff) {\x0d\n  let message = '';\x0d\n\x0d\n  for (let diffIdx = diff.length - 1; diffIdx >= 0; diffIdx--) {\x0d\n    const { 0: operation\x2C 1: value } = diff[diffIdx];\x0d\n    let color = colors.white;\x0d\n\x0d\n    if (operation === kOperations.INSERT) {\x0d\n      color = colors.green;\x0d\n    } else if (operation === kOperations.DELETE) {\x0d\n      color = colors.red;\x0d\n    }\x0d\n\x0d\n    message += `${color}${value}${colors.white}`;\x0d\n  }\x0d\n\x0d\n  return `\\n${message}`;\x0d\n}\x0d\n\x0d\nfunction printMyersDiff(diff\x2C operator) {\x0d\n  let message = '';\x0d\n  let skipped = false;\x0d\n  let nopCount = 0;\x0d\n\x0d\n  for (let diffIdx = diff.length - 1; diffIdx >= 0; diffIdx--) {\x0d\n    const { 0: operation\x2C 1: value } = diff[diffIdx];\x0d\n    const previousOperation = diffIdx < diff.length - 1 ? diff[diffIdx + 1][0] : null;\x0d\n\x0d\n    // Avoid grouping if only one line would have been grouped otherwise\x0d\n    if (previousOperation === kOperations.NOP && operation !== previousOperation) {\x0d\n      if (nopCount === kNopLinesToCollapse + 1) {\x0d\n        message += `${colors.white}  ${diff[diffIdx + 1][1]}\\n`;\x0d\n      } else if (nopCount === kNopLinesToCollapse + 2) {\x0d\n        message += `${colors.white}  ${diff[diffIdx + 2][1]}\\n`;\x0d\n        message += `${colors.white}  ${diff[diffIdx + 1][1]}\\n`;\x0d\n      } else if (nopCount >= kNopLinesToCollapse + 3) {\x0d\n        message += `${colors.blue}...${colors.white}\\n`;\x0d\n        message += `${colors.white}  ${diff[diffIdx + 1][1]}\\n`;\x0d\n        skipped = true;\x0d\n      }\x0d\n      nopCount = 0;\x0d\n    }\x0d\n\x0d\n    if (operation === kOperations.INSERT) {\x0d\n      if (operator === 'partialDeepStrictEqual') {\x0d\n        message += `${colors.gray}${colors.hasColors ? ' ' : '+'} ${value}${colors.white}\\n`;\x0d\n      } else {\x0d\n        message += `${colors.green}+${colors.white} ${value}\\n`;\x0d\n      }\x0d\n    } else if (operation === kOperations.DELETE) {\x0d\n      message += `${colors.red}-${colors.white} ${value}\\n`;\x0d\n    } else if (operation === kOperations.NOP) {\x0d\n      if (nopCount < kNopLinesToCollapse) {\x0d\n        message += `${colors.white}  ${value}\\n`;\x0d\n      }\x0d\n      nopCount++;\x0d\n    }\x0d\n  }\x0d\n\x0d\n  message = message.trimEnd();\x0d\n\x0d\n  return { message: `\\n${message}`\x2C skipped };\x0d\n}\x0d\n\x0d\nmodule.exports = { myersDiff\x2C printMyersDiff\x2C printSimpleMyersDiff };\x0d\n

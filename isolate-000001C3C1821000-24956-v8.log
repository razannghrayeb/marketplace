script-source,136,node:internal/streams/fast-utf8-stream,'use strict';\x0d\n\x0d\n// This file is derived from the original SonicBoom module\x0d\n// MIT License\x0d\n// Copyright (c) 2017 Matteo Collina\x0d\n\x0d\nconst {\x0d\n  ArrayPrototypePush\x2C\x0d\n  AtomicsWait\x2C\x0d\n  Int32Array\x2C\x0d\n  MathMax\x2C\x0d\n  Number\x2C\x0d\n  SymbolDispose\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  constructSharedArrayBuffer\x2C\x0d\n} = require('internal/util');\x0d\n\x0d\nconst {\x0d\n  Buffer\x2C\x0d\n} = require('buffer');\x0d\n\x0d\nconst fs = require('fs');\x0d\nconst EventEmitter = require('events');\x0d\nconst path = require('path');\x0d\nconst {\x0d\n  clearInterval\x2C\x0d\n  setInterval\x2C\x0d\n  setTimeout\x2C\x0d\n} = require('timers');\x0d\nconst {\x0d\n  codes: {\x0d\n    ERR_INVALID_ARG_TYPE\x2C\x0d\n    ERR_INVALID_ARG_VALUE\x2C\x0d\n    ERR_INVALID_STATE\x2C\x0d\n    ERR_OPERATION_FAILED\x2C\x0d\n  }\x2C\x0d\n} = require('internal/errors');\x0d\n\x0d\nconst {\x0d\n  validateBoolean\x2C\x0d\n  validateFunction\x2C\x0d\n  validateObject\x2C\x0d\n  validateOneOf\x2C\x0d\n  validateString\x2C\x0d\n  validateUint32\x2C\x0d\n} = require('internal/validators');\x0d\n\x0d\nconst BUSY_WRITE_TIMEOUT = 100;\x0d\nconst kEmptyBuffer = Buffer.allocUnsafe(0);\x0d\n\x0d\nconst kNil = new Int32Array(constructSharedArrayBuffer(4));\x0d\n\x0d\nfunction sleep(ms) {\x0d\n  // Also filters out NaN\x2C non-number types\x2C including empty strings\x2C but allows bigints\x0d\n  const valid = ms > 0 && ms < Infinity;\x0d\n  if (valid === false) {\x0d\n    if (typeof ms !== 'number' && typeof ms !== 'bigint') {\x0d\n      throw new ERR_INVALID_ARG_TYPE('ms'\x2C ['number'\x2C 'bigint']\x2C ms);\x0d\n    }\x0d\n    throw new ERR_INVALID_ARG_VALUE.RangeError('ms'\x2C ms\x2C\x0d\n                                               'must be a number greater than 0 and less than Infinity');\x0d\n  }\x0d\n\x0d\n  AtomicsWait(kNil\x2C 0\x2C 0\x2C Number(ms));\x0d\n}\x0d\n\x0d\n// 16 KB. Don't write more than docker buffer size.\x0d\n// https://github.com/moby/moby/blob/513ec73831269947d38a644c278ce3cac36783b2/daemon/logger/copier.go#L13\x0d\nconst kMaxWrite = 16 * 1024;\x0d\nconst kContentModeBuffer = 'buffer';\x0d\nconst kContentModeUtf8 = 'utf8';\x0d\nconst kNullPrototype = { __proto__: null };\x0d\n\x0d\n// Utf8Stream is a port of the original SonicBoom module\x0d\n// (https://github.com/pinojs/sonic-boom) that provides a fast and efficient\x0d\n// way to write UTF-8 encoded data to a file or stream.\x0d\nclass Utf8Stream extends EventEmitter {\x0d\n  #len = 0;\x0d\n  #fd = -1;\x0d\n  #bufs = [];\x0d\n  #lens = [];\x0d\n  #writing = false;\x0d\n  #ending = false;\x0d\n  #reopening = false;\x0d\n  #asyncDrainScheduled = false;\x0d\n  #flushPending = false;\x0d\n  #hwm = 16387; // 16 KB\x0d\n  #file = null;\x0d\n  #destroyed = false;\x0d\n  #minLength = 0;\x0d\n  #maxLength = 0;\x0d\n  #maxWrite = kMaxWrite;\x0d\n  #opening = false;\x0d\n  #periodicFlush = 0;\x0d\n  #periodicFlushTimer = undefined;\x0d\n  #sync = false;\x0d\n  #fsync = false;\x0d\n  #append = true;\x0d\n  #mode = 0o666;\x0d\n  #retryEAGAIN = () => true;\x0d\n  #mkdir = false;\x0d\n  #writingBuf = '';\x0d\n  #write;\x0d\n  #flush;\x0d\n  #flushSync;\x0d\n  #actualWrite;\x0d\n  #fsWriteSync;\x0d\n  #fsWrite;\x0d\n  #fs;\x0d\n\x0d\n  /**\x0d\n   * @typedef {object} Utf8StreamOptions\x0d\n   * @property {string} [dest] - path to the file to write to\x0d\n   * @property {number} [fd] - file descriptor to write to\x0d\n   * @property {number} [minLength] - minimum length of the internal buffer before a write is triggered\x0d\n   * @property {number} [maxLength] - maximum length of the internal buffer before writes are dropped\x0d\n   * @property {number} [maxWrite] - maximum size of a single write operation (default 16384)\x0d\n   * @property {number} [periodicFlush] - interval in ms to flush the stream periodically (default 0\x2C disabled)\x0d\n   * @property {boolean} [sync] - if true\x2C writes are performed synchronously (default false)\x0d\n   * @property {boolean} [fsync] - if true\x2C fsync is called after every write (default false)\x0d\n   * @property {boolean} [append] - if true\x2C data is appended to the file (default true\x2C ignored\x0d\n   *   if fd is provided)\x0d\n   * @property {string} [contentMode] - 'utf8' or 'buffer'\x0d\n   * @property {string} [mode] - file mode (permission and sticky bits)\x2C default is 0o666\x0d\n   * @property {boolean} [mkdir] - if true\x2C the directory path will be created if it does not exist (default false)\x0d\n   * @property {Function} [retryEAGAIN] - function that receives (err\x2C writingBufLength\x2C\x0d\n   *   remainingBufLength) and returns true if EAGAIN/EBUSY should be retried\x0d\n   * @property {object} [fs] - custom fs implementation\x2C must provide write\x2C writeSync\x2C fsync\x2C\x0d\n   *   fsyncSync\x2C close\x2C open\x2C mkdir\x2C mkdirSync methods. Mostly useful for testing.\x0d\n   * @param {Utf8StreamOptions} [options]\x0d\n   */\x0d\n  constructor(options = kNullPrototype) {\x0d\n    validateObject(options\x2C 'options');\x0d\n    let {\x0d\n      fd\x2C\x0d\n    } = options;\x0d\n    const {\x0d\n      dest\x2C\x0d\n      minLength\x2C\x0d\n      maxLength\x2C\x0d\n      maxWrite\x2C\x0d\n      periodicFlush\x2C\x0d\n      sync\x2C\x0d\n      append = true\x2C\x0d\n      mkdir\x2C\x0d\n      retryEAGAIN\x2C\x0d\n      fsync\x2C\x0d\n      contentMode = kContentModeUtf8\x2C\x0d\n      mode\x2C\x0d\n      // Provides for a custom fs implementation. Mostly useful for testing.\x0d\n      fs: overrideFs = {}\x2C\x0d\n    } = options;\x0d\n\x0d\n    super();\x0d\n\x0d\n    fd ??= dest;\x0d\n\x0d\n    validateObject(overrideFs\x2C 'options.fs');\x0d\n    this.#fs = { ...fs\x2C ...overrideFs };\x0d\n    validateFunction(this.#fs.write\x2C 'options.fs.write');\x0d\n    validateFunction(this.#fs.writeSync\x2C 'options.fs.writeSync');\x0d\n    validateFunction(this.#fs.fsync\x2C 'options.fs.fsync');\x0d\n    validateFunction(this.#fs.fsyncSync\x2C 'options.fs.fsyncSync');\x0d\n    validateFunction(this.#fs.close\x2C 'options.fs.close');\x0d\n    validateFunction(this.#fs.open\x2C 'options.fs.open');\x0d\n    validateFunction(this.#fs.mkdir\x2C 'options.fs.mkdir');\x0d\n    validateFunction(this.#fs.mkdirSync\x2C 'options.fs.mkdirSync');\x0d\n\x0d\n    this.#hwm = MathMax(minLength || 0\x2C this.#hwm);\x0d\n    this.#minLength = minLength || 0;\x0d\n    this.#maxLength = maxLength || 0;\x0d\n    this.#maxWrite = maxWrite || kMaxWrite;\x0d\n    this.#periodicFlush = periodicFlush || 0;\x0d\n    this.#sync = sync || false;\x0d\n    this.#fsync = fsync || false;\x0d\n    this.#append = append || false;\x0d\n    this.#mode = mode;\x0d\n    this.#retryEAGAIN = retryEAGAIN || (() => true);\x0d\n    this.#mkdir = mkdir || false;\x0d\n\x0d\n    validateUint32(this.#hwm\x2C 'options.hwm');\x0d\n    validateUint32(this.#minLength\x2C 'options.minLength');\x0d\n    validateUint32(this.#maxLength\x2C 'options.maxLength');\x0d\n    validateUint32(this.#maxWrite\x2C 'options.maxWrite');\x0d\n    validateUint32(this.#periodicFlush\x2C 'options.periodicFlush');\x0d\n    validateBoolean(this.#sync\x2C 'options.sync');\x0d\n    validateBoolean(this.#fsync\x2C 'options.fsync');\x0d\n    validateBoolean(this.#append\x2C 'options.append');\x0d\n    validateBoolean(this.#mkdir\x2C 'options.mkdir');\x0d\n    validateFunction(this.#retryEAGAIN\x2C 'options.retryEAGAIN');\x0d\n    validateOneOf(contentMode\x2C 'options.contentMode'\x2C [kContentModeBuffer\x2C kContentModeUtf8]);\x0d\n\x0d\n    if (contentMode === kContentModeBuffer) {\x0d\n      this.#writingBuf = kEmptyBuffer;\x0d\n      this.#write = (...args) => this.#writeBuffer(...args);\x0d\n      this.#flush = (...args) => this.#flushBuffer(...args);\x0d\n      this.#flushSync = (...args) => this.#flushBufferSync(...args);\x0d\n      this.#actualWrite = (...args) => this.#actualWriteBuffer(...args);\x0d\n      this.#fsWriteSync = () => this.#fs.writeSync(this.#fd\x2C this.#writingBuf);\x0d\n      this.#fsWrite = () => this.#fs.write(this.#fd\x2C this.#writingBuf\x2C (...args) => {\x0d\n        return this.#release(...args);\x0d\n      });\x0d\n    } else {\x0d\n      this.#writingBuf = '';\x0d\n      this.#write = (...args) => this.#writeUtf8(...args);\x0d\n      this.#flush = (...args) => this.#flushUtf8(...args);\x0d\n      this.#flushSync = (...args) => this.#flushSyncUtf8(...args);\x0d\n      this.#actualWrite = (...args) => this.#actualWriteUtf8(...args);\x0d\n      this.#fsWriteSync = () => this.#fs.writeSync(this.#fd\x2C this.#writingBuf\x2C 'utf8');\x0d\n      this.#fsWrite = () => this.#fs.write(this.#fd\x2C this.#writingBuf\x2C 'utf8'\x2C (...args) => {\x0d\n        return this.#release(...args);\x0d\n      });\x0d\n    }\x0d\n\x0d\n    // TODO(@jasnell): Support passing in an AbortSignal to cancel the stream.\x0d\n\x0d\n    // TODO(@jasnell): Support FileHandle here as well?\x0d\n\x0d\n    // TODO(@jasnell): The `dest` option is a path string. We may consider\x0d\n    // also supporting URL and Buffer types here as well like the rest of\x0d\n    // the fs module APIs do.\x0d\n\x0d\n    if (typeof fd === 'number') {\x0d\n      this.#fd = fd;\x0d\n      process.nextTick(() => this.emit('ready'));\x0d\n    } else if (typeof fd === 'string') {\x0d\n      this.#openFile(fd);\x0d\n    } else {\x0d\n      throw new ERR_INVALID_ARG_TYPE('fd'\x2C ['number'\x2C 'string']\x2C fd);\x0d\n    }\x0d\n    if (this.#minLength >= this.#maxWrite) {\x0d\n      throw new ERR_INVALID_ARG_VALUE.RangeError('minLength'\x2C this.#minLength\x2C\x0d\n                                                 `should be smaller than maxWrite (${this.#maxWrite})`);\x0d\n    }\x0d\n\x0d\n    this.on('newListener'\x2C (name) => {\x0d\n      if (name === 'drain') {\x0d\n        this._asyncDrainScheduled = false;\x0d\n      }\x0d\n    });\x0d\n\x0d\n    if (this.#periodicFlush !== 0) {\x0d\n      this.#periodicFlushTimer = setInterval(() => this.flush(null)\x2C this.#periodicFlush);\x0d\n      this.#periodicFlushTimer.unref();\x0d\n    }\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @param {string|Buffer} data\x0d\n   * @returns {boolean}\x0d\n   */\x0d\n  write(data) {\x0d\n    return this.#write(data);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @callback FlushCallback\x0d\n   * @param {Error} [err] - Error if any\x0d\n   * @returns {void}\x0d\n   */\x0d\n\x0d\n  /**\x0d\n   * @param {FlushCallback} [cb]\x0d\n   */\x0d\n  flush(cb = function(_err) {}) { this.#flush(cb); }\x0d\n\x0d\n  flushSync() { return this.#flushSync(); }\x0d\n\x0d\n  /**\x0d\n   * @param {string} [file]\x0d\n   */\x0d\n  reopen(file) {\x0d\n    if (this.#destroyed) {\x0d\n      throw new ERR_INVALID_STATE('Utf8Stream is destroyed');\x0d\n    }\x0d\n\x0d\n    if (this.#opening) {\x0d\n      this.once('ready'\x2C () => this.reopen(file));\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    if (this.#ending) {\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    if (!this.#file) {\x0d\n      throw new ERR_OPERATION_FAILED(\x0d\n        'Unable to reopen a file descriptor\x2C you must pass a file to SonicBoom');\x0d\n    }\x0d\n\x0d\n    if (file) {\x0d\n      this.#file = file;\x0d\n    }\x0d\n    this.#reopening = true;\x0d\n\x0d\n    if (this.#writing) {\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    const fd = this.#fd;\x0d\n    this.once('ready'\x2C () => {\x0d\n      if (fd !== this.#fd) {\x0d\n        this.#fs.close(fd\x2C (err) => {\x0d\n          if (err) {\x0d\n            return this.emit('error'\x2C err);\x0d\n          }\x0d\n        });\x0d\n      }\x0d\n    });\x0d\n\x0d\n    this.#openFile(this.#file);\x0d\n  }\x0d\n\x0d\n  end() {\x0d\n    if (this.#destroyed) {\x0d\n      throw new ERR_INVALID_STATE('Utf8Stream is destroyed');\x0d\n    }\x0d\n\x0d\n    if (this.#opening) {\x0d\n      this.once('ready'\x2C () => {\x0d\n        this.end();\x0d\n      });\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    if (this.#ending) {\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    this.#ending = true;\x0d\n\x0d\n    if (this.#writing) {\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    if (this.#len > 0 && this.#fd >= 0) {\x0d\n      this.#actualWrite();\x0d\n    } else {\x0d\n      this.#actualClose();\x0d\n    }\x0d\n  }\x0d\n\x0d\n  destroy() {\x0d\n    if (this.#destroyed) {\x0d\n      return;\x0d\n    }\x0d\n    this.#actualClose();\x0d\n  }\x0d\n\x0d\n  /** @type {number} */\x0d\n  get mode() { return this.#mode; }\x0d\n\x0d\n  /** @type {string|undefined} */\x0d\n  get file() { return this.#file; }\x0d\n\x0d\n  /** @type {number} */\x0d\n  get fd() { return this.#fd; }\x0d\n\x0d\n  /** @type {number} */\x0d\n  get minLength() { return this.#minLength; }\x0d\n\x0d\n  /** @type {number} */\x0d\n  get maxLength() { return this.#maxLength; }\x0d\n\x0d\n  /** @type {boolean} */\x0d\n  get writing() { return this.#writing; }\x0d\n\x0d\n  /** @type {boolean} */\x0d\n  get sync() { return this.#sync; }\x0d\n\x0d\n  /** @type {boolean} */\x0d\n  get fsync() { return this.#fsync; }\x0d\n\x0d\n  /** @type {boolean} */\x0d\n  get append() { return this.#append; }\x0d\n\x0d\n  /** @type {number} */\x0d\n  get periodicFlush() { return this.#periodicFlush; }\x0d\n\x0d\n  /** @type {'buffer'|'utf8'} */\x0d\n  get contentMode() {\x0d\n    return this.#writingBuf instanceof Buffer ? kContentModeBuffer : kContentModeUtf8;\x0d\n  }\x0d\n\x0d\n  /** @type {boolean} */\x0d\n  get mkdir() { return this.#mkdir; }\x0d\n\x0d\n  [SymbolDispose]() { this.destroy(); }\x0d\n\x0d\n  #release(err\x2C n) {\x0d\n    if (err) {\x0d\n      if ((err.code === 'EAGAIN' || err.code === 'EBUSY') &&\x0d\n          this.#retryEAGAIN(err\x2C this.#writingBuf.length\x2C this.#len - this.#writingBuf.length)) {\x0d\n        if (this.#sync) {\x0d\n          // This error code should not happen in sync mode\x2C because it is\x0d\n          // not using the underlining operating system asynchronous functions.\x0d\n          // However i
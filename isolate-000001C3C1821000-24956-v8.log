e and return its Promise.\x0d\n   * @param {string} [parentURL] The URL of the module where the module request is initiated.\x0d\n   *   It's undefined if it's from the root module.\x0d\n   * @param {ModuleRequest} request Module request.\x0d\n   * @param {ModuleRequestType} requestType Type of the module request.\x0d\n   * @returns {Promise<ModuleJobBase>|ModuleJobBase}\x0d\n   */\x0d\n  getOrCreateModuleJob(parentURL\x2C request\x2C requestType) {\x0d\n    let maybePromise;\x0d\n    if (requestType === kRequireInImportedCJS || requestType === kImportInRequiredESM) {\x0d\n      // In these two cases\x2C resolution must be synchronous.\x0d\n      maybePromise = this.resolveSync(parentURL\x2C request);\x0d\n      assert(!isPromise(maybePromise));\x0d\n    } else {\x0d\n      maybePromise = this.#resolve(parentURL\x2C request);\x0d\n    }\x0d\n\x0d\n    const afterResolve = (resolveResult) => {\x0d\n      return this.#getOrCreateModuleJobAfterResolve(parentURL\x2C resolveResult\x2C request\x2C requestType);\x0d\n    };\x0d\n\x0d\n    if (isPromise(maybePromise)) {\x0d\n      return PromisePrototypeThen(maybePromise\x2C afterResolve);\x0d\n    }\x0d\n    return afterResolve(maybePromise);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * This method is usually called indirectly as part of the loading processes.\x0d\n   * Use directly with caution.\x0d\n   * @param {string} specifier The first parameter of an `import()` expression.\x0d\n   * @param {string} parentURL Path of the parent importing the module.\x0d\n   * @param {Record<string\x2C string>} importAttributes Validations for the\x0d\n   *   module import.\x0d\n   * @param {number} [phase] The phase of the import.\x0d\n   * @param {boolean} [isEntryPoint] Whether this is the realm-level entry point.\x0d\n   * @returns {Promise<ModuleExports>}\x0d\n   */\x0d\n  async import(specifier\x2C parentURL\x2C importAttributes\x2C phase = kEvaluationPhase\x2C isEntryPoint = false) {\x0d\n    return onImport.tracePromise(async () => {\x0d\n      const request = { specifier\x2C phase\x2C attributes: importAttributes\x2C __proto__: null };\x0d\n      let moduleJob;\x0d\n      try {\x0d\n        moduleJob = await this.getOrCreateModuleJob(parentURL\x2C request);\x0d\n      } catch (e) {\x0d\n        if (e?.code === 'ERR_ASYNC_LOADER_REQUEST_NEVER_SETTLED') {\x0d\n          return new Promise(() => {});\x0d\n        }\x0d\n        throw e;\x0d\n      }\x0d\n      if (phase === kSourcePhase) {\x0d\n        const module = await moduleJob.modulePromise;\x0d\n        return module.getModuleSourceObject();\x0d\n      }\x0d\n      const { module } = await moduleJob.run(isEntryPoint);\x0d\n      return module.getNamespace();\x0d\n    }\x2C {\x0d\n      __proto__: null\x2C\x0d\n      parentURL\x2C\x0d\n      url: specifier\x2C\x0d\n    });\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @see {@link AsyncLoaderHooks.register}\x0d\n   * @returns {any}\x0d\n   */\x0d\n  register(specifier\x2C parentURL\x2C data\x2C transferList\x2C isInternal) {\x0d\n    if (!this.#asyncLoaderHooks) {\x0d\n      // On the loader hook worker thread\x2C the #asyncLoaderHooks must already have been initialized\x0d\n      // to be an instance of AsyncLoaderHooksOnLoaderHookWorker\x2C so this branch can only ever\x0d\n      // be hit on a non-loader-hook thread that will talk to the loader hook worker thread.\x0d\n      const { AsyncLoaderHooksProxiedToLoaderHookWorker } = require('internal/modules/esm/hooks');\x0d\n      this.#setAsyncLoaderHooks(new AsyncLoaderHooksProxiedToLoaderHookWorker());\x0d\n    }\x0d\n    return this.#asyncLoaderHooks.register(`${specifier}`\x2C `${parentURL}`\x2C data\x2C transferList\x2C isInternal);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Resolve a module request to a URL identifying the location of the module. Handles customization hooks\x2C\x0d\n   * if any.\x0d\n   * @param {string} [parentURL] The URL of the module where the module request is initiated.\x0d\n   *   It's undefined if it's from the root module.\x0d\n   * @param {ModuleRequest} request Module request.\x0d\n   * @returns {Promise<{format: string\x2C url: string}>|{format: string\x2C url: string}}\x0d\n   */\x0d\n  #resolve(parentURL\x2C request) {\x0d\n    if (this.isForAsyncLoaderHookWorker) {\x0d\n      const specifier = `${request.specifier}`;\x0d\n      const importAttributes = request.attributes ?? kEmptyObject;\x0d\n      // TODO(joyeecheung): invoke the synchronous hooks in the default step on loader thread.\x0d\n      return this.#asyncLoaderHooks.resolve(specifier\x2C parentURL\x2C importAttributes);\x0d\n    }\x0d\n\x0d\n    return this.resolveSync(parentURL\x2C request);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Either return a cached resolution\x2C or perform the default resolution which is synchronous\x2C and\x0d\n   * cache the result.\x0d\n   * @param {string} specifier See {@link resolve}.\x0d\n   * @param {{ parentURL?: string\x2C importAttributes: ImportAttributes\x2C conditions?: string[]}} context\x0d\n   * @returns {{ format: string\x2C url: string }}\x0d\n   */\x0d\n  #cachedDefaultResolve(specifier\x2C context) {\x0d\n    const { parentURL\x2C importAttributes } = context;\x0d\n    const requestKey = this.#resolveCache.serializeKey(specifier\x2C importAttributes);\x0d\n    const cachedResult = this.#resolveCache.get(requestKey\x2C parentURL);\x0d\n    if (cachedResult != null) {\x0d\n      return cachedResult;\x0d\n    }\x0d\n    defaultResolve ??= require('internal/modules/esm/resolve').defaultResolve;\x0d\n    const result = defaultResolve(specifier\x2C context);\x0d\n    this.#resolveCache.set(requestKey\x2C parentURL\x2C result);\x0d\n    return result;\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * This is the default resolve step for module.registerHooks()\x2C which incorporates asynchronous hooks\x0d\n   * from module.register() which are run in a blocking fashion for it to be synchronous.\x0d\n   * @param {string|URL} specifier See {@link resolveSync}.\x0d\n   * @param {{ parentURL?: string\x2C importAttributes: ImportAttributes\x2C conditions?: string[]}} context\x0d\n   *   See {@link resolveSync}.\x0d\n   * @returns {{ format: string\x2C url: string }}\x0d\n   */\x0d\n  #resolveAndMaybeBlockOnLoaderThread(specifier\x2C context) {\x0d\n    if (this.#asyncLoaderHooks?.resolveSync) {\x0d\n      return this.#asyncLoaderHooks.resolveSync(specifier\x2C context.parentURL\x2C context.importAttributes);\x0d\n    }\x0d\n    return this.#cachedDefaultResolve(specifier\x2C context);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Similar to {@link resolve}\x2C but the results are always synchronously returned. If there are any\x0d\n   * asynchronous resolve hooks from module.register()\x2C it will block until the results are returned\x0d\n   * from the loader thread for this to be synchronous.\x0d\n   * This is here to support `import.meta.resolve()`\x2C `require()` in imported CJS\x2C and\x0d\n   * `module.registerHooks()` hooks.\x0d\n   * @param {string} [parentURL] See {@link resolve}.\x0d\n   * @param {ModuleRequest} request See {@link resolve}.\x0d\n   * @returns {{ format: string\x2C url: string }}\x0d\n   */\x0d\n  resolveSync(parentURL\x2C request) {\x0d\n    const specifier = `${request.specifier}`;\x0d\n    const importAttributes = request.attributes ?? kEmptyObject;\x0d\n\x0d\n    if (syncResolveHooks.length) {\x0d\n      // Has module.registerHooks() hooks\x2C chain the asynchronous hooks in the default step.\x0d\n      return resolveWithSyncHooks(specifier\x2C parentURL\x2C importAttributes\x2C this.#defaultConditions\x2C\x0d\n                                  this.#resolveAndMaybeBlockOnLoaderThread.bind(this));\x0d\n    }\x0d\n    const context = {\x0d\n      ...request\x2C\x0d\n      conditions: this.#defaultConditions\x2C\x0d\n      parentURL\x2C\x0d\n      importAttributes\x2C\x0d\n      __proto__: null\x2C\x0d\n    };\x0d\n    return this.#resolveAndMaybeBlockOnLoaderThread(specifier\x2C context);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Provide source that is understood by one of Node's translators. Handles customization hooks\x2C\x0d\n   * if any.\x0d\n   * @typedef { {format: ModuleFormat\x2C source: ModuleSource }} LoadResult\x0d\n   * @param {string} url The URL of the module to be loaded.\x0d\n   * @param {object} context Metadata about the module\x0d\n   * @returns {Promise<LoadResult> | LoadResult}}\x0d\n   */\x0d\n  load(url\x2C context) {\x0d\n    if (this.isForAsyncLoaderHookWorker) {\x0d\n      // TODO(joyeecheung): invoke the synchronous hooks in the default step on loader thread.\x0d\n      return this.#asyncLoaderHooks.load(url\x2C context);\x0d\n    }\x0d\n    return this.#loadSync(url\x2C context);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * This is the default load step for module.registerHooks()\x2C which incorporates asynchronous hooks\x0d\n   * from module.register() which are run in a blocking fashion for it to be synchronous.\x0d\n   * @param {string} url See {@link load}\x0d\n   * @param {object} context See {@link load}\x0d\n   * @returns {{ format: ModuleFormat\x2C source: ModuleSource }}\x0d\n   */\x0d\n  #loadAndMaybeBlockOnLoaderThread(url\x2C context) {\x0d\n    if (this.#asyncLoaderHooks?.loadSync) {\x0d\n      return this.#asyncLoaderHooks.loadSync(url\x2C context);\x0d\n    }\x0d\n    defaultLoadSync ??= require('internal/modules/esm/load').defaultLoadSync;\x0d\n    return defaultLoadSync(url\x2C context);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Similar to {@link load} but this is always run synchronously. If there are asynchronous hooks\x0d\n   * from module.register()\x2C this blocks on the loader thread for it to return synchronously.\x0d\n   *\x0d\n   * This is here to support `require()` in imported CJS and `module.registerHooks()` hooks.\x0d\n   * @param {string} url See {@link load}\x0d\n   * @param {object} [context] See {@link load}\x0d\n   * @returns {{ format: ModuleFormat\x2C source: ModuleSource }}\x0d\n   */\x0d\n  #loadSync(url\x2C context) {\x0d\n    if (syncLoadHooks.length) {\x0d\n      //
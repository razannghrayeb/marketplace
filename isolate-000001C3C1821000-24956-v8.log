script-source,135,node:internal/repl/history,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayPrototypeIndexOf\x2C\x0d\n  ArrayPrototypeJoin\x2C\x0d\n  ArrayPrototypePop\x2C\x0d\n  ArrayPrototypeShift\x2C\x0d\n  ArrayPrototypeSplice\x2C\x0d\n  ArrayPrototypeUnshift\x2C\x0d\n  Boolean\x2C\x0d\n  RegExpPrototypeSymbolSplit\x2C\x0d\n  StringPrototypeStartsWith\x2C\x0d\n  StringPrototypeTrim\x2C\x0d\n  Symbol\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst { validateNumber\x2C validateArray } = require('internal/validators');\x0d\n\x0d\nconst path = require('path');\x0d\nconst fs = require('fs');\x0d\nconst os = require('os');\x0d\nlet debug = require('internal/util/debuglog').debuglog('repl'\x2C (fn) => {\x0d\n  debug = fn;\x0d\n});\x0d\nconst permission = require('internal/process/permission');\x0d\nconst { clearTimeout\x2C setTimeout } = require('timers');\x0d\nconst {\x0d\n  reverseString\x2C\x0d\n} = require('internal/readline/utils');\x0d\n\x0d\n// The debounce is to guard against code pasted into the REPL.\x0d\nconst kDebounceHistoryMS = 15;\x0d\nconst kHistorySize = 30;\x0d\n\x0d\n// Class fields\x0d\nconst kTimer = Symbol('_kTimer');\x0d\nconst kWriting = Symbol('_kWriting');\x0d\nconst kPending = Symbol('_kPending');\x0d\nconst kRemoveHistoryDuplicates = Symbol('_kRemoveHistoryDuplicates');\x0d\nconst kHistoryHandle = Symbol('_kHistoryHandle');\x0d\nconst kHistoryPath = Symbol('_kHistoryPath');\x0d\nconst kContext = Symbol('_kContext');\x0d\nconst kIsFlushing = Symbol('_kIsFlushing');\x0d\nconst kHistory = Symbol('_kHistory');\x0d\nconst kSize = Symbol('_kSize');\x0d\nconst kIndex = Symbol('_kIndex');\x0d\n\x0d\n// Class methods\x0d\nconst kNormalizeLineEndings = Symbol('_kNormalizeLineEndings');\x0d\nconst kWriteToOutput = Symbol('_kWriteToOutput');\x0d\nconst kOnLine = Symbol('_kOnLine');\x0d\nconst kOnExit = Symbol('_kOnExit');\x0d\nconst kInitializeHistory = Symbol('_kInitializeHistory');\x0d\nconst kHandleHistoryInitError = Symbol('_kHandleHistoryInitError');\x0d\nconst kHasWritePermission = Symbol('_kHasWritePermission');\x0d\nconst kValidateOptions = Symbol('_kValidateOptions');\x0d\nconst kResolveHistoryPath = Symbol('_kResolveHistoryPath');\x0d\nconst kReplHistoryMessage = Symbol('_kReplHistoryMessage');\x0d\nconst kFlushHistory = Symbol('_kFlushHistory');\x0d\nconst kGetHistoryPath = Symbol('_kGetHistoryPath');\x0d\n\x0d\nclass ReplHistory {\x0d\n  constructor(context\x2C options) {\x0d\n    this[kValidateOptions](options);\x0d\n\x0d\n    this[kHistoryPath] = ReplHistory[kGetHistoryPath](options);\x0d\n    this[kContext] = context;\x0d\n    this[kTimer] = null;\x0d\n    this[kWriting] = false;\x0d\n    this[kPending] = false;\x0d\n    this[kRemoveHistoryDuplicates] = options.removeHistoryDuplicates || false;\x0d\n    this[kHistoryHandle] = null;\x0d\n    this[kIsFlushing] = false;\x0d\n    this[kSize] = options.size ?? context.historySize ?? kHistorySize;\x0d\n    this[kHistory] = options.history ?? [];\x0d\n    this[kIndex] = -1;\x0d\n  }\x0d\n\x0d\n  initialize(onReadyCallback) {\x0d\n    // Empty string disables persistent history\x0d\n    if (this[kHistoryPath] === '') {\x0d\n      // Save a reference to the context's original _historyPrev\x0d\n      this.historyPrev = this[kContext]._historyPrev;\x0d\n      this[kContext]._historyPrev = this[kReplHistoryMessage].bind(this);\x0d\n      return onReadyCallback(null\x2C this[kContext]);\x0d\n    }\x0d\n\x0d\n    const resolvedPath = this[kResolveHistoryPath]();\x0d\n    if (!resolvedPath) {\x0d\n      ReplHistory[kWriteToOutput](\x0d\n        this[kContext]\x2C\x0d\n        '\\nError: Could not get the home directory.\\n' +\x0d\n        'REPL session history will not be persisted.\\n'\x2C\x0d\n      );\x0d\n\x0d\n      // Save a reference to the context's original _historyPrev\x0d\n      this.historyPrev = this[kContext]._historyPrev;\x0d\n      this[kContext]._historyPrev = this[kReplHistoryMessage].bind(this);\x0d\n      return onReadyCallback(null\x2C this[kContext]);\x0d\n    }\x0d\n\x0d\n    if (!this[kHasWritePermission]()) {\x0d\n      ReplHistory[kWriteToOutput](\x0d\n        this[kContext]\x2C\x0d\n        '\\nAccess to FileSystemWrite is restricted.\\n' +\x0d\n        'REPL session history will not be persisted.\\n'\x2C\x0d\n      );\x0d\n      return onReadyCallback(null\x2C this[kContext]);\x0d\n    }\x0d\n\x0d\n    this[kContext].pause();\x0d\n\x0d\n    this[kInitializeHistory](onReadyCallback).catch((err) => {\x0d\n      this[kHandleHistoryInitError](err\x2C onReadyCallback);\x0d\n    });\x0d\n  }\x0d\n\x0d\n  addHistory(isMultiline\x2C lastCommandErrored) {\x0d\n    const line = this[kContext].line;\x0d\n\x0d\n    if (line.length === 0) return '';\x0d\n\x0d\n    // If the history is disabled then return the line\x0d\n    if (this[kSize] === 0) return line;\x0d\n\x0d\n    // If the trimmed line is empty then return the line\x0d\n    if (StringPrototypeTrim(line).length === 0) return line;\x0d\n\x0d\n    // This is necessary because each line would be saved in the history while creating\x0d\n    // a new multiline\x2C and we don't want that.\x0d\n    if (isMultiline && this[kIndex] === -1) {\x0d\n      ArrayPrototypeShift(this[kHistory]);\x0d\n    } else if (lastCommandErrored) {\x0d\n      // If the last command errored and we are trying to edit the history to fix it\x0d\n      // remove the broken one from the history\x0d\n      ArrayPrototypeShift(this[kHistory]);\x0d\n    }\x0d\n\x0d\n    const normalizedLine = ReplHistory[kNormalizeLineEndings](line\x2C '\\n'\x2C '\\r');\x0d\n\x0d\n    if (this[kHistory].length === 0 || this[kHistory][0] !== normalizedLine) {\x0d\n      if (this[kRemoveHistoryDuplicates]) {\x0d\n        // Remove older history line if identical to new one\x0d\n        const dupIndex = ArrayPrototypeIndexOf(this[kHistory]\x2C line);\x0d\n        if (dupIndex !== -1) ArrayPrototypeSplice(this[kHistory]\x2C dupIndex\x2C 1);\x0d\n      }\x0d\n\x0d\n      // Add the new line to the history\x0d\n      ArrayPrototypeUnshift(this[kHistory]\x2C normalizedLine);\x0d\n\x0d\n      // Only store so many\x0d\n      if (this[kHistory].length > this[kSize])\x0d\n        ArrayPrototypePop(this[kHistory]);\x0d\n    }\x0d\n\x0d\n    this[kIndex] = -1;\x0d\n\x0d\n    const finalLine = isMultiline ? reverseString(this[kHistory][0]) : this[kHistory][0];\x0d\n\x0d\n    // The listener could change the history object\x2C possibly\x0d\n    // to remove the last added entry if it is sensitive and should\x0d\n    // not be persisted in the history\x2C like a password\x0d\n    // Emit history event to notify listeners of update\x0d\n    this[kContext].emit('history'\x2C this[kHistory]);\x0d\n\x0d\n    return finalLine;\x0d\n  }\x0d\n\x0d\n  canNavigateToNext() {\x0d\n    return this[kIndex] > -1 && this[kHistory].length > 0;\x0d\n  }\x0d\n\x0d\n  navigateToNext(substringSearch) {\x0d\n    if (!this.canNavigateToNext()) {\x0d\n      return null;\x0d\n    }\x0d\n    const search = substringSearch || '';\x0d\n    let index = this[kIndex] - 1;\x0d\n\x0d\n    while (\x0d\n      index >= 0 &&\x0d\n      (!StringPrototypeStartsWith(this[kHistory][index]\x2C search) ||\x0d\n        this[kContext].line === this[kHistory][index])\x0d\n    ) {\x0d\n      index--;\x0d\n    }\x0d\n\x0d\n    this[kIndex] = index;\x0d\n\x0d\n    if (index === -1) {\x0d\n      return search;\x0d\n    }\x0d\n\x0d\n    return ReplHistory[kNormalizeLineEndings](this[kHistory][index]\x2C '\\r'\x2C '\\n');\x0d\n  }\x0d\n\x0d\n  canNavigateToPrevious() {\x0d\n    return this[kHistory].length !== this[kIndex] && this[kHistory].length > 0;\x0d\n  }\x0d\n\x0d\n  navigateToPrevious(substringSearch = '') {\x0d\n    if (!this.canNavigateToPrevious()) {\x0d\n      return null;\x0d\n    }\x0d\n    const search = substringSearch || '';\x0d\n    let index = this[kIndex] + 1;\x0d\n\x0d\n    while (\x0d\n      index < this[kHistory].length &&\x0d\n      (!StringPrototypeStartsWith(this[kHistory][index]\x2C search) ||\x0d\n        this[kContext].line === this[kHistory][index])\x0d\n    ) {\x0d\n      index++;\x0d\n    }\x0d\n\x0d\n    this[kIndex] = index;\x0d\n\x0d\n    if (index === this[kHistory].length) {\x0d\n      return search;\x0d\n    }\x0d\n\x0d\n    return ReplHistory[kNormalizeLineEndings](this[kHistory][index]\x2C '\\r'\x2C '\\n');\x0d\n  }\x0d\n\x0d\n  get size() { return this[kSize]; }\x0d\n  get isFlushing() { return this[kIsFlushing]; }\x0d\n  get history() { return this[kHistory]; }\x0d\n  set history(value) { this[kHistory] = value; }\x0d\n  get index() { return this[kIndex]; }\x0d\n  set index(value) { this[kIndex] = value; }\x0d\n\x0d\n  // Start private methods\x0d\n\x0d\n  static [kGetHistoryPath](options) {\x0d\n    let historyPath = options.filePath;\x0d\n    if (typeof historyPath === 'string') {\x0d\n      historyPath = StringPrototypeTrim(historyPath);\x0d\n    }\x0d\n    return historyPath;\x0d\n  }\x0d\n\x0d\n  static [kNormalizeLineEndings](line\x2C from\x2C to) {\x0d\n    // Multiline history entries are saved reversed\x0d\n    // History is structured with the newest entries at the top\x0d\n    // and the oldest at the bottom. Multiline histories\x2C however\x2C only occupy\x0d\n    // one line in the history file. When loading multiline history with\x0d\n    // an old node binary\x2C the history will be saved in the old format.\x0d\n    // This is why we need to reverse the multilines.\x0d\n    // Reversing the multilines is necessary when adding / editing and displaying them\x0d\n    return reverseString(line\x2C from\x2C to);\x0d\n  }\x0d\n\x0d\n  static [kWriteToOutput](context\x2C message) {\x0d\n    if (typeof context._writeToOutput === 'function') {\x0d\n      context._writeToOutput(message);\x0d\n      if (typeof context._refreshLine === 'function') {\x0d\n        context._refreshLine();\x0d\n      }\x0d\n    }\x0d\n  }\x0d\n\x0d\n  [kResolveHistoryPath]() {\x0d\n    if (!this[kHistoryPath]) {\x0d\n      try {\x0d\n        this[kHistoryPath] = path.join(os.homedir()\x2C '.node_repl_history');\x0d\n        return this[kHistoryPath];\x0d\n      } catch (err) {\x0d\n        debug(err.stack);\x0d\n        return null;\x0d\n      }\x0d\n    }\x0d\n    return this[kHistoryPath];\x0d\n  }\x0d\n\x0d\n  [kHasWritePermission]() {\x0d\n    return !(permission.isEnabled() &&\x0d\n             permission.has('fs.write'\x2C this[kHistoryPath]) === false);\x0d\n  }\x0d\n\x0d\n  [kValidateOptions](options) {\x0d\n    if (typeof options.history !== 'undefined') {\x0d\n      validateArray(options.history\x2C 'history');\x0d\n    }\x0d\n    if (typeof options.size !== 'undefined') {\x0d\n      validateNumber(options.size\x2C 'size'\x2C 0);\x0d\n    }\x0d\n  }\x0d\n\x0d\n  async [kInitializeHistory](onReadyCallback) {\x0d\n    try {\x0d\n      // Open and close file first to ensure it exists\x0d\n      // History files are conventionally not readable by others\x0d\n      // 0o0600 = read/write for owner only\x0d\n      const hnd = await fs.promises.open(this[kHistoryPath]\x2C 'a+'\x2C 0o0600);\x0d\n      await hnd.close();\x0d\n\x0d\n      let data;\x0d\n      try {\x0d\n        data = await fs.promises.readFile(this[kHistoryPath]\x2C 'utf8');\x0d\n      } catch (err) {\x0d\n        return this[kHandleHistoryInitError](err\x2C onReadyCallback);\x0d\n      }\x0d\n\x0d\n      if (data) {\x0d\n        this[kHistory] = RegExpPrototypeSymbolSplit(/\\r?\\n+/\x2C data\x2C this[kSize]);\x0d\n      } else {\x0d\n        this[kHistory] = [];\x0d\n      }\x0d\n\x0d\n      validateArray(this[kHistory]\x2C 'history');\x0d\n\x0d\n      const handle = await fs.promises.open(this[kHistoryPath]\x2C 'r+');\x0d\n      this[kHistoryHandle] = handle;\x0d\n\x0d\n      await handle.truncate(0);\x0d\n\x0d\n      this[kContext].on('line'\x2C this[kOnLine].bind(this));\x0d\n      this[kContext].once('exit'\x2C this[kOnExit].bind(this));\x0d\n\x0d\n      this[kContext].once('flushHistory'\x2C () => {\x0d\n        if (!this[kContext].closed) {\x0d\n          this[kContext].resume();\x0d\n          onReadyCallback(null\x2C this[kContext]);\x0d\n        }\x0d\n      });\x0d\n\x0d\n      await this[kFlushHistory]();\x0d\n    } catch (err) {\x0d\n      return this[kHandleHistoryInitError](err\x2C onReadyCallback);\x0d\n    }\x0d\n  }\x0d\n\x0d\n  [kHandleHistoryInitError](err\x2C onReadyCallback) {\x0d\n    // Cannot open history file.\x0d\n    // Don't crash\x2C just don't persist history.\x0d\n    ReplHistory[kWriteToOutput](\x0d\n      this[kContext]\x2C\x0d\n      '\\nError: Could not open history file.\\n' +\x0d\n      'REPL session history will not be persisted.\\n'\x2C\x0d\n    );\x0d\n    debug(err.stack);\x0d\n\x0d\n    // Save a reference to the context's original _historyPrev\x0d\n    this.historyPrev = this[kContext]._historyPrev;\x0d\n    this[kContext]._historyPrev = this[kReplHistoryMessage].bind(this);\x0d\n    this[kContext].resume();\x0d\n    return onReadyCallback(null\x2C this[kContext]);\x0d\n  }\x0d\n\x0d\n  [kOnLine]() {\x0d\n    this[kIsFlushing] = true;\x0d\n\x0d\n    if (this[kTimer]) {\x0d\n      clearTimeout(this[kTimer]);\x0d\n    }\x0d\n\x0d\n    this[kTimer] = setTimeout(() => this[kFlushHistory]()\x2C kDebounceHistoryMS);\x0d\n  }\x0d\n\x0d\n  async [kFlushHistory]() {\x0d\n    this[kTimer] = null;\x0d\n    if (this[kWriting]) {\x0d\n      this[kPending] = true;\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    this[kWriting] = true;\x0d\n    const historyData = ArrayPrototypeJoin(this[kHistory]\x2C '\\n');\x0d\n\x0d\n    try {\x0d\n      await this[kHistoryHandle].write(historyData\x2C 0\x2C 'utf8');\x0d\n      this[kWriting] = false;\x0d\n\x0d\n      if (this[kPending]) {\x0d\n        this[kPending] = false;\x0d\n        this[kOnLine]();\x0d\n      } else {\x0d\n        this[kIsFlushing] = Boolean(this[kTimer]);\x0d\n        if (!this[kIsFlushing]) {\x0d\n          this[kContext].emit('flushHistory');\x0d\n        }\x0d\n      }\x0d\n    } catch (err) {\x0d\n      this[kWriting] = false;\x0d\n      debug('Error writing history file:'\x2C err);\x0d\n    }\x0d\n  }\x0d\n\x0d\n  async [kOnExit]() {\x0d\n    if (this[kIsFlushing]) {\x0d\n      this[kContext].once('flushHistory'\x2C this[kOnExit].bind(this));\x0d\n      return;\x0d\n    }\x0d\n    this[kContext].off('line'\x2C this[kOnLine].bind(this));\x0d\n\x0d\n    if (this[kHistoryHandle] !== null) {\x0d\n      try {\x0d\n        await this[kHistoryHandle].close();\x0d\n      } catch (err) {\x0d\n        debug('Error closing history file:'\x2C err);\x0d\n      }\x0d\n    }\x0d\n  }\x0d\n\x0d\n  [kReplHistoryMessage]() {\x0d\n    if (this[kHistory].length === 0) {\x0d\n      ReplHistory[kWriteToOutput](\x0d\n        this[kContext]\x2C\x0d\n        '\\nPersistent history support disabled. ' +\x0d\n        'Set the NODE_REPL_HISTORY environment\\nvariable to ' +\x0d\n        'a valid\x2C user-writable path to enable.\\n'\x2C\x0d\n      );\x0d\n    }\x0d\n    // First restore the original method on the context\x0d\n    this[kContext]._historyPrev = this.historyPrev;\x0d\n    // Then call it with the correct context\x0d\n    return this[kContext]._historyPrev();\x0d\n  }\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  ReplHistory\x2C\x0d\n};\x0d\n

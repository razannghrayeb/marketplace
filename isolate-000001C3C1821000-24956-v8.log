script-source,19,node:internal/util/debuglog,'use strict';\x0d\n\x0d\nconst {\x0d\n  MathFloor\x2C\x0d\n  Number\x2C\x0d\n  NumberPrototypeToFixed\x2C\x0d\n  ObjectDefineProperty\x2C\x0d\n  RegExp\x2C\x0d\n  RegExpPrototypeExec\x2C\x0d\n  SafeArrayIterator\x2C\x0d\n  SafeMap\x2C\x0d\n  StringPrototypePadStart\x2C\x0d\n  StringPrototypeSplit\x2C\x0d\n  StringPrototypeToLowerCase\x2C\x0d\n  StringPrototypeToUpperCase\x2C\x0d\n} = primordials;\x0d\nconst {\x0d\n  CHAR_LOWERCASE_B: kTraceBegin\x2C\x0d\n  CHAR_LOWERCASE_E: kTraceEnd\x2C\x0d\n  CHAR_LOWERCASE_N: kTraceInstant\x2C\x0d\n} = require('internal/constants');\x0d\nconst { inspect\x2C format\x2C formatWithOptions } = require('internal/util/inspect');\x0d\nconst { getCategoryEnabledBuffer\x2C trace } = internalBinding('trace_events');\x0d\n\x0d\n// `debugImpls` and `testEnabled` are deliberately not initialized so any call\x0d\n// to `debuglog()` before `initializeDebugEnv()` is called will throw.\x0d\nlet debugImpls;\x0d\nlet testEnabled;\x0d\n\x0d\n\x0d\n// `debugEnv` is initial value of process.env.NODE_DEBUG\x0d\nfunction initializeDebugEnv(debugEnv) {\x0d\n  debugImpls = { __proto__: null };\x0d\n  if (debugEnv) {\x0d\n    // This is run before any user code\x2C it's OK not to use primordials.\x0d\n    debugEnv = debugEnv.replace(/[|\\\\{}()[\\]^$+?.]/g\x2C '\\\\$&')\x0d\n      .replaceAll('*'\x2C '.*')\x0d\n      .replaceAll('\x2C'\x2C '$|^');\x0d\n    const debugEnvRegex = new RegExp(`^${debugEnv}$`\x2C 'i');\x0d\n    testEnabled = (str) => RegExpPrototypeExec(debugEnvRegex\x2C str) !== null;\x0d\n  } else {\x0d\n    testEnabled = () => false;\x0d\n  }\x0d\n}\x0d\n\x0d\n// Emits warning when user sets\x0d\n// NODE_DEBUG=http or NODE_DEBUG=http2.\x0d\nfunction emitWarningIfNeeded(set) {\x0d\n  if ('HTTP' === set || 'HTTP2' === set) {\x0d\n    process.emitWarning('Setting the NODE_DEBUG environment variable ' +\x0d\n      'to \\'' + StringPrototypeToLowerCase(set) + '\\' can expose sensitive ' +\x0d\n      'data (such as passwords\x2C tokens and authentication headers) ' +\x0d\n      'in the resulting log.');\x0d\n  }\x0d\n}\x0d\n\x0d\nconst noop = () => {};\x0d\n\x0d\nlet utilColors;\x0d\nfunction lazyUtilColors() {\x0d\n  utilColors ??= require('internal/util/colors');\x0d\n  return utilColors;\x0d\n}\x0d\n\x0d\nfunction debuglogImpl(enabled\x2C set) {\x0d\n  if (debugImpls[set] === undefined) {\x0d\n    if (enabled) {\x0d\n      const pid = process.pid;\x0d\n      emitWarningIfNeeded(set);\x0d\n      debugImpls[set] = function debug(...args) {\x0d\n        const colors = lazyUtilColors().shouldColorize(process.stderr);\x0d\n        const msg = formatWithOptions({ colors }\x2C ...args);\x0d\n        const coloredPID = inspect(pid\x2C { colors });\x0d\n        process.stderr.write(format('%s %s: %s\\n'\x2C set\x2C coloredPID\x2C msg));\x0d\n      };\x0d\n    } else {\x0d\n      debugImpls[set] = noop;\x0d\n    }\x0d\n  }\x0d\n  return debugImpls[set];\x0d\n}\x0d\n\x0d\n// debuglogImpl depends on process.pid and process.env.NODE_DEBUG\x2C\x0d\n// so it needs to be called lazily in top scopes of internal modules\x0d\n// that may be loaded before these run time states are allowed to\x0d\n// be accessed.\x0d\nfunction debuglog(set\x2C cb) {\x0d\n  function init() {\x0d\n    set = StringPrototypeToUpperCase(set);\x0d\n    enabled = testEnabled(set);\x0d\n  }\x0d\n  let debug = (...args) => {\x0d\n    init();\x0d\n    // Only invokes debuglogImpl() when the debug function is\x0d\n    // called for the first time.\x0d\n    debug = debuglogImpl(enabled\x2C set);\x0d\n    if (typeof cb === 'function') {\x0d\n      ObjectDefineProperty(debug\x2C 'enabled'\x2C {\x0d\n        __proto__: null\x2C\x0d\n        get() {\x0d\n          return enabled;\x0d\n        }\x2C\x0d\n        configurable: true\x2C\x0d\n        enumerable: true\x2C\x0d\n      });\x0d\n      cb(debug);\x0d\n    }\x0d\n    switch (args.length) {\x0d\n      case 1: return debug(args[0]);\x0d\n      case 2: return debug(args[0]\x2C args[1]);\x0d\n      default: return debug(...new SafeArrayIterator(args));\x0d\n    }\x0d\n  };\x0d\n  let enabled;\x0d\n  let test = () => {\x0d\n    init();\x0d\n    test = () => enabled;\x0d\n    return enabled;\x0d\n  };\x0d\n  const logger = (...args) => {\x0d\n    // Improve performance when debug is disabled\x2C avoid calling `new SafeArrayIterator(args)`\x0d\n    if (enabled === false) return;\x0d\n    switch (args.length) {\x0d\n      case 1: return debug(args[0]);\x0d\n      case 2: return debug(args[0]\x2C args[1]);\x0d\n      default: return debug(...new SafeArrayIterator(args));\x0d\n    }\x0d\n  };\x0d\n  ObjectDefineProperty(logger\x2C 'enabled'\x2C {\x0d\n    __proto__: null\x2C\x0d\n    get() {\x0d\n      return test();\x0d\n    }\x2C\x0d\n    configurable: true\x2C\x0d\n    enumerable: true\x2C\x0d\n  });\x0d\n  return logger;\x0d\n}\x0d\n\x0d\nfunction pad(value) {\x0d\n  return StringPrototypePadStart(`${value}`\x2C 2\x2C '0');\x0d\n}\x0d\n\x0d\nconst kNone = 1 << 0;\x0d\nconst kSkipLog = 1 << 1;\x0d\nconst kSkipTrace = 1 << 2;\x0d\nconst kShouldSkipAll = kSkipLog | kSkipTrace;\x0d\n\x0d\nconst kSecond = 1000;\x0d\nconst kMinute = 60 * kSecond;\x0d\nconst kHour = 60 * kMinute;\x0d\n\x0d\nfunction formatTime(ms) {\x0d\n  let hours = 0;\x0d\n  let minutes = 0;\x0d\n  let seconds = 0;\x0d\n\x0d\n  if (ms >= kSecond) {\x0d\n    if (ms >= kMinute) {\x0d\n      if (ms >= kHour) {\x0d\n        hours = MathFloor(ms / kHour);\x0d\n        ms = ms % kHour;\x0d\n      }\x0d\n      minutes = MathFloor(ms / kMinute);\x0d\n      ms = ms % kMinute;\x0d\n    }\x0d\n    seconds = ms / kSecond;\x0d\n  }\x0d\n\x0d\n  if (hours !== 0 || minutes !== 0) {\x0d\n    ({ 0: seconds\x2C 1: ms } = StringPrototypeSplit(\x0d\n      NumberPrototypeToFixed(seconds\x2C 3)\x2C\x0d\n      '.'\x2C\x0d\n      2\x2C\x0d\n    ));\x0d\n    const res = hours !== 0 ? `${hours}:${pad(minutes)}` : minutes;\x0d\n    return `${res}:${pad(seconds)}.${ms} (${hours !== 0 ? 'h:m' : ''}m:ss.mmm)`;\x0d\n  }\x0d\n\x0d\n  if (seconds !== 0) {\x0d\n    return `${NumberPrototypeToFixed(seconds\x2C 3)}s`;\x0d\n  }\x0d\n\x0d\n  return `${Number(NumberPrototypeToFixed(ms\x2C 3))}ms`;\x0d\n}\x0d\n\x0d\nfunction safeTraceLabel(label) {\x0d\n  return label.replaceAll('\\\\'\x2C '\\\\\\\\').replaceAll('"'\x2C '\\\\"');\x0d\n}\x0d\n\x0d\n/**\x0d\n * @typedef {(label: string\x2C timeFormatted: string\x2C args?: any[]) => void} LogImpl\x0d\n */\x0d\n\x0d\n/**\x0d\n * Returns true if label was found\x0d\n * @param {string} timesStore\x0d\n * @param {string} implementation\x0d\n * @param {LogImpl} logImp\x0d\n * @param {string} label\x0d\n * @param {any} args\x0d\n * @returns {void}\x0d\n */\x0d\nfunction timeLogImpl(timesStore\x2C implementation\x2C logImp\x2C label\x2C args) {\x0d\n  const time = timesStore.get(label);\x0d\n  if (time === undefined) {\x0d\n    process.emitWarning(`No such label '${label}' for ${implementation}`);\x0d\n    return;\x0d\n  }\x0d\n\x0d\n  const duration = process.hrtime(time);\x0d\n  const ms = duration[0] * 1000 + duration[1] / 1e6;\x0d\n\x0d\n  const formatted = formatTime(ms);\x0d\n\x0d\n  if (args === undefined) {\x0d\n    logImp(label\x2C formatted);\x0d\n  } else {\x0d\n    logImp(label\x2C formatted\x2C args);\x0d\n  }\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {SafeMap} timesStore\x0d\n * @param {string} traceCategory\x0d\n * @param {string} implementation\x0d\n * @param {number} timerFlags\x0d\n * @param {string} logLabel\x0d\n * @param {string} traceLabel\x0d\n * @returns {void}\x0d\n */\x0d\nfunction time(timesStore\x2C traceCategory\x2C implementation\x2C timerFlags\x2C logLabel = 'default'\x2C traceLabel = undefined) {\x0d\n  // Coerces everything other than Symbol to a string\x0d\n  logLabel = `${logLabel}`;\x0d\n\x0d\n  if (traceLabel !== undefined) {\x0d\n    traceLabel = `${traceLabel}`;\x0d\n  } else {\x0d\n    traceLabel = logLabel;\x0d\n  }\x0d\n\x0d\n  if (timesStore.has(logLabel)) {\x0d\n    process.emitWarning(`Label '${logLabel}' already exists for ${implementation}`);\x0d\n    return;\x0d\n  }\x0d\n\x0d\n  if ((timerFlags & kSkipTrace) === 0) {\x0d\n    traceLabel = safeTraceLabel(traceLabel);\x0d\n    trace(kTraceBegin\x2C traceCategory\x2C traceLabel\x2C 0);\x0d\n  }\x0d\n\x0d\n  timesStore.set(logLabel\x2C process.hrtime());\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {SafeMap} timesStore\x0d\n * @param {string} traceCategory\x0d\n * @param {string} implementation\x0d\n * @param {number} timerFlags\x0d\n * @param {LogImpl} logImpl\x0d\n * @param {string} logLabel\x0d\n * @param {string} traceLabel\x0d\n * @returns {void}\x0d\n */\x0d\nfunction timeEnd(\x0d\n  timesStore\x2C\x0d\n  traceCategory\x2C\x0d\n  implementation\x2C\x0d\n  timerFlags\x2C\x0d\n  logImpl\x2C\x0d\n  logLabel = 'default'\x2C\x0d\n  traceLabel = undefined\x2C\x0d\n) {\x0d\n  // Coerces everything other than Symbol to a string\x0d\n  logLabel = `${logLabel}`;\x0d\n\x0d\n  if (traceLabel !== undefined) {\x0d\n    traceLabel = `${traceLabel}`;\x0d\n  } else {\x0d\n    traceLabel = logLabel;\x0d\n  }\x0d\n\x0d\n  if ((timerFlags & kSkipLog) === 0) {\x0d\n    timeLogImpl(timesStore\x2C implementation\x2C logImpl\x2C logLabel);\x0d\n  }\x0d\n\x0d\n  if ((timerFlags & kSkipTrace) === 0) {\x0d\n    traceLabel = safeTraceLabel(traceLabel);\x0d\n    trace(kTraceEnd\x2C traceCategory\x2C traceLabel\x2C 0);\x0d\n  }\x0d\n\x0d\n  timesStore.delete(logLabel);\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {SafeMap} timesStore\x0d\n * @param {string} traceCategory\x0d\n * @param {string} implementation\x0d\n * @param {number} timerFlags\x0d\n * @param {LogImpl} logImpl\x0d\n * @param {string} logLabel\x0d\n * @param {string} traceLabel\x0d\n * @param {any[]} args\x0d\n * @returns {void}\x0d\n */\x0d\nfunction timeLog(\x0d\n  timesStore\x2C\x0d\n  traceCategory\x2C\x0d\n  implementation\x2C\x0d\n  timerFlags\x2C\x0d\n  logImpl\x2C\x0d\n  logLabel = 'default'\x2C\x0d\n  traceLabel = undefined\x2C\x0d\n  args\x2C\x0d\n) {\x0d\n  // Coerces everything other than Symbol to a string\x0d\n  logLabel = `${logLabel}`;\x0d\n\x0d\n  if (traceLabel !== undefined) {\x0d\n    traceLabel = `${traceLabel}`;\x0d\n  } else {\x0d\n    traceLabel = logLabel;\x0d\n  }\x0d\n\x0d\n  if ((timerFlags & kSkipLog) === 0) {\x0d\n    timeLogImpl(timesStore\x2C implementation\x2C logImpl\x2C logLabel\x2C args);\x0d\n  }\x0d\n\x0d\n  if ((timerFlags & kSkipTrace) === 0) {\x0d\n    traceLabel = safeTraceLabel(traceLabel);\x0d\n    trace(kTraceInstant\x2C traceCategory\x2C traceLabel\x2C 0);\x0d\n  }\x0d\n}\x0d\n\x0d\n/**\x0d\n * @type {Record<string\x2C SafeMap>}\x0d\n */\x0d\nlet tracesStores;\x0d\n\x0d\n/**\x0d\n * @typedef {(logLabel: string\x2C traceLabel?: string) => void} TimerStart\x0d\n */\x0d\n\x0d\n/**\x0d\n * @typedef {(logLabel: string\x2C traceLabel?: string) => void} TimerEnd\x0d\n */\x0d\n\x0d\n/**\x0d\n * @typedef {(logLabel: string\x2C traceLabel?: string\x2C args?: any[]) => void} TimerLog\x0d\n */\x0d\n\x0d\n/**\x0d\n * Debuglog with time fns and support for trace\x0d\n * @param {string} set\x0d\n * @param {(startTimer: TimerStart\x2C endTimer: TimerEnd\x2C logTimer: TimerLog) => void} cb\x0d\n * @returns {{startTimer: TimerStart\x2C endTimer: TimerEnd\x2C logTimer: TimerLog}}\x0d\n */\x0d\nfunction debugWithTimer(set\x2C cb) {\x0d\n  set = StringPrototypeToUpperCase(set);\x0d\n\x0d\n  if (tracesStores === undefined) {\x0d\n    tracesStores = { __proto__: null };\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @type {LogImpl}\x0d\n   */\x0d\n  function logImpl(label\x2C timeFormatted\x2C args) {\x0d\n    const pid = process.pid;\x0d\n    const colors = { colors: lazyUtilColors().shouldColorize(process.stderr) };\x0d\n    const coloredPID = inspect(pid\x2C colors);\x0d\n\x0d\n    if (args === undefined)\x0d\n      process.stderr.write(format('%s %s %s: %s\\n'\x2C set\x2C coloredPID\x2C label\x2C timeFormatted));\x0d\n    else\x0d\n      process.stderr.write(\x0d\n        format(\x0d\n          '%s %s %s: %s\\n'\x2C\x0d\n          set\x2C\x0d\n          coloredPID\x2C\x0d\n          label\x2C\x0d\n          timeFormatted\x2C\x0d\n          ...new SafeArrayIterator(args)\x2C\x0d\n        )\x2C\x0d\n      );\x0d\n  }\x0d\n\x0d\n  const traceCategory = `node\x2Cnode.${StringPrototypeToLowerCase(set)}`;\x0d\n  let traceCategoryBuffer;\x0d\n  let debugLogCategoryEnabled = false;\x0d\n  let timerFlags = kNone;\x0d\n\x0d\n  function ensureTimerFlagsAreUpdated() {\x0d\n    timerFlags &= ~kSkipTrace;\x0d\n\x0d\n    if (traceCategoryBuffer[0] === 0) {\x0d\n      timerFlags |= kSkipTrace;\x0d\n    }\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @type {TimerStart}\x0d\n   */\x0d\n  function internalStartTimer(logLabel\x2C traceLabel) {\x0d\n    ensureTimerFlagsAreUpdated();\x0d\n\x0d\n    if ((timerFlags & kShouldSkipAll) === kShouldSkipAll) {\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    time(\x0d\n      tracesStores[set]\x2C\x0d\n      traceCategory\x2C\x0d\n      'debuglog.time'\x2C\x0d\n      timerFlags\x2C\x0d\n      logLabel\x2C\x0d\n      traceLabel\x2C\x0d\n    );\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @type {TimerEnd}\x0d\n   */\x0d\n  function internalEndTimer(logLabel\x2C traceLabel) {\x0d\n    ensureTimerFlagsAreUpdated();\x0d\n\x0d\n    if ((timerFlags & kShouldSkipAll) === kShouldSkipAll) {\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    timeEnd(\x0d\n      tracesStores[set]\x2C\x0d\n      traceCategory\x2C\x0d\n      'debuglog.timeEnd'\x2C\x0d\n      timerFlags\x2C\x0d\n      logImpl\x2C\x0d\n      logLabel\x2C\x0d\n      traceLabel\x2C\x0d\n    );\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @type {TimerLog}\x0d\n   */\x0d\n  function internalLogTimer(logLabel\x2C traceLabel\x2C args) {\x0d\n    ensureTimerFlagsAreUpdated();\x0d\n\x0d\n    if ((timerFlags & kShouldSkipAll) === kShouldSkipAll) {\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    timeLog(\x0d\n      tracesStores[set]\x2C\x0d\n      traceCategory\x2C\x0d\n      'debuglog.timeLog'\x2C\x0d\n      timerFlags\x2C\x0d\n      logImpl\x2C\x0d\n      logLabel\x2C\x0d\n      traceLabel\x2C\x0d\n      args\x2C\x0d\n    );\x0d\n  }\x0d\n\x0d\n  function init() {\x0d\n    if (tracesStores[set] === undefined) {\x0d\n      tracesStores[set] = new SafeMap();\x0d\n    }\x0d\n    emitWarningIfNeeded(set);\x0d\n    debugLogCategoryEnabled = testEnabled(set);\x0d\n    traceCategoryBuffer = getCategoryEnabledBuffer(traceCategory);\x0d\n\x0d\n    timerFlags = kNone;\x0d\n\x0d\n    if (!debugLogCategoryEnabled) {\x0d\n      timerFlags |= kSkipLog;\x0d\n    }\x0d\n\x0d\n    if (traceCategoryBuffer[0] === 0) {\x0d\n      timerFlags |= kSkipTrace;\x0d\n    }\x0d\n\x0d\n    cb(internalStartTimer\x2C internalEndTimer\x2C internalLogTimer);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @type {TimerStart}\x0d\n   */\x0d\n  const startTimer = (logLabel\x2C traceLabel) => {\x0d\n    init();\x0d\n\x0d\n    if ((timerFlags & kShouldSkipAll) !== kShouldSkipAll)\x0d\n      internalStartTimer(logLabel\x2C traceLabel);\x0d\n  };\x0d\n\x0d\n  /**\x0d\n   * @type {TimerEnd}\x0d\n   */\x0d\n  const endTimer = (logLabel\x2C traceLabel) => {\x0d\n    init();\x0d\n\x0d\n    if ((timerFlags & kShouldSkipAll) !== kShouldSkipAll)\x0d\n      internalEndTimer(logLabel\x2C traceLabel);\x0d\n  };\x0d\n\x0d\n  /**\x0d\n   * @type {TimerLog}\x0d\n   */\x0d\n  const logTimer = (logLabel\x2C traceLabel\x2C args) => {\x0d\n    init();\x0d\n\x0d\n    if ((timerFlags & kShouldSkipAll) !== kShouldSkipAll)\x0d\n      internalLogTimer(logLabel\x2C traceLabel\x2C args);\x0d\n  };\x0d\n\x0d\n  return {\x0d\n    startTimer\x2C\x0d\n    endTimer\x2C\x0d\n    logTimer\x2C\x0d\n  };\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  kNone\x2C\x0d\n  kSkipLog\x2C\x0d\n  kSkipTrace\x2C\x0d\n  formatTime\x2C\x0d\n  time\x2C\x0d\n  timeEnd\x2C\x0d\n  timeLog\x2C\x0d\n  debuglog\x2C\x0d\n  debugWithTimer\x2C\x0d\n  initializeDebugEnv\x2C\x0d\n};\x0d\n

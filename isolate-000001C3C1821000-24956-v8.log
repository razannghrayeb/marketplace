adzone (TDZ).\x0d\n    const { exports } = new WebAssembly.Instance(compiled\x2C reflect.imports);\x0d\n    wasmInstances.set(module.getNamespace()\x2C exports);\x0d\n    for (const expt of exportsList) {\x0d\n      let val = exports[expt];\x0d\n      // Unwrap WebAssembly.Global for JS bindings\x0d\n      if (wasmGlobalExports.has(expt)) {\x0d\n        try {\x0d\n          // v128 will throw in GetGlobalValue\x2C see:\x0d\n          // https://webassembly.github.io/esm-integration/js-api/index.html#getglobalvalue\x0d\n          val = val.value;\x0d\n        } catch {\x0d\n          // v128 doesn't support ToJsValue() -> use undefined (ideally should stay in TDZ)\x0d\n          continue;\x0d\n        }\x0d\n      }\x0d\n      reflect.exports[expt].set(val);\x0d\n    }\x0d\n  });\x0d\n  // WebAssembly modules support source phase imports\x2C to import the compiled module\x0d\n  // separate from the linked instance.\x0d\n  module.setModuleSourceObject(compiled);\x0d\n  return module;\x0d\n});\x0d\n\x0d\n// Strategy for loading a addon\x0d\ntranslators.set('addon'\x2C function translateAddon(url\x2C translateContext\x2C parentURL) {\x0d\n  emitExperimentalWarning('Importing addons');\x0d\n\x0d\n  const { source } = translateContext;\x0d\n  // The addon must be loaded from file system with dlopen. Assert\x0d\n  // the source is null.\x0d\n  if (source !== null) {\x0d\n    throw new ERR_INVALID_RETURN_PROPERTY_VALUE(\x0d\n      'null'\x2C\x0d\n      'load'\x2C\x0d\n      'source'\x2C\x0d\n      source);\x0d\n  }\x0d\n\x0d\n  debug(`Translating addon ${url}`\x2C translateContext);\x0d\n\x0d\n  return createCJSNoSourceModuleWrap(url\x2C parentURL);\x0d\n});\x0d\n\x0d\n// Strategy for loading a commonjs TypeScript module\x0d\ntranslators.set('commonjs-typescript'\x2C function(url\x2C translateContext\x2C parentURL) {\x0d\n  const { source } = translateContext;\x0d\n  assertBufferSource(source\x2C true\x2C 'load');\x0d\n  debug(`Translating TypeScript ${url}`\x2C translateCo
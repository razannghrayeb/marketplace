script-source,14,node:internal/options,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayPrototypeMap\x2C\x0d\n  ArrayPrototypeSort\x2C\x0d\n  ObjectFromEntries\x2C\x0d\n  ObjectKeys\x2C\x0d\n  StringPrototypeReplace\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  getCLIOptionsValues\x2C\x0d\n  getCLIOptionsInfo\x2C\x0d\n  getOptionsAsFlags\x2C\x0d\n  getEmbedderOptions: getEmbedderOptionsFromBinding\x2C\x0d\n  getEnvOptionsInputType\x2C\x0d\n  getNamespaceOptionsInputType\x2C\x0d\n} = internalBinding('options');\x0d\n\x0d\nlet warnOnAllowUnauthorized = true;\x0d\n\x0d\nlet optionsDict;\x0d\nlet cliInfo;\x0d\nlet embedderOptions;\x0d\nlet optionsFlags;\x0d\n\x0d\n// getCLIOptionsValues() would serialize the option values from C++ land.\x0d\n// It would error if the values are queried before bootstrap is\x0d\n// complete so that we don't accidentally include runtime-dependent\x0d\n// states into a runtime-independent snapshot.\x0d\nfunction getCLIOptionsFromBinding() {\x0d\n  return optionsDict ??= getCLIOptionsValues();\x0d\n}\x0d\n\x0d\nfunction getCLIOptionsInfoFromBinding() {\x0d\n  return cliInfo ??= getCLIOptionsInfo();\x0d\n}\x0d\n\x0d\nfunction getOptionsAsFlagsFromBinding() {\x0d\n  return optionsFlags ??= getOptionsAsFlags();\x0d\n}\x0d\n\x0d\nfunction getEmbedderOptions() {\x0d\n  return embedderOptions ??= getEmbedderOptionsFromBinding();\x0d\n}\x0d\n\x0d\nfunction generateConfigJsonSchema() {\x0d\n  const envOptionsMap = getEnvOptionsInputType();\x0d\n  const namespaceOptionsMap = getNamespaceOptionsInputType();\x0d\n\x0d\n  function createPropertyForType(type) {\x0d\n    if (type === 'array') {\x0d\n      return {\x0d\n        __proto__: null\x2C\x0d\n        oneOf: [\x0d\n          { __proto__: null\x2C type: 'string' }\x2C\x0d\n          { __proto__: null\x2C items: { __proto__: null\x2C type: 'string'\x2C minItems: 1 }\x2C type: 'array' }\x2C\x0d\n        ]\x2C\x0d\n      };\x0d\n    }\x0d\n\x0d\n    return { __proto__: null\x2C type };\x0d\n  }\x0d\n\x0d\n  const schema = {\x0d\n    __proto__: null\x2C\x0d\n    $schema: 'https://json-schema.org/draft/2020-12/schema'\x2C\x0d\n    additionalProperties: false\x2C\x0d\n    properties: {\x0d\n      $schema: {\x0d\n        __proto__: null\x2C\x0d\n        type: 'string'\x2C\x0d\n      }\x2C\x0d\n      nodeOptions: {\x0d\n        __proto__: null\x2C\x0d\n        additionalProperties: false\x2C\x0d\n        properties: { __proto__: null }\x2C\x0d\n        type: 'object'\x2C\x0d\n      }\x2C\x0d\n      __proto__: null\x2C\x0d\n    }\x2C\x0d\n    type: 'object'\x2C\x0d\n  };\x0d\n\x0d\n  // Get the root properties object for adding namespaces\x0d\n  const rootProperties = schema.properties;\x0d\n  const nodeOptions = rootProperties.nodeOptions.properties;\x0d\n\x0d\n  // Add env options to nodeOptions (backward compatibility)\x0d\n  for (const { 0: key\x2C 1: type } of envOptionsMap) {\x0d\n    const keyWithoutPrefix = StringPrototypeReplace(key\x2C '--'\x2C '');\x0d\n    nodeOptions[keyWithoutPrefix] = createPropertyForType(type);\x0d\n  }\x0d\n\x0d\n  // Add namespace properties at the root level\x0d\n  for (const { 0: namespace\x2C 1: optionsMap } of namespaceOptionsMap) {\x0d\n    // Create namespace object at the root level\x0d\n    rootProperties[namespace] = {\x0d\n      __proto__: null\x2C\x0d\n      type: 'object'\x2C\x0d\n      additionalProperties: false\x2C\x0d\n      properties: { __proto__: null }\x2C\x0d\n    };\x0d\n\x0d\n    const namespaceProperties = rootProperties[namespace].properties;\x0d\n\x0d\n    // Add all options for this namespace\x0d\n    for (const { 0: optionName\x2C 1: optionType } of optionsMap) {\x0d\n      const keyWithoutPrefix = StringPrototypeReplace(optionName\x2C '--'\x2C '');\x0d\n      namespaceProperties[keyWithoutPrefix] = createPropertyForType(optionType);\x0d\n    }\x0d\n\x0d\n    // Sort the namespace properties alphabetically\x0d\n    const sortedNamespaceKeys = ArrayPrototypeSort(ObjectKeys(namespaceProperties));\x0d\n    const sortedNamespaceProperties = ObjectFromEntries(\x0d\n      ArrayPrototypeMap(sortedNamespaceKeys\x2C (key) => [key\x2C namespaceProperties[key]])\x2C\x0d\n    );\x0d\n    rootProperties[namespace].properties = sortedNamespaceProperties;\x0d\n  }\x0d\n\x0d\n  // Sort the top-level properties by key alphabetically\x0d\n  const sortedKeys = ArrayPrototypeSort(ObjectKeys(nodeOptions));\x0d\n  const sortedProperties = ObjectFromEntries(\x0d\n    ArrayPrototypeMap(sortedKeys\x2C (key) => [key\x2C nodeOptions[key]])\x2C\x0d\n  );\x0d\n\x0d\n  schema.properties.nodeOptions.properties = sortedProperties;\x0d\n\x0d\n  // Also sort the root level properties\x0d\n  const sortedRootKeys = ArrayPrototypeSort(ObjectKeys(rootProperties));\x0d\n  const sortedRootProperties = ObjectFromEntries(\x0d\n    ArrayPrototypeMap(sortedRootKeys\x2C (key) => [key\x2C rootProperties[key]])\x2C\x0d\n  );\x0d\n\x0d\n  schema.properties = sortedRootProperties;\x0d\n\x0d\n  return schema;\x0d\n}\x0d\n\x0d\nfunction refreshOptions() {\x0d\n  optionsDict = undefined;\x0d\n}\x0d\n\x0d\nfunction getOptionValue(optionName) {\x0d\n  return getCLIOptionsFromBinding()[optionName];\x0d\n}\x0d\n\x0d\nfunction getAllowUnauthorized() {\x0d\n  const allowUnauthorized = process.env.NODE_TLS_REJECT_UNAUTHORIZED === '0';\x0d\n\x0d\n  if (allowUnauthorized && warnOnAllowUnauthorized) {\x0d\n    warnOnAllowUnauthorized = false;\x0d\n    process.emitWarning(\x0d\n      'Setting the NODE_TLS_REJECT_UNAUTHORIZED ' +\x0d\n      'environment variable to \\'0\\' makes TLS connections ' +\x0d\n      'and HTTPS requests insecure by disabling ' +\x0d\n      'certificate verification.');\x0d\n  }\x0d\n  return allowUnauthorized;\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  getCLIOptionsInfo: getCLIOptionsInfoFromBinding\x2C\x0d\n  getOptionValue\x2C\x0d\n  getOptionsAsFlagsFromBinding\x2C\x0d\n  getAllowUnauthorized\x2C\x0d\n  getEmbedderOptions\x2C\x0d\n  generateConfigJsonSchema\x2C\x0d\n  refreshOptions\x2C\x0d\n};\x0d\n

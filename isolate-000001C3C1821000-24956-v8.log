script-source,88,node:internal/modules/esm/module_job,'use strict';\x0d\n\x0d\nconst {\x0d\n  Array\x2C\x0d\n  ArrayPrototypeFind\x2C\x0d\n  ArrayPrototypeJoin\x2C\x0d\n  ArrayPrototypePush\x2C\x0d\n  FunctionPrototype\x2C\x0d\n  ObjectSetPrototypeOf\x2C\x0d\n  PromisePrototypeThen\x2C\x0d\n  PromiseResolve\x2C\x0d\n  RegExpPrototypeExec\x2C\x0d\n  RegExpPrototypeSymbolReplace\x2C\x0d\n  SafePromiseAllReturnArrayLike\x2C\x0d\n  SafePromiseAllReturnVoid\x2C\x0d\n  SafeSet\x2C\x0d\n  StringPrototypeIncludes\x2C\x0d\n  StringPrototypeSplit\x2C\x0d\n  StringPrototypeStartsWith\x2C\x0d\n  globalThis\x2C\x0d\n} = primordials;\x0d\nlet debug = require('internal/util/debuglog').debuglog('esm'\x2C (fn) => {\x0d\n  debug = fn;\x0d\n});\x0d\n\x0d\nconst {\x0d\n  ModuleWrap\x2C\x0d\n  kErrored\x2C\x0d\n  kEvaluated\x2C\x0d\n  kEvaluating\x2C\x0d\n  kEvaluationPhase\x2C\x0d\n  kInstantiated\x2C\x0d\n  kUninstantiated\x2C\x0d\n} = internalBinding('module_wrap');\x0d\nconst {\x0d\n  privateSymbols: {\x0d\n    entry_point_module_private_symbol\x2C\x0d\n  }\x2C\x0d\n} = internalBinding('util');\x0d\n/**\x0d\n * @typedef {import('./utils.js').ModuleRequestType} ModuleRequestType\x0d\n */\x0d\nconst { decorateErrorStack } = require('internal/util');\x0d\nconst { isPromise } = require('internal/util/types');\x0d\nconst {\x0d\n  getSourceMapsSupport\x2C\x0d\n} = require('internal/source_map/source_map_cache');\x0d\nconst assert = require('internal/assert');\x0d\nconst resolvedPromise = PromiseResolve();\x0d\nconst {\x0d\n  setHasStartedUserESMExecution\x2C\x0d\n  urlToFilename\x2C\x0d\n} = require('internal/modules/helpers');\x0d\nconst { getOptionValue } = require('internal/options');\x0d\nconst noop = FunctionPrototype;\x0d\nconst {\x0d\n  ERR_REQUIRE_ASYNC_MODULE\x2C\x0d\n} = require('internal/errors').codes;\x0d\nlet hasPausedEntry = false;\x0d\n\x0d\nconst CJSGlobalLike = [\x0d\n  'require'\x2C\x0d\n  'module'\x2C\x0d\n  'exports'\x2C\x0d\n  '__filename'\x2C\x0d\n  '__dirname'\x2C\x0d\n];\x0d\nconst findCommonJSGlobalLikeNotDefinedError = (errorMessage) =>\x0d\n  ArrayPrototypeFind(\x0d\n    CJSGlobalLike\x2C\x0d\n    (globalLike) => errorMessage === `${globalLike} is not defined`\x2C\x0d\n  );\x0d\n\x0d\n\x0d\n/**\x0d\n *\x0d\n * @param {Error} e\x0d\n * @param {string} url\x0d\n * @returns {void}\x0d\n */\x0d\nconst explainCommonJSGlobalLikeNotDefinedError = (e\x2C url\x2C hasTopLevelAwait) => {\x0d\n  const notDefinedGlobalLike = e?.name === 'ReferenceError' && findCommonJSGlobalLikeNotDefinedError(e.message);\x0d\n\x0d\n  if (notDefinedGlobalLike) {\x0d\n    if (hasTopLevelAwait) {\x0d\n      let advice;\x0d\n      switch (notDefinedGlobalLike) {\x0d\n        case 'require':\x0d\n          advice = 'replace require() with import';\x0d\n          break;\x0d\n        case 'module':\x0d\n        case 'exports':\x0d\n          advice = 'use export instead of module.exports/exports';\x0d\n          break;\x0d\n        case '__filename':\x0d\n          advice = 'use import.meta.filename instead';\x0d\n          break;\x0d\n        case '__dirname':\x0d\n          advice = 'use import.meta.dirname instead';\x0d\n          break;\x0d\n      }\x0d\n\x0d\n      e.message = `Cannot determine intended module format because both '${notDefinedGlobalLike}' and top-level await are present. If the code is intended to be CommonJS\x2C wrap await in an async function. If the code is intended to be an ES module\x2C ${advice}.`;\x0d\n      e.code = 'ERR_AMBIGUOUS_MODULE_SYNTAX';\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    e.message += ' in ES module scope';\x0d\n\x0d\n    if (StringPrototypeStartsWith(e.message\x2C 'require ')) {\x0d\n      e.message += '\x2C you can use import instead';\x0d\n    }\x0d\n\x0d\n    const packageConfig =\x0d\n      StringPrototypeStartsWith(url\x2C 'file://') &&\x0d\n        RegExpPrototypeExec(/\\.js(\\?[^#]*)?(#.*)?$/\x2C url) !== null &&\x0d\n        require('internal/modules/package_json_reader')\x0d\n          .getPackageScopeConfig(url);\x0d\n    if (packageConfig.type === 'module') {\x0d\n      e.message +=\x0d\n        '\\nThis file is being treated as an ES module because it has a ' +\x0d\n        `'.js' file extension and '${packageConfig.pjsonPath}' contains ` +\x0d\n        '"type": "module". To treat it as a CommonJS script\x2C rename it ' +\x0d\n        'to use the \\'.cjs\\' file extension.';\x0d\n    }\x0d\n  }\x0d\n};\x0d\n\x0d\nclass ModuleJobBase {\x0d\n  constructor(loader\x2C url\x2C importAttributes\x2C phase\x2C isMain\x2C inspectBrk) {\x0d\n    assert(typeof phase === 'number');\x0d\n    this.loader = loader;\x0d\n    this.importAttributes = importAttributes;\x0d\n    this.phase = phase;\x0d\n    this.isMain = isMain;\x0d\n    this.inspectBrk = inspectBrk;\x0d\n\x0d\n    this.url = url;\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Synchronously link the module and its dependencies.\x0d\n   * @param {ModuleRequestType} requestType Type of the module request.\x0d\n   * @returns {ModuleJobBase[]}\x0d\n   */\x0d\n  syncLink(requestType) {\x0d\n    // Store itself into the cache first before linking in case there are circular\x0d\n    // references in the linking.\x0d\n    this.loader.loadCache.set(this.url\x2C this.type\x2C this);\x0d\n    const moduleRequests = this.module.getModuleRequests();\x0d\n    // Modules should be aligned with the moduleRequests array in order.\x0d\n    const modules = Array(moduleRequests.length);\x0d\n    const evaluationDepJobs = [];\x0d\n    this.commonJsDeps = Array(moduleRequests.length);\x0d\n    try {\x0d\n      for (let idx = 0; idx < moduleRequests.length; idx++) {\x0d\n        const request = moduleRequests[idx];\x0d\n        // TODO(joyeecheung): split this into two iterators\x2C one for resolving and one for loading so\x0d\n        // that hooks can pre-fetch sources off-thread.\x0d\n        const job = this.loader.getOrCreateModuleJob(this.url\x2C request\x2C requestType);\x0d\n        debug(`ModuleJobBase.syncLink() ${this.url} -> ${request.specifier}`\x2C job);\x0d\n        assert(!isPromise(job));\x0d\n        assert(job.module instanceof ModuleWrap);\x0d\n        if (request.phase === kEvaluationPhase) {\x0d\n          ArrayPrototypePush(evaluationDepJobs\x2C job);\x0d\n        }\x0d\n        modules[idx] = job.module;\x0d\n        this.commonJsDeps[idx] = job.module.isCommonJS;\x0d\n      }\x0d\n      this.module.link(modules);\x0d\n    } finally {\x0d\n      // Restore it - if it succeeds\x2C we'll reset in the caller; Otherwise it's\x0d\n      // not cached and if the error is caught\x2C subsequent attempt would still fail.\x0d\n      this.loader.loadCache.delete(this.url\x2C this.type);\x0d\n    }\x0d\n\x0d\n    return evaluationDepJobs;\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Ensure that this ModuleJob is moving towards the required phase\x0d\n   * (does not necessarily mean it is ready at that phase - run does that)\x0d\n   * @param {number} phase\x0d\n   */\x0d\n  ensurePhase(phase\x2C requestType) {\x0d\n    if (this.phase < phase) {\x0d\n      this.phase = phase;\x0d\n      this.linked = this.link(requestType);\x0d\n      if (isPromise(this.linked)) {\x0d\n        PromisePrototypeThen(this.linked\x2C undefined\x2C noop);\x0d\n      }\x0d\n    }\x0d\n  }\x0d\n}\x0d\n\x0d\n/* A ModuleJob tracks the loading of a single Module\x2C and the ModuleJobs of\x0d\n * its dependencies\x2C over time. */\x0d\nclass ModuleJob extends ModuleJobBase {\x0d\n  /**\x0d\n   * @param {ModuleLoader} loader The ESM loader.\x0d\n   * @param {string} url URL of the module to be wrapped in ModuleJob.\x0d\n   * @param {ImportAttributes} importAttributes Import attributes from the import statement.\x0d\n   * @param {ModuleWrap|Promise<ModuleWrap>} moduleOrModulePromise Translated ModuleWrap for the module.\x0d\n   * @param {number} phase The phase to load the module to.\x0d\n   * @param {boolean} isMain Whether the module is the entry point.\x0d\n   * @param {boolean} inspectBrk Whether this module should be evaluated with the\x0d\n   *   first line paused in the debugger (because --inspect-brk is passed).\x0d\n   * @param {ModuleRequestType} requestType Type of the module request.\x0d\n   */\x0d\n  constructor(loader\x2C url\x2C importAttributes = { __proto__: null }\x2C moduleOrModulePromise\x2C\x0d\n              phase = kEvaluationPhase\x2C isMain\x2C inspectBrk\x2C requestType) {\x0d\n    super(loader\x2C url\x2C importAttributes\x2C phase\x2C isMain\x2C inspectBrk);\x0d\n\x0d\n    // Expose the promise to the ModuleWrap directly for linking below.\x0d\n    if (isPromise(moduleOrModulePromise)) {\x0d\n      this.modulePromise = moduleOrModulePromise;\x0d\n    } else {\x0d\n      this.module = moduleOrModulePromise;\x0d\n      this.modulePromise = PromiseResolve(moduleOrModulePromise);\x0d\n    }\x0d\n\x0d\n    if (this.phase === kEvaluationPhase) {\x0d\n      // Promise for the list of all dependencyJobs.\x0d\n      this.linked = this.link(requestType);\x0d\n      // This promise is awaited later anyway\x2C so silence\x0d\n      // 'unhandled rejection' warnings.\x0d\n      if (isPromise(this.linked)) {\x0d\n        PromisePrototypeThen(this.linked\x2C undefined\x2C noop);\x0d\n      }\x0d\n    }\x0d\n\x0d\n    // instantiated == deep dependency jobs wrappers are instantiated\x2C\x0d\n    // and module wrapper is instantiated.\x0d\n    this.instantiated = undefined;\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @param {ModuleRequestType} requestType Type of the module request.\x0d\n   * @returns {ModuleJobBase[]|Promise<ModuleJobBase[]>}\x0d\n   */\x0d\n  link(requestType) {\x0d\n    if (this.loader.isForAsyncLoaderHookWorker) {\x0d\n      return this.#asyncLink(requestType);\x0d\n    }\x0d\n    return this.syncLink(requestType);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @param {ModuleRequestType} requestType Type of the module request.\x0d\n   * @returns {Promise<ModuleJobBase[]>}\x0d\n   */\x0d\n  async #asyncLink(requestType) {\x0d\n    assert(this.loader.isForAsyncLoaderHookWorker);\x0d\n    this.module = await this.modulePromise;\x0d\n    assert(this.module instanceof ModuleWrap);\x0d\n    const moduleRequests = this.module.getModuleRequests();\x0d\n    // Create an ArrayLike to avoid calling into userspace with `.then`\x0d\n    // when returned from the async function.\x0d\n    // Modules should be aligned with the moduleRequests array in order.\x0d\n    const modulePromises = Array(moduleRequests.length);\x0d\n    const evaluationDepJobs = [];\x0d\n    this.commonJsDeps = Array(moduleRequests.length);\x0d\n    for (let idx = 0; idx < moduleRequests.length; idx++) {\x0d\n      const request = moduleRequests[idx];\x0d\n      // Explicitly keeping track of dependency jobs is needed in order\x0d\n      // to flatten out the dependency graph below in `asyncInstantiate()`\x2C\x0d\n      // so that circular dependencies can't cause a deadlock by two of\x0d\n      // these `link` callbacks depending on each other.\x0d\n      // TODO(joyeecheung): split this into two iterators\x2C one for resolving and one for loading so\x0d\n      // that hooks can pre-fetch sources off-thread.\x0d\n      const dependencyJobPromise = this.loader.getOrCreateModuleJob(this.url\x2C request\x2C requestType);\x0d\n      const modulePromise = PromisePrototypeThen(dependencyJobPromise\x2C (job) => {\x0d\n        debug(`ModuleJob.asyncLink() ${this.url} -> ${request.specifier}`\x2C job);\x0d\n        if (request.phase === kEvaluationPhase) {\x0d\n          ArrayPrototypePush(evaluationDepJobs\x2C job);\x0d\n        }\x0d\n        return job.modulePromise;\x0d\n      });\x0d\n      modulePromises[idx] = modulePromise;\x0d\n    }\x0d\n    const modules = await SafePromiseAllReturnArrayLike(modulePromises);\x0d\n    for (let idx = 0; idx < moduleRequests.length; idx++) {\x0d\n      this.commonJsDeps[idx] = modules[idx].isCommonJS;\x0d\n    }\x0d\n\x0d\n    this.module.link(modules);\x0d\n    return evaluationDepJobs;\x0d\n  }\x0d\n\x0d\n  #instantiate() {\x0d\n    if (this.instantiated === undefined) {\x0d\n      this.instantiated = this.#asyncInstantiate();\x0d\n    }\x0d\n    return this.instantiated;\x0d\n  }\x0d\n\x0d\n  async #asyncInstantiate() {\x0d\n    const jobsInGraph = new SafeSet();\x0d\n    // TODO(joyeecheung): if it's not on the async loader thread\x2C consider this already\x0d\n    // linked.\x0d\n    const addJobsToDependencyGraph = async (moduleJob) => {\x0d\n      debug(`async addJobsToDependencyGraph() ${this.url}`\x2C moduleJob);\x0d\n\x0d\n      if (jobsInGraph.has(moduleJob)) {\x0d\n        return;\x0d\n      }\x0d\n      jobsInGraph.add(moduleJob);\x0d\n      const dependencyJobs = isPromise(moduleJob.linked) ? await moduleJob.linked : moduleJob.linked;\x0d\n      return SafePromiseAllReturnVoid(dependencyJobs\x2C addJobsToDependencyGraph);\x0d\n    };\x0d\n    await addJobsToDependencyGraph(this);\x0d\n\x0d\n    try {\x0d\n      if (!hasPausedEntry && this.inspectBrk) {\x0d\n        hasPausedEntry = true;\x0d\n        const initWrapper = internalBinding('inspector').callAndPauseOnStart;\x0d\n        initWrapper(this.module.instantiate\x2C this.module);\x0d\n      } else {\x0d\n        this.module.instantiate();\x0d\n      }\x0d\n    } catch (e) {\x0d\n      decorateErrorStack(e);\x0d\n      // TODO(@bcoe): Add source map support to exception that occurs as result\x0d\n      // of missing named export. This is currently not possible because\x0d\n      // stack trace originates in module_job\x2C not the file itself. A hidden\x0d\n      // symbol with filename could be set in node_errors.cc to facilitate this.\x0d\n      if (!getSourceMapsSupport().enabled &&\x0d\n          StringPrototypeIncludes(e.message\x2C\x0d\n                                  ' does not provide an export named')) {\x0d\n        const splitStack = StringPrototypeSplit(e.stack\x2C '\\n'\x2C 2);\x0d\n        const { 1: childSpecifier\x2C 2: name } = RegExpPrototypeExec(\x0d\n          /module '(.*)' does not provide an export named '(.+)'/\x2C\x0d\n          e.message);\x0d\n        const moduleRequests = this.module.getModuleRequests();\x0d\n        let isCommonJS = false;\x0d\n        for (let i = 0; i < moduleRequests.length; ++i) {\x0d\n          if (moduleRequests[i].specifier === childSpecifier) {\x0d\n            isCommonJS = this.commonJsDeps[i];\x0d\n            break;\x0d\n          }\x0d\n        }\x0d\n\x0d\n        if (isCommonJS) {\x0d\n          const importStatement = splitStack[1];\x0d\n          // TODO(@ctavan): The original error stack only provides the single\x0d\n          // line which causes the error. For multi-line import statements we\x0d\n          // cannot generate an equivalent object destructuring assignment by\x0d\n          // just parsing the error stack.\x0d\n          const oneLineNamedImports = RegExpPrototypeExec(/{.*}/\x2C importStatement);\x0d\n          const destructuringAssignment = oneLineNamedImports &&\x0d\n            RegExpPrototypeSymbolReplace(/\\s+as\\s+/g\x2C oneLineNamedImports\x2C ': ');\x0d\n          e.message = `Named export '${name}' not found. The requested module` +\x0d\n            ` '${childSpecifier}' is a CommonJS module\x2C which may not support` +\x0d\n            ' all module.exports as named exports.\\nCommonJS modules can ' +\x0d\n            'always be imported via the default export\x2C for example using:' +\x0d\n            `\\n\\nimport pkg from '${childSpecifier}';\\n${\x0d\n              destructuringAssignment ?\x0d\n                `const ${destructuringAssignment} = pkg;\\n` : ''}`;\x0d\n          const newStack = StringPrototypeSplit(e.stack\x2C '\\n');\x0d\n          newStack[3] = `SyntaxError: ${e.message}`;\x0d\n          e.stack = ArrayPrototypeJoin(newStack\x2C '\\n');\x0d\n        }\x0d\n      }\x0d\n      throw e;\x0d\n    }\x0d\n\x0d\n    for (const dependencyJob of jobsInGraph) {\x0d\n      // Calling `this.module.instantiate()` instantiates not only the\x0d\n      // ModuleWrap in this module\x2C but all modules in the graph.\x0d\n      dependencyJob.instantiated = resolvedPromise;\x0d\n    }\x0d\n  }\x0d\n\x0d\n  runSync(parent) {\x0d\n    assert(this.phase === kEvaluationPhase);\x0d\n    assert(this.module instanceof ModuleWrap);\x0d\n    let status = this.module.getStatus();\x0d\n\x0d\n    debug('ModuleJob.runSync()'\x2C status\x2C this.module);\x0d\n    if (status === kUninstantiated) {\x0d\n      // FIXME(joyeecheung): this cannot fully handle < kInstantiated. Make the linking\x0d\n      // fully synchronous instead.\x0d\n      if (this.module.getModuleRequests().length === 0) {\x0d\n        this.module.link([]);\x0d\n      }\x0d\n      this.module.instantiate();\x0d\n      status = this.module.getStatus();\x0d\n    }\x0d\n    if (status === kInstantiated || status === kErrored) {\x0d\n      const filename = urlToFilename(this.url);\x0d\n      const parentFilename = urlToFilename(parent?.filename);\x0d\n      if (this.module.hasAsyncGraph && !getOptionValue('--experimental-print-required-tla')) {\x0d\n        throw new ERR_REQUIRE_ASYNC_MODULE(filename\x2C parentFilename);\x0d\n      }\x0d\n      if (status === kInstantiated) {\x0d\n        setHasStartedUserESMExecution();\x0d\n        const namespace = this.module.evaluateSync(filename\x2C parentFilename);\x0d\n        return { __proto__: null\x2C module: this.module\x2C namespace };\x0d\n      }\x0d\n      throw this.module.getError();\x0d\n    } else if (status === kEvaluating || status === kEvaluated) {\x0d\n      if (this.module.hasAsyncGraph) {\x0d\n        const filename = urlToFilename(this.url);\x0d\n        const parentFilename = urlToFilename(parent?.filename);\x0d\n        throw new ERR_REQUIRE_ASYNC_MODULE(filename\x2C parentFilename);\x0d\n      }\x0d\n      // kEvaluating can show up when this is being used to deal with CJS <-> CJS cycles.\x0d\n      // Allow it for now\x2C since we only need to ban ESM <-> CJS cycles which would be\x0d\n      // detected earlier during the linking phase\x2C though the CJS handling in the ESM\x0d\n      // loader won't be able to emit warnings on pending circular exports like what\x0d\n      // the CJS loader does.\x0d\n      // TODO(joyeecheung): remove the re-invented require() in the ESM loader and\x0d\n      // always handle CJS using the CJS loader to eliminate the quirks.\x0d\n      return { __proto__: null\x2C module: this.module\x2C namespace: this.module.getNamespace() };\x0d\n    }\x0d\n    assert.fail(`Unexpected module status ${status}.`);\x0d\n  }\x0d\n\x0d\n  async run(isEntryPoint = false) {\x0d\n    debug('ModuleJob.run()'\x2C this.module);\x0d\n    assert(this.phase === kEvaluationPhase);\x0d\n    await this.#instantiate();\x0d\n    if (isEntryPoint) {\x0d\n      globalThis[entry_point_module_private_symbol] = this.module;\x0d\n    }\x0d\n    const timeout = -1;\x0d\n    const breakOnSigint = false;\x0d\n    setHasStartedUserESMExecution();\x0d\n    try {\x0d\n      await this.module.evaluate(timeout\x2C breakOnSigint);\x0d\n    } catch (e) {\x0d\n      explainCommonJSGlobalLikeNotDefinedError(e\x2C this.module.url\x2C this.module.hasTopLevelAwait);\x0d\n      throw e;\x0d\n    }\x0d\n    return { __proto__: null\x2C module: this.module };\x0d\n  }\x0d\n}\x0d\n\x0d\n/**\x0d\n * This is a fully synchronous job and does not spawn additional threads in any way.\x0d\n * All the steps are ensured to be synchronous and it throws on instantiating\x0d\n * an asynchronous graph. It also disallows CJS <-> ESM cycles.\x0d\n *\x0d\n * This is used for ES modules loaded via require(esm). Modules loaded by require() in\x0d\n * imported CJS are handled by ModuleJob with the isForRequireInImportedCJS set to true instead.\x0d\n * The two currently have different caching behaviors.\x0d\n * TODO(joyeecheung): consolidate this with the isForRequireInImportedCJS variant of ModuleJob.\x0d\n */\x0d\nclass ModuleJobSync extends ModuleJobBase {\x0d\n  /**\x0d\n   * @param {ModuleLoader} loader The ESM loader.\x0d\n   * @param {string} url URL of the module to be wrapped in ModuleJob.\x0d\n   * @param {ImportAttributes} importAttributes Import attributes from the import statement.\x0d\n   * @param {ModuleWrap} moduleWrap Translated ModuleWrap for the module.\x0d\n   * @param {number} phase The phase to load the module to.\x0d\n   * @param {boolean} isMain Whether the module is the entry point.\x0d\n   * @param {boolean} inspectBrk Whether this module should be evaluated with the\x0d\n   *   first line paused in the debugger (because --inspect-brk is passed).\x0d\n   */\x0d\n  constructor(loader\x2C url\x2C importAttributes\x2C moduleWrap\x2C phase = kEvaluationPhase\x2C isMain\x2C\x0d\n              inspectBrk\x2C requestType) {\x0d\n    super(loader\x2C url\x2C importAttributes\x2C phase\x2C isMain\x2C inspectBrk);\x0d\n\x0d\n    this.module = moduleWrap;\x0d\n\x0d\n    assert(this.module instanceof ModuleWrap);\x0d\n    this.linked = undefined;\x0d\n    this.type = importAttributes.type;\x0d\n    if (phase === kEvaluationPhase) {\x0d\n      this.linked = this.link(requestType);\x0d\n    }\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @param {ModuleRequestType} requestType Type of the module request.\x0d\n   * @returns {ModuleJobBase[]}\x0d\n   */\x0d\n  link(requestType) {\x0d\n    // Synchronous linking is always used for ModuleJobSync.\x0d\n    return this.syncLink(requestType);\x0d\n  }\x0d\n\x0d\n  get modulePromise() {\x0d\n    return PromiseResolve(this.module);\x0d\n  }\x0d\n\x0d\n  async run() {\x0d\n    assert(this.phase === kEvaluationPhase);\x0d\n    // This path is hit by a require'd module that is imported again.\x0d\n    const status = this.module.getStatus();\x0d\n    debug('ModuleJobSync.run()'\x2C status\x2C this.module);\x0d\n    // If the module was previously required and errored\x2C reject from import() again.\x0d\n    if (status === kErrored) {\x0d\n      throw this.module.getError();\x0d\n    } else if (status > kInstantiated) {\x0d\n      if (this.evaluationPromise) {\x0d\n        await this.evaluationPromise;\x0d\n      }\x0d\n      return { __proto__: null\x2C module: this.module };\x0d\n    } else if (status === kInstantiated) {\x0d\n      // The evaluation may have been canceled because instantiate() detected TLA first.\x0d\n      // But when it is imported again\x2C it's fine to re-evaluate it asynchronously.\x0d\n      const timeout = -1;\x0d\n      const breakOnSigint = false;\x0d\n      this.evaluationPromise = this.module.evaluate(timeout\x2C breakOnSigint);\x0d\n      await this.evaluationPromise;\x0d\n      this.evaluationPromise = undefined;\x0d\n      return { __proto__: null\x2C module: this.module };\x0d\n    }\x0d\n\x0d\n    assert.fail('Unexpected status of a module that is imported again after being required. ' +\x0d\n                `Status = ${status}`);\x0d\n  }\x0d\n\x0d\n  runSync(parent) {\x0d\n    debug('ModuleJobSync.runSync()'\x2C this.module);\x0d\n    assert(this.phase === kEvaluationPhase);\x0d\n    // TODO(joyeecheung): add the error decoration logic from the async instantiate.\x0d\n    this.module.instantiate();\x0d\n    // If --experimental-print-required-tla is true\x2C proceeds to evaluation even\x0d\n    // if it's async because we want to search for the TLA and help users locate\x0d\n    // them.\x0d\n    // TODO(joyeecheung): track the asynchroniticy using v8::Module::HasTopLevelAwait()\x0d\n    // and we'll be able to throw right after compilation of the modules\x2C using acron\x0d\n    // to find and print the TLA. This requires the linking to be synchronous in case\x0d\n    // it runs into cached asynchronous modules that are not yet fetched.\x0d\n    const parentFilename = urlToFilename(parent?.filename);\x0d\n    const filename = urlToFilename(this.url);\x0d\n    if (this.module.hasAsyncGraph && !getOptionValue('--experimental-print-required-tla')) {\x0d\n      throw new ERR_REQUIRE_ASYNC_MODULE(filename\x2C parentFilename);\x0d\n    }\x0d\n    setHasStartedUserESMExecution();\x0d\n    try {\x0d\n      const namespace = this.module.evaluateSync(filename\x2C parentFilename);\x0d\n      return { __proto__: null\x2C module: this.module\x2C namespace };\x0d\n    } catch (e) {\x0d\n      explainCommonJSGlobalLikeNotDefinedError(e\x2C this.module.url\x2C this.module.hasTopLevelAwait);\x0d\n      throw e;\x0d\n    }\x0d\n  }\x0d\n}\x0d\n\x0d\nObjectSetPrototypeOf(ModuleJobBase.prototype\x2C null);\x0d\nmodule.exports = {\x0d\n  ModuleJob\x2C ModuleJobSync\x2C ModuleJobBase\x2C\x0d\n};\x0d\n

script-source,150,node:internal/locks,'use strict';\x0d\n\x0d\nconst {\x0d\n  ObjectDefineProperties\x2C\x0d\n  Promise\x2C\x0d\n  PromisePrototypeThen\x2C\x0d\n  PromiseResolve\x2C\x0d\n  SafePromisePrototypeFinally\x2C\x0d\n  Symbol\x2C\x0d\n  SymbolToStringTag\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  ERR_ILLEGAL_CONSTRUCTOR\x2C\x0d\n  ERR_INVALID_THIS\x2C\x0d\n} = require('internal/errors');\x0d\nconst {\x0d\n  kEmptyObject\x2C\x0d\n  lazyDOMException\x2C\x0d\n  kEnumerableProperty\x2C\x0d\n} = require('internal/util');\x0d\nconst {\x0d\n  validateAbortSignal\x2C\x0d\n  validateFunction\x2C\x0d\n} = require('internal/validators');\x0d\nconst { threadId } = require('internal/worker');\x0d\nconst {\x0d\n  converters\x2C\x0d\n  createEnumConverter\x2C\x0d\n  createDictionaryConverter\x2C\x0d\n} = require('internal/webidl');\x0d\n\x0d\nconst locks = internalBinding('locks');\x0d\n\x0d\nconst kName = Symbol('kName');\x0d\nconst kMode = Symbol('kMode');\x0d\nconst kConstructLock = Symbol('kConstructLock');\x0d\nconst kConstructLockManager = Symbol('kConstructLockManager');\x0d\n\x0d\n// WebIDL dictionary LockOptions\x0d\nconst convertLockOptions = createDictionaryConverter([\x0d\n  {\x0d\n    key: 'mode'\x2C\x0d\n    converter: createEnumConverter('LockMode'\x2C [\x0d\n      'shared'\x2C\x0d\n      'exclusive'\x2C\x0d\n    ])\x2C\x0d\n    defaultValue: () => 'exclusive'\x2C\x0d\n  }\x2C\x0d\n  {\x0d\n    key: 'ifAvailable'\x2C\x0d\n    converter: (value) => !!value\x2C\x0d\n    defaultValue: () => false\x2C\x0d\n  }\x2C\x0d\n  {\x0d\n    key: 'steal'\x2C\x0d\n    converter: (value) => !!value\x2C\x0d\n    defaultValue: () => false\x2C\x0d\n  }\x2C\x0d\n  {\x0d\n    key: 'signal'\x2C\x0d\n    converter: converters.object\x2C\x0d\n  }\x2C\x0d\n]);\x0d\n\x0d\n// https://w3c.github.io/web-locks/#api-lock\x0d\nclass Lock {\x0d\n  constructor(symbol = undefined\x2C name\x2C mode) {\x0d\n    if (symbol !== kConstructLock) {\x0d\n      throw new ERR_ILLEGAL_CONSTRUCTOR();\x0d\n    }\x0d\n    this[kName] = name;\x0d\n    this[kMode] = mode;\x0d\n  }\x0d\n\x0d\n  get name() {\x0d\n    if (this instanceof Lock) {\x0d\n      return this[kName];\x0d\n    }\x0d\n    throw new ERR_INVALID_THIS('Lock');\x0d\n  }\x0d\n\x0d\n  get mode() {\x0d\n    if (this instanceof Lock) {\x0d\n      return this[kMode];\x0d\n    }\x0d\n    throw new ERR_INVALID_THIS('Lock');\x0d\n  }\x0d\n}\x0d\n\x0d\nObjectDefineProperties(Lock.prototype\x2C {\x0d\n  name: kEnumerableProperty\x2C\x0d\n  mode: kEnumerableProperty\x2C\x0d\n  [SymbolToStringTag]: {\x0d\n    __proto__: null\x2C\x0d\n    value: 'Lock'\x2C\x0d\n    writable: false\x2C\x0d\n    enumerable: false\x2C\x0d\n    configurable: true\x2C\x0d\n  }\x2C\x0d\n});\x0d\n\x0d\n// Helper to create Lock objects from internal C++ lock data\x0d\nfunction createLock(internalLock) {\x0d\n  return internalLock === null ? null : new Lock(kConstructLock\x2C internalLock.name\x2C internalLock.mode);\x0d\n}\x0d\n\x0d\n// Convert LOCK_STOLEN_ERROR to AbortError DOMException\x0d\nfunction convertLockError(error) {\x0d\n  if (error?.message === locks.LOCK_STOLEN_ERROR) {\x0d\n    return lazyDOMException('The operation was aborted'\x2C 'AbortError');\x0d\n  }\x0d\n  return error;\x0d\n}\x0d\n\x0d\n// https://w3c.github.io/web-locks/#api-lock-manager\x0d\nclass LockManager {\x0d\n  constructor(symbol = undefined) {\x0d\n    if (symbol !== kConstructLockManager) {\x0d\n      throw new ERR_ILLEGAL_CONSTRUCTOR();\x0d\n    }\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Request a Web Lock for a named resource.\x0d\n   * @param {string} name - The name of the lock resource\x0d\n   * @param {object} [options] - Lock options (optional)\x0d\n   * @param {string} [options.mode] - Lock mode: 'exclusive' or 'shared' default is exclusive\x0d\n   * @param {boolean} [options.ifAvailable] - Only grant if immediately available\x0d\n   * @param {boolean} [options.steal] - Steal existing locks with same name\x0d\n   * @param {AbortSignal} [options.signal] - Signal to abort pending lock request\x0d\n   * @param {Function} [callback] - Function called when lock is granted\x0d\n   * @returns {Promise} Promise that resolves when the lock is released\x0d\n   * @throws {TypeError} When name is not a string or callback is not a function\x0d\n   * @throws {DOMException} When validation fails or operation is not supported\x0d\n   */\x0d\n  // https://w3c.github.io/web-locks/#api-lock-manager-request\x0d\n  async request(name\x2C options\x2C callback = undefined) {\x0d\n    if (callback === undefined) {\x0d\n      callback = options;\x0d\n      options = undefined;\x0d\n    }\x0d\n\x0d\n    name = converters.DOMString(name);\x0d\n    validateFunction(callback\x2C 'callback');\x0d\n\x0d\n    if (options === undefined || typeof options === 'function') {\x0d\n      options = kEmptyObject;\x0d\n    }\x0d\n\x0d\n    // Convert LockOptions dictionary\x0d\n    options = convertLockOptions(options);\x0d\n\x0d\n    const { mode\x2C ifAvailable\x2C steal\x2C signal } = options;\x0d\n\x0d\n    validateAbortSignal(signal\x2C 'options.signal');\x0d\n\x0d\n    if (signal) {\x0d\n      signal.throwIfAborted();\x0d\n    }\x0d\n\x0d\n    if (name.startsWith('-')) {\x0d\n      // If name starts with U+002D HYPHEN-MINUS (-)\x2C then reject promise with a\x0d\n      // "NotSupportedError" DOMException.\x0d\n      throw lazyDOMException('Lock name may not start with hyphen'\x2C\x0d\n                             'NotSupportedError');\x0d\n    }\x0d\n\x0d\n    if (ifAvailable === true && steal === true) {\x0d\n      // If both options' steal dictionary member and option's\x0d\n      // ifAvailable dictionary member are true\x2C then reject promise with a\x0d\n      // "NotSupportedError" DOMException.\x0d\n      throw lazyDOMException('ifAvailable and steal are mutually exclusive'\x2C\x0d\n                             'NotSupportedError');\x0d\n    }\x0d\n\x0d\n    if (mode !== locks.LOCK_MODE_EXCLUSIVE && steal === true) {\x0d\n      // If options' steal dictionary member is true and options' mode\x0d\n      // dictionary member is not "exclusive"\x2C then return a promise rejected\x0d\n      // with a "NotSupportedError" DOMException.\x0d\n      throw lazyDOMException(`mode: "${locks.LOCK_MODE_SHARED}" and steal are mutually exclusive`\x2C\x0d\n                             'NotSupportedError');\x0d\n    }\x0d\n\x0d\n    if (signal && (steal === true || ifAvailable === true)) {\x0d\n      // If options' signal dictionary member is present\x2C and either of\x0d\n      // options' steal dictionary member or options' ifAvailable dictionary\x0d\n      // member is true\x2C then return a promise rejected with a\x0d\n      // "NotSupportedError" DOMException.\x0d\n      throw lazyDOMException('signal cannot be used with steal or ifAvailable'\x2C\x0d\n                             'NotSupportedError');\x0d\n    }\x0d\n\x0d\n    const clientId = `node-${process.pid}-${threadId}`;\x0d\n\x0d\n    // Handle requests with AbortSignal\x0d\n    if (signal) {\x0d\n      return new Promise((resolve\x2C reject) => {\x0d\n        let lockGranted = false;\x0d\n\x0d\n        const abortListener = () => {\x0d\n          if (!lockGranted) {\x0d\n            reject(signal.reason || lazyDOMException('The operation was aborted'\x2C 'AbortError'));\x0d\n          }\x0d\n        };\x0d\n\x0d\n        signal.addEventListener('abort'\x2C abortListener\x2C { once: true });\x0d\n\x0d\n        const wrappedCallback = (lock) => {\x0d\n          return PromisePrototypeThen(PromiseResolve()\x2C () => {\x0d\n            if (signal.aborted) {\x0d\n              return undefined;\x0d\n            }\x0d\n            lockGranted = true;\x0d\n            return callback(createLock(lock));\x0d\n          });\x0d\n        };\x0d\n\x0d\n        try {\x0d\n          const released = locks.request(\x0d\n            name\x2C\x0d\n            clientId\x2C\x0d\n            mode\x2C\x0d\n            steal\x2C\x0d\n            ifAvailable\x2C\x0d\n            wrappedCallback\x2C\x0d\n          );\x0d\n\x0d\n          // When released promise settles\x2C clean up listener and resolve main promise\x0d\n          SafePromisePrototypeFinally(\x0d\n            PromisePrototypeThen(released\x2C resolve\x2C (error) => reject(convertLockError(error)))\x2C\x0d\n            () => signal.removeEventListener('abort'\x2C abortListener)\x2C\x0d\n          );\x0d\n        } catch (error) {\x0d\n          signal.removeEventListener('abort'\x2C abortListener);\x0d\n          reject(convertLockError(error));\x0d\n        }\x0d\n      });\x0d\n    }\x0d\n\x0d\n    // When ifAvailable: true and lock is not available\x2C C++ passes null to indicate no lock granted\x0d\n    const wrapCallback = (internalLock) => {\x0d\n      const lock = createLock(internalLock);\x0d\n      return callback(lock);\x0d\n    };\x0d\n\x0d\n    // Standard request without signal\x0d\n    try {\x0d\n      return await locks.request(name\x2C clientId\x2C mode\x2C steal\x2C ifAvailable\x2C wrapCallback);\x0d\n    } catch (error) {\x0d\n      const convertedError = convertLockError(error);\x0d\n      throw convertedError;\x0d\n    }\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Query the current state of locks for this environment.\x0d\n   * @returns {Promise<{held: Array<object>\x2C pending: Array<object>}>} Promise resolving to lock manager snapshot\x0d\n   */\x0d\n  // https://w3c.github.io/web-locks/#api-lock-manager-query\x0d\n  async query() {\x0d\n    if (this instanceof LockManager) {\x0d\n      return locks.query();\x0d\n    }\x0d\n    throw new ERR_INVALID_THIS('LockManager');\x0d\n  }\x0d\n}\x0d\n\x0d\nObjectDefineProperties(LockManager.prototype\x2C {\x0d\n  request: kEnumerableProperty\x2C\x0d\n  query: kEnumerableProperty\x2C\x0d\n  [SymbolToStringTag]: {\x0d\n    __proto__: null\x2C\x0d\n    value: 'LockManager'\x2C\x0d\n    writable: false\x2C\x0d\n    enumerable: false\x2C\x0d\n    configurable: true\x2C\x0d\n  }\x2C\x0d\n});\x0d\n\x0d\nmodule.exports = {\x0d\n  Lock\x2C\x0d\n  LockManager\x2C\x0d\n  locks: new LockManager(kConstructLockManager)\x2C\x0d\n};\x0d\n

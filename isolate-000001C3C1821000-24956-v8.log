script-source,143,node:internal/util/trace_sigint,'use strict';\x0d\n\x0d\nconst { isMainThread } = require('worker_threads');\x0d\nconst {\x0d\n  ERR_WORKER_UNSUPPORTED_OPERATION\x2C\x0d\n} = require('internal/errors').codes;\x0d\n\x0d\nlet sigintWatchdog;\x0d\nfunction getSigintWatchdog() {\x0d\n  if (!sigintWatchdog) {\x0d\n    const { SigintWatchdog } = require('internal/watchdog');\x0d\n    sigintWatchdog = new SigintWatchdog();\x0d\n  }\x0d\n  return sigintWatchdog;\x0d\n}\x0d\n\x0d\nfunction setTraceSigInt(enable) {\x0d\n  if (!isMainThread)\x0d\n    throw new ERR_WORKER_UNSUPPORTED_OPERATION('Calling util.setTraceSigInt');\x0d\n  if (enable) {\x0d\n    getSigintWatchdog().start();\x0d\n  } else {\x0d\n    getSigintWatchdog().stop();\x0d\n  }\x0d\n};\x0d\n\x0d\nmodule.exports = {\x0d\n  setTraceSigInt\x2C\x0d\n};\x0d\n

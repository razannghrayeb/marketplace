script-source,172,node:internal/modules/esm/initialize_import_meta,'use strict';\x0d\n\x0d\nconst {\x0d\n  StringPrototypeStartsWith\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst { getOptionValue } = require('internal/options');\x0d\nconst {\x0d\n  setLazyPathHelpers\x2C\x0d\n} = internalBinding('modules');\x0d\n\x0d\nconst experimentalImportMetaResolve = getOptionValue('--experimental-import-meta-resolve');\x0d\n\x0d\n/**\x0d\n * Generate a function to be used as import.meta.resolve for a particular module.\x0d\n * @param {string} defaultParentURL The default base to use for resolution\x0d\n * @param {typeof import('./loader.js').ModuleLoader} loader Reference to the current module loader\x0d\n * @param {bool} allowParentURL Whether to permit parentURL second argument for contextual resolution\x0d\n * @returns {(specifier: string) => string} Function to assign to import.meta.resolve\x0d\n */\x0d\nfunction createImportMetaResolve(defaultParentURL\x2C loader\x2C allowParentURL) {\x0d\n  /**\x0d\n   * @param {string} specifier\x0d\n   * @param {URL['href']} [parentURL] When `--experimental-import-meta-resolve` is specified\x2C a\x0d\n   *   second argument can be provided.\x0d\n   * @returns {string}\x0d\n   */\x0d\n  return function resolve(specifier\x2C parentURL = defaultParentURL) {\x0d\n    let url;\x0d\n\x0d\n    if (!allowParentURL) {\x0d\n      parentURL = defaultParentURL;\x0d\n    }\x0d\n\x0d\n    try {\x0d\n      const request = { specifier\x2C __proto__: null };\x0d\n      ({ url } = loader.resolveSync(parentURL\x2C request));\x0d\n      return url;\x0d\n    } catch (error) {\x0d\n      switch (error?.code) {\x0d\n        case 'ERR_UNSUPPORTED_DIR_IMPORT':\x0d\n        case 'ERR_MODULE_NOT_FOUND':\x0d\n          ({ url } = error);\x0d\n          if (url) {\x0d\n            return url;\x0d\n          }\x0d\n      }\x0d\n      throw error;\x0d\n    }\x0d\n  };\x0d\n}\x0d\n\x0d\n/**\x0d\n * Create the `import.meta` object for a module.\x0d\n * @param {object} meta\x0d\n * @param {{url: string\x2C isMain?: boolean}} context\x0d\n * @param {typeof import('./loader.js').ModuleLoader} loader Reference to the current module loader\x0d\n * @returns {{dirname?: string\x2C filename?: string\x2C url: string\x2C resolve?: Function}}\x0d\n */\x0d\nfunction initializeImportMeta(meta\x2C context\x2C loader) {\x0d\n  const { url\x2C isMain } = context;\x0d\n\x0d\n  // Alphabetical\x0d\n  if (StringPrototypeStartsWith(url\x2C 'file:') === true) {\x0d\n    // dirname\x0d\n    // filename\x0d\n    setLazyPathHelpers(meta\x2C url);\x0d\n  }\x0d\n\x0d\n  meta.main = !!isMain;\x0d\n\x0d\n  if (!loader || loader.allowImportMetaResolve) {\x0d\n    meta.resolve = createImportMetaResolve(url\x2C loader\x2C experimentalImportMetaResolve);\x0d\n  }\x0d\n\x0d\n  meta.url = url;\x0d\n\x0d\n  return meta;\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  initializeImportMeta\x2C\x0d\n};\x0d\n

script-source,144,node:worker_threads,'use strict';\x0d\n\x0d\nconst {\x0d\n  isInternalThread\x2C\x0d\n  isMainThread\x2C\x0d\n  SHARE_ENV\x2C\x0d\n  resourceLimits\x2C\x0d\n  setEnvironmentData\x2C\x0d\n  getEnvironmentData\x2C\x0d\n  threadId\x2C\x0d\n  threadName\x2C\x0d\n  Worker\x2C\x0d\n} = require('internal/worker');\x0d\n\x0d\nconst {\x0d\n  MessagePort\x2C\x0d\n  MessageChannel\x2C\x0d\n  markAsUncloneable\x2C\x0d\n  moveMessagePortToContext\x2C\x0d\n  receiveMessageOnPort\x2C\x0d\n  BroadcastChannel\x2C\x0d\n} = require('internal/worker/io');\x0d\n\x0d\nconst {\x0d\n  postMessageToThread\x2C\x0d\n} = require('internal/worker/messaging');\x0d\n\x0d\nconst {\x0d\n  markAsUntransferable\x2C\x0d\n  isMarkedAsUntransferable\x2C\x0d\n} = require('internal/buffer');\x0d\n\x0d\nconst { locks } = require('internal/locks');\x0d\n\x0d\nmodule.exports = {\x0d\n  isInternalThread\x2C\x0d\n  isMainThread\x2C\x0d\n  MessagePort\x2C\x0d\n  MessageChannel\x2C\x0d\n  markAsUncloneable\x2C\x0d\n  markAsUntransferable\x2C\x0d\n  isMarkedAsUntransferable\x2C\x0d\n  moveMessagePortToContext\x2C\x0d\n  receiveMessageOnPort\x2C\x0d\n  resourceLimits\x2C\x0d\n  postMessageToThread\x2C\x0d\n  threadId\x2C\x0d\n  threadName\x2C\x0d\n  SHARE_ENV\x2C\x0d\n  Worker\x2C\x0d\n  parentPort: null\x2C\x0d\n  workerData: null\x2C\x0d\n  BroadcastChannel\x2C\x0d\n  setEnvironmentData\x2C\x0d\n  getEnvironmentData\x2C\x0d\n  locks\x2C\x0d\n};\x0d\n

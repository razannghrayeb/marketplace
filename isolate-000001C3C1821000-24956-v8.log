script-source,152,node:internal/blocklist,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayIsArray\x2C\x0d\n  Boolean\x2C\x0d\n  JSONParse\x2C\x0d\n  NumberParseInt\x2C\x0d\n  ObjectSetPrototypeOf\x2C\x0d\n  Symbol\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  BlockList: BlockListHandle\x2C\x0d\n} = internalBinding('block_list');\x0d\n\x0d\nconst {\x0d\n  customInspectSymbol: kInspect\x2C\x0d\n} = require('internal/util');\x0d\n\x0d\nconst {\x0d\n  SocketAddress\x2C\x0d\n  kHandle: kSocketAddressHandle\x2C\x0d\n} = require('internal/socketaddress');\x0d\n\x0d\nconst {\x0d\n  markTransferMode\x2C\x0d\n  kClone\x2C\x0d\n  kDeserialize\x2C\x0d\n} = require('internal/worker/js_transferable');\x0d\n\x0d\nconst { inspect } = require('internal/util/inspect');\x0d\n\x0d\nconst kHandle = Symbol('kHandle');\x0d\nconst { owner_symbol } = internalBinding('symbols');\x0d\n\x0d\nconst {\x0d\n  ERR_INVALID_ARG_VALUE\x2C\x0d\n  ERR_INVALID_ARG_TYPE\x2C\x0d\n} = require('internal/errors').codes;\x0d\n\x0d\nconst { validateInt32\x2C validateString } = require('internal/validators');\x0d\n\x0d\nclass BlockList {\x0d\n  constructor() {\x0d\n    markTransferMode(this\x2C true\x2C false);\x0d\n    this[kHandle] = new BlockListHandle();\x0d\n    this[kHandle][owner_symbol] = this;\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * Returns true if the value is a BlockList\x0d\n   * @param {any} value\x0d\n   * @returns {boolean}\x0d\n   */\x0d\n  static isBlockList(value) {\x0d\n    return value?.[kHandle] !== undefined;\x0d\n  }\x0d\n\x0d\n  [kInspect](depth\x2C options) {\x0d\n    if (depth < 0)\x0d\n      return this;\x0d\n\x0d\n    const opts = {\x0d\n      ...options\x2C\x0d\n      depth: options.depth == null ? null : options.depth - 1\x2C\x0d\n    };\x0d\n\x0d\n    return `BlockList ${inspect({\x0d\n      rules: this.rules\x2C\x0d\n    }\x2C opts)}`;\x0d\n  }\x0d\n\x0d\n  addAddress(address\x2C family = 'ipv4') {\x0d\n    if (!SocketAddress.isSocketAddress(address)) {\x0d\n      validateString(address\x2C 'address');\x0d\n      validateString(family\x2C 'family');\x0d\n      address = new SocketAddress({\x0d\n        address\x2C\x0d\n        family\x2C\x0d\n      });\x0d\n    }\x0d\n    this[kHandle].addAddress(address[kSocketAddressHandle]);\x0d\n  }\x0d\n\x0d\n  addRange(start\x2C end\x2C family = 'ipv4') {\x0d\n    if (!SocketAddress.isSocketAddress(start)) {\x0d\n      validateString(start\x2C 'start');\x0d\n      validateString(family\x2C 'family');\x0d\n      start = new SocketAddress({\x0d\n        address: start\x2C\x0d\n        family\x2C\x0d\n      });\x0d\n    }\x0d\n    if (!SocketAddress.isSocketAddress(end)) {\x0d\n      validateString(end\x2C 'end');\x0d\n      validateString(family\x2C 'family');\x0d\n      end = new SocketAddress({\x0d\n        address: end\x2C\x0d\n        family\x2C\x0d\n      });\x0d\n    }\x0d\n    const ret = this[kHandle].addRange(\x0d\n      start[kSocketAddressHandle]\x2C\x0d\n      end[kSocketAddressHandle]);\x0d\n    if (ret === false)\x0d\n      throw new ERR_INVALID_ARG_VALUE('start'\x2C start\x2C 'must come before end');\x0d\n  }\x0d\n\x0d\n  addSubnet(network\x2C prefix\x2C family = 'ipv4') {\x0d\n    if (!SocketAddress.isSocketAddress(network)) {\x0d\n      validateString(network\x2C 'network');\x0d\n      validateString(family\x2C 'family');\x0d\n      network = new SocketAddress({\x0d\n        address: network\x2C\x0d\n        family\x2C\x0d\n      });\x0d\n    }\x0d\n    switch (network.family) {\x0d\n      case 'ipv4':\x0d\n        validateInt32(prefix\x2C 'prefix'\x2C 0\x2C 32);\x0d\n        break;\x0d\n      case 'ipv6':\x0d\n        validateInt32(prefix\x2C 'prefix'\x2C 0\x2C 128);\x0d\n        break;\x0d\n    }\x0d\n    this[kHandle].addSubnet(network[kSocketAddressHandle]\x2C prefix);\x0d\n  }\x0d\n\x0d\n  check(address\x2C family = 'ipv4') {\x0d\n    if (!SocketAddress.isSocketAddress(address)) {\x0d\n      validateString(address\x2C 'address');\x0d\n      validateString(family\x2C 'family');\x0d\n      try {\x0d\n        address = new SocketAddress({\x0d\n          address\x2C\x0d\n          family\x2C\x0d\n        });\x0d\n      } catch {\x0d\n        // Ignore the error. If it's not a valid address\x2C return false.\x0d\n        return false;\x0d\n      }\x0d\n    }\x0d\n    return Boolean(this[kHandle].check(address[kSocketAddressHandle]));\x0d\n  }\x0d\n\x0d\n  /*\x0d\n  * @param {string[]} data\x0d\n  * @example\x0d\n  * const data = [\x0d\n  *   // IPv4 examples\x0d\n  *   'Subnet: IPv4 192.168.1.0/24'\x2C\x0d\n  *   'Address: IPv4 10.0.0.5'\x2C\x0d\n  *   'Range: IPv4 192.168.2.1-192.168.2.10'\x2C\x0d\n  *   'Range: IPv4 10.0.0.1-10.0.0.10'\x2C\x0d\n  *\x0d\n  *   // IPv6 examples\x0d\n  *   'Subnet: IPv6 2001:0db8:85a3:0000:0000:8a2e:0370:7334/64'\x2C\x0d\n  *   'Address: IPv6 2001:0db8:85a3:0000:0000:8a2e:0370:7334'\x2C\x0d\n  *   'Range: IPv6 2001:0db8:85a3:0000:0000:8a2e:0370:7334-2001:0db8:85a3:0000:0000:8a2e:0370:7335'\x2C\x0d\n  *   'Subnet: IPv6 2001:db8:1234::/48'\x2C\x0d\n  *   'Address: IPv6 2001:db8:1234::1'\x2C\x0d\n  *   'Range: IPv6 2001:db8:1234::1-2001:db8:1234::10'\x0d\n  * ];\x0d\n  */\x0d\n  #parseIPInfo(data) {\x0d\n    for (const item of data) {\x0d\n      if (item.includes('IPv4')) {\x0d\n        const subnetMatch = item.match(\x0d\n          /Subnet: IPv4 (\\d{1\x2C3}(?:\\.\\d{1\x2C3}){3})\\/(\\d{1\x2C2})/\x2C\x0d\n        );\x0d\n        if (subnetMatch) {\x0d\n          const { 1: network\x2C 2: prefix } = subnetMatch;\x0d\n          this.addSubnet(network\x2C NumberParseInt(prefix));\x0d\n          continue;\x0d\n        }\x0d\n        const addressMatch = item.match(/Address: IPv4 (\\d{1\x2C3}(?:\\.\\d{1\x2C3}){3})/);\x0d\n        if (addressMatch) {\x0d\n          const { 1: address } = addressMatch;\x0d\n          this.addAddress(address);\x0d\n          continue;\x0d\n        }\x0d\n\x0d\n        const rangeMatch = item.match(\x0d\n          /Range: IPv4 (\\d{1\x2C3}(?:\\.\\d{1\x2C3}){3})-(\\d{1\x2C3}(?:\\.\\d{1\x2C3}){3})/\x2C\x0d\n        );\x0d\n        if (rangeMatch) {\x0d\n          const { 1: start\x2C 2: end } = rangeMatch;\x0d\n          this.addRange(start\x2C end);\x0d\n          continue;\x0d\n        }\x0d\n      }\x0d\n      // IPv6 parsing with support for compressed addresses\x0d\n      if (item.includes('IPv6')) {\x0d\n        // IPv6 subnet pattern: supports both full and compressed formats\x0d\n        // Examples:\x0d\n        // - 2001:0db8:85a3:0000:0000:8a2e:0370:7334/64 (full)\x0d\n        // - 2001:db8:85a3::8a2e:370:7334/64 (compressed)\x0d\n        // - 2001:db8:85a3::192.0.2.128/64 (mixed)\x0d\n        const ipv6SubnetMatch = item.match(\x0d\n          /Subnet: IPv6 ([0-9a-fA-F:]{1\x2C39})\\/([0-9]{1\x2C3})/i\x2C\x0d\n        );\x0d\n        if (ipv6SubnetMatch) {\x0d\n          const { 1: network\x2C 2: prefix } = ipv6SubnetMatch;\x0d\n          this.addSubnet(network\x2C NumberParseInt(prefix)\x2C 'ipv6');\x0d\n          continue;\x0d\n        }\x0d\n\x0d\n        // IPv6 address pattern: supports both full and compressed formats\x0d\n        // Examples:\x0d\n        // - 2001:0db8:85a3:0000:0000:8a2e:0370:7334 (full)\x0d\n        // - 2001:db8:85a3::8a2e:370:7334 (compressed)\x0d\n        // - 2001:db8:85a3::192.0.2.128 (mixed)\x0d\n        const ipv6AddressMatch = item.match(/Address: IPv6 ([0-9a-fA-F:]{1\x2C39})/i);\x0d\n        if (ipv6AddressMatch) {\x0d\n          const { 1: address } = ipv6AddressMatch;\x0d\n          this.addAddress(address\x2C 'ipv6');\x0d\n          continue;\x0d\n        }\x0d\n\x0d\n        // IPv6 range pattern: supports both full and compressed formats\x0d\n        // Examples:\x0d\n        // - 2001:0db8:85a3:0000:0000:8a2e:0370:7334-2001:0db8:85a3:0000:0000:8a2e:0370:7335 (full)\x0d\n        // - 2001:db8:85a3::8a2e:370:7334-2001:db8:85a3::8a2e:370:7335 (compressed)\x0d\n        // - 2001:db8:85a3::192.0.2.128-2001:db8:85a3::192.0.2.129 (mixed)\x0d\n        const ipv6RangeMatch = item.match(/Range: IPv6 ([0-9a-fA-F:]{1\x2C39})-([0-9a-fA-F:]{1\x2C39})/i);\x0d\n        if (ipv6RangeMatch) {\x0d\n          const { 1: start\x2C 2: end } = ipv6RangeMatch;\x0d\n          this.addRange(start\x2C end\x2C 'ipv6');\x0d\n          continue;\x0d\n        }\x0d\n      }\x0d\n    }\x0d\n  }\x0d\n\x0d\n\x0d\n  toJSON() {\x0d\n    return this.rules;\x0d\n  }\x0d\n\x0d\n  fromJSON(data) {\x0d\n    // The data argument must be a string\x2C or an array of strings that\x0d\n    // is JSON parseable.\x0d\n    if (ArrayIsArray(data)) {\x0d\n      for (const n of data) {\x0d\n        if (typeof n !== 'string') {\x0d\n          throw new ERR_INVALID_ARG_TYPE('data'\x2C ['string'\x2C 'string[]']\x2C data);\x0d\n        }\x0d\n      }\x0d\n    } else if (typeof data !== 'string') {\x0d\n      throw new ERR_INVALID_ARG_TYPE('data'\x2C ['string'\x2C 'string[]']\x2C data);\x0d\n    } else {\x0d\n      data = JSONParse(data);\x0d\n      if (!ArrayIsArray(data)) {\x0d\n        throw new ERR_INVALID_ARG_TYPE('data'\x2C ['string'\x2C 'string[]']\x2C data);\x0d\n      }\x0d\n      for (const n of data) {\x0d\n        if (typeof n !== 'string') {\x0d\n          throw new ERR_INVALID_ARG_TYPE('data'\x2C ['string'\x2C 'string[]']\x2C data);\x0d\n        }\x0d\n      }\x0d\n    }\x0d\n\x0d\n    this.#parseIPInfo(data);\x0d\n  }\x0d\n\x0d\n\x0d\n  get rules() {\x0d\n    return this[kHandle].getRules();\x0d\n  }\x0d\n  [kClone]() {\x0d\n    const handle = this[kHandle];\x0d\n    return {\x0d\n      data: { handle }\x2C\x0d\n      deserializeInfo: 'internal/blocklist:InternalBlockList'\x2C\x0d\n    };\x0d\n  }\x0d\n\x0d\n  [kDeserialize]({ handle }) {\x0d\n    this[kHandle] = handle;\x0d\n    this[kHandle][owner_symbol] = this;\x0d\n  }\x0d\n}\x0d\n\x0d\nclass InternalBlockList {\x0d\n  constructor(handle) {\x0d\n    markTransferMode(this\x2C true\x2C false);\x0d\n    this[kHandle] = handle;\x0d\n    if (handle !== undefined)\x0d\n      handle[owner_symbol] = this;\x0d\n  }\x0d\n}\x0d\n\x0d\nInternalBlockList.prototype.constructor = BlockList.prototype.constructor;\x0d\nObjectSetPrototypeOf(InternalBlockList.prototype\x2C BlockList.prototype);\x0d\n\x0d\nmodule.exports = {\x0d\n  BlockList\x2C\x0d\n  InternalBlockList\x2C\x0d\n};\x0d\n

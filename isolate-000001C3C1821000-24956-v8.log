script-source,31,node:internal/process/promises,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayPrototypePush\x2C\x0d\n  ArrayPrototypeShift\x2C\x0d\n  Error\x2C\x0d\n  ObjectPrototypeHasOwnProperty\x2C\x0d\n  SafeMap\x2C\x0d\n  SafeWeakMap\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  tickInfo\x2C\x0d\n  promiseRejectEvents: {\x0d\n    kPromiseRejectWithNoHandler\x2C\x0d\n    kPromiseHandlerAddedAfterReject\x2C\x0d\n    kPromiseRejectAfterResolved\x2C\x0d\n    kPromiseResolveAfterResolved\x2C\x0d\n  }\x2C\x0d\n  setPromiseRejectCallback\x2C\x0d\n} = internalBinding('task_queue');\x0d\n\x0d\nconst { deprecate } = require('internal/util');\x0d\n\x0d\nconst {\x0d\n  noSideEffectsToString\x2C\x0d\n  triggerUncaughtException\x2C\x0d\n  exitCodes: { kGenericUserError }\x2C\x0d\n} = internalBinding('errors');\x0d\n\x0d\nconst {\x0d\n  pushAsyncContext\x2C\x0d\n  popAsyncContext\x2C\x0d\n  symbols: {\x0d\n    async_id_symbol: kAsyncIdSymbol\x2C\x0d\n    trigger_async_id_symbol: kTriggerAsyncIdSymbol\x2C\x0d\n  }\x2C\x0d\n} = require('internal/async_hooks');\x0d\nconst { isErrorStackTraceLimitWritable } = require('internal/errors');\x0d\n\x0d\nconst AsyncContextFrame = require('internal/async_context_frame');\x0d\n\x0d\n// *Must* match Environment::TickInfo::Fields in src/env.h.\x0d\nconst kHasRejectionToWarn = 1;\x0d\n\x0d\n// By default true because in cases where process is not a global\x0d\n// it is not possible to determine if the user has added a listener\x0d\n// to the process object.\x0d\nlet hasMultipleResolvesListener = true;\x0d\n\x0d\nif (process.on) {\x0d\n  hasMultipleResolvesListener = process.listenerCount('multipleResolves') !== 0;\x0d\n\x0d\n  process.on('newListener'\x2C (eventName) => {\x0d\n    if (eventName === 'multipleResolves') {\x0d\n      hasMultipleResolvesListener = true;\x0d\n    }\x0d\n  });\x0d\n\x0d\n  process.on('removeListener'\x2C (eventName) => {\x0d\n    if (eventName === 'multipleResolves') {\x0d\n      hasMultipleResolvesListener = process.listenerCount('multipleResolves') !== 0;\x0d\n    }\x0d\n  });\x0d\n}\x0d\n\x0d\n/**\x0d\n * Errors & Warnings\x0d\n */\x0d\n\x0d\nclass UnhandledPromiseRejection extends Error {\x0d\n  code = 'ERR_UNHANDLED_REJECTION';\x0d\n  name = 'UnhandledPromiseRejection';\x0d\n  /**\x0d\n   * @param {Error} reason\x0d\n   */\x0d\n  constructor(reason) {\x0d\n    super('This error originated either by throwing inside of an ' +\x0d\n    'async function without a catch block\x2C or by rejecting a promise which ' +\x0d\n    'was not handled with .catch(). The promise rejected with the reason "' +\x0d\n    noSideEffectsToString(reason) + '".');\x0d\n  }\x0d\n}\x0d\n\x0d\nclass UnhandledPromiseRejectionWarning extends Error {\x0d\n  name = 'UnhandledPromiseRejectionWarning';\x0d\n  /**\x0d\n   * @param {number} uid\x0d\n   */\x0d\n  constructor(uid) {\x0d\n    const message = 'Unhandled promise rejection. This error originated either by ' +\x0d\n    'throwing inside of an async function without a catch block\x2C ' +\x0d\n    'or by rejecting a promise which was not handled with .catch(). ' +\x0d\n    'To terminate the node process on unhandled promise ' +\x0d\n    'rejection\x2C use the CLI flag `--unhandled-rejections=strict` (see ' +\x0d\n    'https://nodejs.org/api/cli.html#cli_unhandled_rejections_mode). ' +\x0d\n    `(rejection id: ${uid})`;\x0d\n\x0d\n    // UnhandledPromiseRejectionWarning will get the stack trace from the\x0d\n    // reason\x2C so we can disable the stack trace limit temporarily for better\x0d\n    // performance.\x0d\n    if (isErrorStackTraceLimitWritable()) {\x0d\n      const stackTraceLimit = Error.stackTraceLimit;\x0d\n      Error.stackTraceLimit = 0;\x0d\n      super(message);\x0d\n      Error.stackTraceLimit = stackTraceLimit;\x0d\n    } else {\x0d\n      super(message);\x0d\n    }\x0d\n  }\x0d\n}\x0d\n\x0d\nclass PromiseRejectionHandledWarning extends Error {\x0d\n  name = 'PromiseRejectionHandledWarning';\x0d\n\x0d\n  /**\x0d\n   * @param {number} uid\x0d\n   */\x0d\n  constructor(uid) {\x0d\n    super(`Promise rejection was handled asynchronously (rejection id: ${uid})`);\x0d\n    this.id = uid;\x0d\n  }\x0d\n}\x0d\n\x0d\n/**\x0d\n * @typedef PromiseInfo\x0d\n * @property {*} reason the reason for the rejection\x0d\n * @property {number} uid the unique id of the promise\x0d\n * @property {boolean} warned whether the rejection has been warned\x0d\n * @property {object} [domain] the domain the promise was created in\x0d\n */\x0d\n\x0d\n/**\x0d\n * @type {WeakMap<Promise\x2C PromiseInfo>}\x0d\n */\x0d\nconst maybeUnhandledPromises = new SafeWeakMap();\x0d\n\x0d\n/**\x0d\n * Using a Mp causes the promise to be referenced at least for one tick.\x0d\n * @type {Map<Promise\x2C PromiseInfo>}\x0d\n */\x0d\nlet pendingUnhandledRejections = new SafeMap();\x0d\n\x0d\n/**\x0d\n * @type {Array<{promise: Promise\x2C warning: Error}>}\x0d\n */\x0d\nconst asyncHandledRejections = [];\x0d\n\x0d\n/**\x0d\n * @type {number}\x0d\n */\x0d\nlet lastPromiseId = 0;\x0d\n\x0d\n/**\x0d\n * @param {boolean} value\x0d\n */\x0d\nfunction setHasRejectionToWarn(value) {\x0d\n  tickInfo[kHasRejectionToWarn] = value ? 1 : 0;\x0d\n}\x0d\n\x0d\n/**\x0d\n * @returns {boolean}\x0d\n */\x0d\nfunction hasRejectionToWarn() {\x0d\n  return tickInfo[kHasRejectionToWarn] === 1;\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {string|Error} obj\x0d\n * @returns {obj is Error}\x0d\n */\x0d\nfunction isErrorLike(obj) {\x0d\n  return typeof obj === 'object' &&\x0d\n         obj !== null &&\x0d\n         ObjectPrototypeHasOwnProperty(obj\x2C 'stack');\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {0|1|2|3} type\x0d\n * @param {Promise} promise\x0d\n * @param {Error} reason\x0d\n */\x0d\nfunction promiseRejectHandler(type\x2C promise\x2C reason) {\x0d\n  if (unhandledRejectionsMode === undefined) {\x0d\n    unhandledRejectionsMode = getUnhandledRejectionsMode();\x0d\n  }\x0d\n  switch (type) {\x0d\n    case kPromiseRejectWithNoHandler: // 0\x0d\n      unhandledRejecti
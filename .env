# Vertex AI Virtual Try-On (project "marketplace")
# 1. Enable Vertex AI API: gcloud services enable aiplatform.googleapis.com
# 2. Auth: gcloud auth application-default login  OR  GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
GCLOUD_PROJECT=marketplace-490613
GOOGLE_CLOUD_PROJECT=marketplace-490613
GOOGLE_APPLICATION_CREDENTIALS=
TRYON_LOCATION=us-central1
TRYON_MODEL=virtual-try-on-001
TRYON_TIMEOUT=60000
# Optional: write generated outputs to GCS (gs://bucket/prefix)
TRYON_STORAGE_URI=
# Optional: max submissions per user per hour
TRYON_RATE_LIMIT=10
# Optional: force synchronous processing behavior
# true  -> wait for Vertex result before returning from submit endpoint
# false -> always background processing
TRYON_INLINE_PROCESSING=false
# Unauthenticated / Postman: numeric id for try-on jobs (no FK to users in DB)
TRYON_DEMO_USER_ID=1
GEMINI_API_KEY=AIzaSyBdSa6xIoKWWEhYKqewTbYn_z6_FvawKM0
UPSTASH_REDIS_REST_URL=https://moral-marmoset-75579.upstash.io
UPSTASH_REDIS_REST_TOKEN=gQAAAAAAASc7AAIncDFhOTA3ZDMxM2E0ZDU0ZjE5YTcyN2FkZjcwZjQ5ODQyNXAxNzU1Nzk
SEARCH_IMAGE_GARMENT_COLOR_MERGE=1
YOLO_API_URL=http://127.0.0.1:8001
SEARCH_IMAGE_KNN_FIELD=embedding_garment
SEARCH_BLIP_CAPTION_TIMEOUT_MS=5000
SEARCH_IMAGE_SHOP_SOFT_CATEGORY=true
SEARCH_IMAGE_SOFT_CATEGORY=1
SEARCH_IMAGE_SHOP_HARD_CATEGORY_STRICT=0
SEARCH_IMAGE_MIN_ACCESSORY_AREA_RATIO=0.012
SEARCH_IMAGE_MIN_ACCESSORY_CONFIDENCE=0.7
SEARCH_IMAGE_RETRIEVAL_K=700
SEARCH_IMAGE_MERCH_CANDIDATE_CAP=900
SEARCH_RELEVANCE_GATE_MODE=soft
SEARCH_FINAL_ACCEPT_MIN_TEXT=0.6
MULTI_IMAGE_STRICT_PROMPT=1
MULTI_IMAGE_PROMPT_EMBED_WEIGHT=0.6
SEARCH_IMAGE_AISLE_SOFT_WEIGHT=130
SEARCH_IMAGE_DETECTION_CATEGORY_GUARD=1
SEARCH_IMAGE_EXACT_COSINE_RERANK=1
SEARCH_IMAGE_NEAR_IDENTICAL_RAW_MIN=0.90
SEARCH_IMAGE_MERCHANDISE_SIMILARITY=1
SEARCH_IMAGE_LOW_QUALITY_MULTICROP=1
SEARCH_IMAGE_LOW_QUALITY_CONFIDENCE_MAX=0.74
SEARCH_IMAGE_LOW_QUALITY_AREA_RATIO_MAX=0.035

# Image search similarity & relevance gates (tuned April 2026)
CLIP_SIMILARITY_THRESHOLD=0.5
CLIP_IMAGE_SIMILARITY_THRESHOLD=0.45
SEARCH_FINAL_ACCEPT_MIN_IMAGE=0.38
SEARCH_IMAGE_RELAX_FLOOR=0.35

# OpenSearch kNN ef_search parameter (higher = slower queries, better recall)
# Default: 100 (balance between speed and recall). Adjust per deployment needs.
OS_EF_SEARCH=100
SEARCH_IMAGE_SHOP_RELAX=1
SEARCH_IMAGE_SHOP_CATEGORY_FALLBACK=1
SEARCH_IMAGE_MIN_RESULTS=8
SEARCH_IMAGE_DUAL_KNN=1
# optional:
SEARCH_IMAGE_EF_SEARCH=256

# Minimum finalRelevance01 score (0-1) for products to be shown. Default: 0.4
# Lower = more results (including less relevant), higher = only top matches shown
# Example: 0.4 = exclude products below 40% relevance score
SEARCH_IMAGE_SHOP_MIN_FINAL_RELEVANCE=0.4

SEARCH_IMAGE_DEBUG_RAW_EXACT_COSINE_FIRST=0
SEARCH_IMAGE_QUERY_REMBG=conditional

# ========== CRITICAL SEARCH PARAMETERS (May 2026 Tuning) ==========

# Diversity reranking lambda: 0.45 = 45% relevance, 55% diversity
# Higher (0.8+) = more diversity but may push low-similarity items up
# Lower (0.3-0.45) = more relevance-focused
SEARCH_IMAGE_DIVERSITY_LAMBDA=0.45

# Detection KNN pool cap: how many candidates to pull from OpenSearch for reranking
# Default 130 is tuned for detection-scoped image searches
# Bounds latency while keeping enough candidates for quality reranking
SEARCH_IMAGE_DETECTION_KNN_POOL_CAP=130

# Detection rerank candidate cap: max candidates passed to reranking pipeline
# Default 320 is tuned for CPU efficiency
SEARCH_IMAGE_DETECTION_RERANK_CANDIDATE_CAP=320

# Soft category mode for image search: enables aisle-aware reranking
# When ON (1): extracted categories boost relevance but don't hard-filter
# When OFF (0): detected categories force strict filtering
SEARCH_IMAGE_SOFT_CATEGORY=1

# Reranker transport/runtime optimization
SEARCH_IMAGE_RERANK_TRANSPORT=grpc
ONNX_GRPC_ADDRESS=127.0.0.1:50051
ONNX_GRPC_PORT=50051
ONNX_WARMUP_PASSES=8
TRT_FP16_ENABLE=1
TRT_ENGINE_CACHE_PATH=/tmp/trt_engine_cache
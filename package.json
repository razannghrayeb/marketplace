{
  "name": "fashion-aggregator-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon",
    "dev:with-yolo": "docker compose --profile yolo-sidecar up -d yolov8 && nodemon",
    "yolo:dev": "docker compose --profile yolo-sidecar up -d yolov8",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "start:api": "node dist/index.js",
    "start:ml": "node dist/index.js",
    "lint": "eslint .",
    "recreate-index": "npx tsx scripts/recreate-opensearch-index.ts",
    "reindex-embeddings": "npx tsx scripts/reindex-embeddings.ts",
    "resume-reindex": "npx tsx scripts/resume-reindex.ts",
    "os:prune-orphans": "npx tsx scripts/prune-orphan-product-docs.ts",
    "dedupe-products": "npx tsx scripts/dedupe-products.ts",
    "migrate:product-variants": "npx tsx scripts/migrate-to-product-variants.ts",
    "verify:product-variants": "npx tsx scripts/verify-product-variants.ts",
    "backfill:parent-descriptions": "npx tsx scripts/backfill-parent-descriptions.ts",
    "docs:endpoints": "npx tsx scripts/generate-endpoint-matrix.ts",
    "migrate:run": "npx tsx scripts/run-migration.ts",
    "migrate:bootstrap": "npx tsx scripts/bootstrap-db.ts",
    "backfill-r2": "npx tsx scripts/backfill-r2-images.ts",
    "backfill:blip-catalog": "npx tsx scripts/backfill-blip-catalog-fields.ts",
    "add-image-cdn-col": "npx tsx scripts/add-image-cdn-column.ts",
    "migrate:canonicals": "npx tsx scripts/migrate-canonicals.ts",
    "worker": "npx tsx src/workers/ingest.worker.ts",
    "models:download": "python scripts/download-models.py",
    "models:list": "python scripts/download-models.py --dry-run",
    "search:eval": "npx tsx scripts/search-eval.ts",
    "search:eval:image": "npx tsx scripts/eval-image-relevance.ts",
    "search:tune:image": "npx tsx scripts/tune-image-search-profile.ts",
    "search:test:classification": "npx tsx scripts/validate-fashion-classification-matrix.ts",
    "search:verify:phase1": "npx tsx scripts/verify-search-phase1.ts",
    "os:count": "npx tsx scripts/opensearch-count.ts",
    "test:complete-look-matrix": "npx tsx scripts/validate-complete-look-matrix.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.962.0",
    "@aws-sdk/s3-request-presigner": "^3.962.0",
    "@google/generative-ai": "^0.24.1",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@opensearch-project/opensearch": "^2.12.0",
    "@supabase/supabase-js": "^2.90.1",
    "@types/multer": "^2.0.0",
    "@types/sharp": "^0.31.1",
    "@upstash/redis": "^1.37.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.1",
    "google-auth-library": "^10.6.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "onnxruntime-node": "^1.20.0",
    "parseurl": "^1.3.3",
    "pg": "^8.11.3",
    "pino": "^9.0.0",
    "playwright": "^1.58.2",
    "prom-client": "^15.1.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "pnpm": {
    "overrides": {
      "onnxruntime-node": "$onnxruntime-node",
      "onnxruntime-common": "1.23.2"
    }
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.16.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}

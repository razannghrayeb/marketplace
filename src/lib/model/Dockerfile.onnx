# ============================================================================
# ONNX Inference Service
# Containerized FashionCLIP and attribute extraction model serving
# ============================================================================
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for caching
COPY requirements-onnx.txt .
RUN pip install --no-cache-dir -r requirements-onnx.txt

# Copy application code
COPY onnx_inference.py .
COPY onnx_server.py .

# Create models directory (models mounted at runtime)
RUN mkdir -p /models

# Environment variables
ENV PYTHONUNBUFFERED=1
ENV ONNX_NUM_THREADS=4
ENV MODEL_DIR=/models
ENV PORT=8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:${PORT}/health || exit 1

# Expose port
EXPOSE 8000

# Run the server
CMD ["python", "onnx_server.py"]

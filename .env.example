# Local/production environment template (no secrets)
# One Node process serves all routes (search, images, auth, …). Production Docker image bundles YOLO; entrypoint starts it on loopback unless YOLOV8_SERVICE_URL / YOLO_API_URL points at another host.
# Local dev without Docker: `pnpm yolo:dev` then YOLOV8_SERVICE_URL=http://127.0.0.1:8001. Optional separate container: `docker compose --profile yolo-sidecar up -d yolov8` and point YOLOV8_SERVICE_URL at it (build api with EMBEDDED_YOLO=0 for a smaller image).

# Server
PORT=8080
NODE_ENV=development
CORS_ORIGIN=*

# Database/Supabase
# postgresql://USER:PASSWORD@HOST:PORT/postgres — password must be URL-encoded if it contains @ # % etc.
# Supabase: Settings → Database → Connection string (URI). Prefer "Transaction" pooler :6543 for APIs, or "Direct".
# Session pooler (:5432 on *.pooler.supabase.com) → set PG_POOL_MAX=1 to avoid MaxClientsInSessionMode.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=product-images

# OpenSearch
OS_NODE=https://avnadmin:AVNS_seqtyHr-NLC1nO4M5Yt@os-270aa11c-lau-6d81.j.aivencloud.com:12588
OS_INDEX=products
OS_USERNAME=
OS_PASSWORD=

# Redis (Upstash free tier ~256MB — embedding cache can hit "DB capacity quota exceeded")
REDIS_URL=redis://default:gQAAAAAAASc7AAIncDFhOTA3ZDMxM2E0ZDU0ZjE5YTcyN2FkZjcwZjQ5ODQyNXAxNzU1Nzk@moral-marmoset-75579.upstash.io:6379
# Large reindex: skip Redis for embeddings entirely (optional; code also auto-disables writes when quota is hit)
#DISABLE_EMBEDDING_CACHE=1

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fashion-images
R2_PUBLIC_BASE_URL=

# Auth
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Search (text)
# Commerce mode: conservative spell correction and LLM (higher confidence thresholds).
# SEARCH_COMMERCE_MODE=1
# Spell corrector: skip corrections below 0.80/0.85 (categories/brands) when set.
# SEARCH_SPELL_CONSERVATIVE=1
# LLM rewriter: skip for short queries when rule-based corrections exist.
# SEARCH_LLM_CONSERVATIVE=1
# When true, ANY AST-extracted category becomes a hard OpenSearch filter (not only short aisle queries).
# Leave false unless you explicitly want catalog-wide category gating on every entity hit.
SEARCH_STRICT_CATEGORY_DEFAULT=false
# When true, product type from QueryAST is a hard filter (legacy). Default soft boost + taxonomy rerank.
SEARCH_STRICT_PRODUCT_TYPE=false
# Image similarity: skip hard category filter; rerank kNN hits with aisle hints (high recall).
SEARCH_IMAGE_SOFT_CATEGORY=false
# Image search gender: when true, match attr_gender OR title phrase (same idea as text search). Default strict attr only.
# SEARCH_IMAGE_GENDER_SOFT=false
# OpenSearch kNN vector field for image search: `embedding` (full frame) or `embedding_garment` after ROI reindex.
# After changing mappings, recreate the index / reindex so `embedding_garment` uses knn_vector + HNSW.
# SEARCH_IMAGE_KNN_FIELD=embedding
# Full-frame + garment ROI: run two kNN queries (`embedding` + `embedding_garment`) and merge (upload routes that supply both vectors). Default on.
# SEARCH_IMAGE_DUAL_GARMENT_FUSION=1
# SEARCH_IMAGE_DUAL_FULL_WEIGHT=0.55
# SEARCH_IMAGE_DUAL_GARMENT_WEIGHT=0.45
# Optional: per-detection Shop-the-Look kNN field (e.g. embedding_garment when that index is fully backfilled).
# Shop-the-Look / detection crops: defaults to embedding_garment when unset (matches garment ROI index).
# Override: SEARCH_IMAGE_DETECTION_KNN_FIELD=embedding
# Rare: re-enable color kNN merge when using embedding_garment (usually hurts crop vs full-image color).
# SEARCH_IMAGE_GARMENT_COLOR_MERGE=1
# Shop-the-Look: best-effort matches below ?threshold (still must pass SEARCH_IMAGE_RELAX_FLOOR). Default off.
# SEARCH_IMAGE_SHOP_RELAX=1
# Min similarity (0..1) when SHOP_RELAX is on (default 0.58).
# SEARCH_IMAGE_RELAX_FLOOR=0.58
# Retry without category filter if hard-filtered search returns nothing (can look irrelevant). Default off.
# SEARCH_IMAGE_SHOP_CATEGORY_FALLBACK=1
# Shop-the-Look: send predicted aisles for soft rerank without hard category filter (default on). Set false for strict category.
# SEARCH_IMAGE_SHOP_SOFT_CATEGORY=true
# Image search: blend global (or garment) kNN with `embedding_color` when `imageBuffer` is passed to search (weights sum to 1).
# SEARCH_IMAGE_GLOBAL_KNN_WEIGHT=0.65
# SEARCH_IMAGE_COLOR_KNN_WEIGHT=0.35
# Per–kNN OpenSearch call timeout (ms). Slow garment/color queries return [] for that branch; primary still drives results. Default 12000.
# SEARCH_IMAGE_KNN_TIMEOUT_MS=12000
# Text search: set to 0 to disable narrowing results to colorCompliance > 0 when a color is in the query.
# SEARCH_COLOR_POSTFILTER_STRICT=1

# Query understanding / relevance (defaults are safe for fashion-only marketplace)
# OpenSearch recall window before rerank + relevance threshold (pagination applies after).
# SEARCH_RECALL_WINDOW=300
# SEARCH_RECALL_MAX=500
# Drop text-search hits below this calibrated score (0..1); image search uses max(this, CLIP_SIMILARITY_THRESHOLD).
# SEARCH_FINAL_ACCEPT_MIN=0.6
# hard (default) = apply final relevance gate; soft = keep reranked OpenSearch hits without min gate (no empty page from gate alone).
# SEARCH_RELEVANCE_GATE_MODE=hard
# Post-OS score shaping for rerank similarity term: max = top-hit normalized (default); tanh = Math.tanh(raw/scale).
# SEARCH_SIMILARITY_NORMALIZE=max
# SEARCH_SIMILARITY_TANH_SCALE=10
# AST confidence required for hard category filter when not using SEARCH_STRICT_CATEGORY_DEFAULT.
# SEARCH_FILTER_HARD_MIN_CONFIDENCE=0.55
# AST confidence required to apply hard gender/age filters when the caller did not pin them.
# SEARCH_GENDER_HARD_MIN_CONFIDENCE=0.55
# Hard/soft gender filter also allows attr_gender/audience_gender unisex (default on). Set 0 to require exact binary match only.
# SEARCH_GENDER_UNISEX_OR=1
# Cross-instance QueryAST cache: requires UPSTASH_REDIS_* ; serialized AST omits embedding vector.
# SEARCH_QUERY_AST_REDIS=1
# SEARCH_QUERY_AST_REDIS_TTL_SEC=600
# SEARCH_QUERY_AST_LOCALE=default
# When SEARCH_KNN_TEXT_IN_MUST=1: demote kNN from must to should-boost if fashion embedding score is below threshold (proactive).
# SEARCH_KNN_DEMOTE_LOW_FASHION_EMB=1
# SEARCH_KNN_DEMOTE_FASHION_EMB_MAX=0.52
# CLIP text vs fashion prototype below this blocks query as off-domain when SEARCH_DOMAIN_GATE=true (no anchors).
# SEARCH_DOMAIN_EMBEDDING_REJECT_BELOW=0.3
# Block obvious non-fashion queries (e.g. "food") with empty results when true.
SEARCH_DOMAIN_GATE=true
# Text hybrid: unset = kNN is should-boost only (reduces embedding drift). Set to restore must+min_score.
# SEARCH_KNN_TEXT_IN_MUST=1
# Cap AST expansions: total + per-channel (synonyms max 5, category 3, translit 3 by default).
# SEARCH_EXPANSION_MAX_TERMS=5
# SEARCH_EXPANSION_MAX_SYNONYMS=5
# SEARCH_EXPANSION_MAX_CATEGORY=3
# SEARCH_EXPANSION_MAX_TRANSLIT=3
# Below this AST confidence, drop category expansions; synonyms drop slightly earlier.
# SEARCH_AST_EXPANSION_CONFIDENCE_MIN=0.54
# When AST confidence is below this and color came only from AST (not caller), use soft color boost vs hard filter.
# SEARCH_AST_SOFT_COLOR_CONFIDENCE=0.62
# Rerank: penalize incompatible garment families (abaya vs pants). Set to 0 to disable.
# SEARCH_TYPE_CROSS_FAMILY_PENALTY=1
# SEARCH_CROSS_FAMILY_PENALTY_WEIGHT=420
# XGB ranker tie-break (needs RANKER_API_URL + serving model). Runs on all text searches when true (ranker health + batch).
# SEARCH_USE_XGB_RANKER=true
# Full recall before pagination is default (page 2+ sees ML order). Set false for legacy: ML only on current page after slice.
# SEARCH_XGB_RERANK_FULL_RECALL=false
# Window size = max(SEARCH_XGB_FULL_RECALL_MAX, offset+limit) capped by result count.
# SEARCH_XGB_FULL_RECALL_MAX=300

# CLIP: generic similarity (text hybrid min_score caps, etc.)
# CLIP_SIMILARITY_THRESHOLD=0.6
# Image-only kNN gate (searchByImageWithSimilarity / POST /search/image). Stricter default drops loose matches.
# CLIP_IMAGE_SIMILARITY_THRESHOLD=0.68
# UI match_type "exact" when normalized similarity >= this (default 0.68; fashion CLIP rarely reaches 0.8).
# CLIP_MATCH_TYPE_EXACT_MIN=0.68
# Rerank tie-break: similarity vs audienceCompliance weights when type/color intent absent (defaults 72 / 24).
# SEARCH_RERANK_SIM_WEIGHT=72
# SEARCH_RERANK_AUD_WEIGHT=24
# Global vs color kNN blend when embedding_color exists (defaults 0.55 / 0.45).
# SEARCH_IMAGE_GLOBAL_KNN_WEIGHT=0.55
# SEARCH_IMAGE_COLOR_KNN_WEIGHT=0.45
# Soft category rerank: score += categoryMatch * boost (default 450; was 220).
# SEARCH_IMAGE_CATEGORY_BOOST=450

# Search eval: JSON lines to stdout as [search_eval] {...}; optional append file for A/B or offline analysis.
# SEARCH_EVAL_LOG=1
# SEARCH_EVAL_LOG_FILE=/tmp/search_eval.jsonl
# SEARCH_EVAL_VARIANT=control

# Virtual try-on (/api/tryon): when the client has no auth yet, set a numeric user id
# so jobs can be created (e.g. 1). Prefer x-user-id from the client in production.
TRYON_DEMO_USER_ID=
# Vertex AI Virtual Try-On (Imagen) — predict API, same project as GCLOUD_PROJECT
TRYON_LOCATION=us-central1
TRYON_MODEL=virtual-try-on-001
TRYON_TIMEOUT=60000
TRYON_BASE_STEPS=32
# TRYON_ADD_WATERMARK=false
# TRYON_PERSON_GENERATION=allow_adult
# TRYON_SAFETY_SETTING=block_medium_and_above
# TRYON_STORAGE_URI=gs://your-bucket/tryon-outputs/
# TRYON_OUTPUT_MIME=image/png

# ML / AI
# Used for multi-image intent + (if OPENAI_API_KEY / ANTHROPIC_API_KEY unset) search query LLM rewriter
GEMINI_API_KEY=
# Optional Google AI Studio model id (generateContent + query rewriter). Default: gemini-2.5-flash
GEMINI_MODEL=
# Multi-image: set to 1 to hard-filter by SEARCH_FINAL_ACCEPT_MIN like text search (default: soft, keep kNN hits)
# MULTI_IMAGE_HARD_RELEVANCE_GATE=1
# Max wall time (ms) for full Gemini intent parse; exceeded → CLIP-only ParsedIntent, meta.gemini_degraded
# MULTI_IMAGE_GEMINI_BUDGET_MS=3000
# Per Gemini generateContent timeout (ms) in IntentParserService (capped by budget above)
# MULTI_IMAGE_GEMINI_CALL_TIMEOUT_MS=10000
# Retries after transient Gemini errors in intent parser (0–5)
# GEMINI_INTENT_MAX_RETRIES=2
GCLOUD_PROJECT=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
RANKER_API_URL=
# Fashion detection (shop-the-look /api/images/*). Node calls GET {base}/health on this URL.
# Canonical: YOLOV8_SERVICE_URL. Deprecated alias: YOLO_API_URL (used only if canonical is unset).
# Local pnpm dev: `pnpm yolo:dev` then YOLOV8_SERVICE_URL=http://127.0.0.1:8001
# docker-compose may set YOLO_API_URL=http://yolov8:8001 (still works as alias).
# Production (root Dockerfile): leave unset; entrypoint starts YOLO on loopback and sets YOLOV8_SERVICE_URL.
# Optional: max ms for GET /health and /labels (first call may load HF weights). Default 120000; cap 180000.
# YOLO_READINESS_TIMEOUT_MS=120000
# POST /detect timeout (ms). Default 2000. Circuit opens after repeated failures (see YOLO_CB_*).
# YOLO_DETECT_TIMEOUT_MS=2000
# YOLO_CB_FAILURE_THRESHOLD=3
# YOLO_CB_OPEN_MS=30000
# Same-label dedupe when SEARCH_IMAGE groupByDetection=false: merge only if IoU ≥ this (default 0.5).
# YOLO_SHOP_DEDUPE_IOU_THRESHOLD=0.5
# Max concurrent per-detection kNN searches per image (default 3).
# SEARCH_IMAGE_SHOP_DETECTION_CONCURRENCY=3
YOLOV8_SERVICE_URL=
YOLO_API_URL=
ONNX_API_URL=

# Build-time only (optional, if HuggingFace repo is private)
HF_TOKEN=

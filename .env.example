# Local/production environment template (no secrets)
# Cloud Run split mode:
# - marketplace-ml  => SERVICE_ROLE=ml
# - marketplace-api => SERVICE_ROLE=api + ML_SERVICE_URL=<ml-url>

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*
SERVICE_ROLE=all
ML_SERVICE_URL=

# Database/Supabase
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=product-images

# OpenSearch
OS_NODE=http://localhost:9200
OS_INDEX=products
OS_USERNAME=
OS_PASSWORD=

# Redis (Upstash REST - required for queues)
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fashion-images
R2_PUBLIC_BASE_URL=

# Auth
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ML / AI
GEMINI_API_KEY=
GCLOUD_PROJECT=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
RANKER_API_URL=
YOLO_API_URL=
ONNX_API_URL=

# Build-time only (optional, if HuggingFace repo is private)
HF_TOKEN=

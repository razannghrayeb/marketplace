# ── Frontend only (recommended) ─────────────────────────────────────────────
# Run ONLY from this folder:  pnpm dev
# Do NOT run `pnpm dev` at the repo root unless you need the local API + Postgres.
#
# Use the hosted API (already the default in src/lib/api/client.ts if this is unset):
# NEXT_PUBLIC_API_URL=https://marketplace-933737368483.europe-west1.run.app
#
# Or delete/comment NEXT_PUBLIC_API_URL entirely — same default applies.

# ── Optional: Supabase (only for /admin/catalog scraper views in the Next app) ──
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── Full local stack (Next + API on your PC; needs repo root .env + DATABASE_URL) ──
# NEXT_PUBLIC_API_URL=http://localhost:4000

# ── If port 3001 is busy ──
# pnpm dev:3010   →  http://localhost:3010

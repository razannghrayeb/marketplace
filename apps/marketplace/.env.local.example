# Backend API base URL - required for all API calls
#
# Local development (run backend from repo root: pnpm dev):
# NEXT_PUBLIC_API_URL=http://localhost:4000
#
# Deployed on Render:
# NEXT_PUBLIC_API_URL=https://marketplace-api-933737368483.us-central1.run.app
#
# Note: Render free tier spins down after ~15 min inactivity; first request may take 30-60s
NEXT_PUBLIC_API_URL=http://localhost:4000
